	<body>
		<nav style="display: flex; justify-content: space-between; padding: 2rem; max-width: 1200px; margin: 0 auto;">
			<div style="font-weight: bold; font-size: 1.4rem;">{nome}</div>
			<div style="display: flex; gap: 20px; align-items: center;">
				<a href="#services" style="color: var(--secondary); text-decoration: none;">Services</a>
				<a href="#works" style="color: var(--secondary); text-decoration: none;">Works</a>
    <ThemeToggle />
			</div>
		</nav>

		<main style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
			<section style="display: flex; align-items: center; min-height: 80vh; gap: 50px;">
				<div style="flex: 1;">
					<span style="color: var(--accent); font-family: code; border: 1px solid var(--accent); padding: 5px 10px; border-radius: 5px;">
						{cargo}
					</span>
					<h1 class="main-header reveal" style="font-size: 4rem; margin: 20px 0;">Talk is cheap.<br/>Show me the code</h1>
					<p class="reveal" style="color: var(--secondary); font-size: 1.2rem; max-width: 500px;">
						I design and code beautifully simple things, and I love what I do.
					</p>
					<a href="#contact" class="chat-link">LET'S CHAT!</a>
				</div>
				<div style="flex: 1; text-align: right;">
					<div style="position: relative;">
    <div class="glow-astro-container" style="top: -20px; left: -20px; animation-delay: 0s;">
    <div class="astro-icon-mask"></div>
</div>
    <div class="glow-react-container" style="bottom: 50px; right: -30px; animation-delay: -2s;"> <div class="react-icon-mask"></div>
</div>
    
    <div style="position: relative; padding: 20px;">
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 110%; height: 110%; background: radial-gradient(circle, rgba(0,255,157,0.05) 0%, transparent 70%); z-index: 0;"></div>
    
    <div class="photo-sensor">
    <div id="profile-photo" class="reveal">
         <img src="/minha-foto.jpg" alt="Michael Howe" />
    </div>
</div>
</div>
</div>
				</div>
			</section>

			<section id="services" style="padding: 100px 0px;">
				<div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 100px;">
					<div style="display: flex; flex-direction: column; gap: 40px;">
						<div class="service-card" style="padding: 40px; border-radius: 15px;">
							<h3 style="color: var(--accent);">Design</h3>
							<p style="color: var(--secondary);">Create digital products with unique ideas.</p>
						</div>
						<div class="service-card" style="padding: 40px; border-radius: 15px;">
							<h3 style="color: var(--accent);">Development</h3>
							<p style="color: var(--secondary);">High performance coding for the web.</p>
						</div>
					</div>
					<div>
						<h2 style="font-size: 2.5rem;">Hello! I'm Michael.</h2>
						<p style="font-style: italic; font-size: 1.5rem;">Every great design begins with an even better story.</p>
						<p style="color: var(--secondary);">Sendo de ascendência europeia e focado no mercado global, trago uma visão técnica e minimalista para cada projeto.</p>
					</div>
				</div>
			</section>
			
<section id="works" style="padding: 100px 0;">
    <h2 style="font-size: 2.5rem; margin-bottom: 40px;">Selected Works</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
        <WorkCard 
            title="E-commerce Global" 
            description="Plataforma de vendas focada no mercado europeu." 
            tags={["Astro", "React", "Stripe"]}
            link="#"
        />
        <WorkCard 
            title="Dashboard Design" 
            description="Interface administrativa minimalista." 
            tags={["Figma", "UI/UX"]}
            link="#"
        />
    </div>
</section>
		</main>
        <footer style="margin-top: 100px; padding: 60px 2rem; border-top: 1px solid var(--card-border); text-align: center;">
    <h2 style="font-size: 2rem; margin-bottom: 20px;">Ready to start a project?</h2>
    <div style="display: flex; justify-content: center; gap: 30px; margin-bottom: 40px;">
        <a href="https://github.com/seu-user" target="_blank" class="chat-link">GITHUB</a>
        <a href="https://linkedin.com/in/seu-user" target="_blank" class="chat-link">LINKEDIN</a>
    </div>
    <p style="color: var(--secondary); font-size: 0.9rem;">
        © 2026 {nome} • Based in Brazil, looking for global opportunities.
    </p>
</footer>

	<script>
    // 1. Seleção de Elementos com Tipagem
    const cursor = document.getElementById('custom-cursor') as HTMLElement | null;
    const photoEl = document.getElementById('profile-photo') as HTMLElement | null;
    const sensor = document.querySelector('.photo-sensor') as HTMLElement | null;
    const title = document.querySelector('h1.main-header') as HTMLElement | null;

    // Variáveis de posição e controle
    let mouseX = 0, mouseY = 0;      // Posição real do mouse
    let targetX = 0, targetY = 0;    // Alvo da foto (sensor)
    let currentX = 0, currentY = 0;  // Posição atual da foto (suavizada)

    // 2. Evento de Mouse (Captura coordenadas e Gradiente)
    document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;

        // Lógica do Gradiente no H1
        if (title) {
            const rect = title.getBoundingClientRect();
            const x = ((mouseX - rect.left) / rect.width) * 100;
            const y = ((mouseY - rect.top) / rect.height) * 100;
            title.style.setProperty('--x', `${x}%`);
            title.style.setProperty('--y', `${y}%`);
        }

        // Lógica do Sensor da Foto
        if (sensor) {
            const rect = sensor.getBoundingClientRect();
            const isInside = (
                mouseX >= rect.left && mouseX <= rect.right &&
                mouseY >= rect.top && mouseY <= rect.bottom
            );

            if (isInside) {
                const centerX = rect.left + rect.width / 2;
                const centerY = rect.top + rect.height / 2;
                targetX = (mouseX - centerX) / 15;
                targetY = (mouseY - centerY) / 15;
            } else {
                targetX = 0;
                targetY = 0;
            }
        }
    });

    // 3. Loop de Animação (Cursor e Parallax)
    function animate() {
        if (cursor) {
            cursor.style.transform = `translate3d(${mouseX - 12}px, ${mouseY - 12}px, 0)`;
        }

        currentX += (targetX - currentX) * 0.1;
        currentY += (targetY - currentY) * 0.1;

        if (photoEl) {
            photoEl.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) scale(1.02)`;
        }

        requestAnimationFrame(animate);
    }
    animate();

    // 4. Gerenciamento de Hover (Refinado via Event Delegation)
    // Esse método detecta automaticamente novos elementos adicionados ao DOM
   document.addEventListener('mouseover', (e) => {
    // Adicionei .theme-switch e .slider à lista
    const target = (e.target as HTMLElement).closest('a, button, .service-card, .work-card, .project-card, h1, .chat-link, .theme-switch, .slider');
    if (target) {
        cursor?.classList.add('is-hovering');
    }
});

document.addEventListener('mouseout', (e) => {
    // Adicionei .theme-switch e .slider à lista aqui também
    const target = (e.target as HTMLElement).closest('a, button, .service-card, .work-card, .project-card, h1, .chat-link, .theme-switch, .slider');
    if (target) {
        cursor?.classList.remove('is-hovering');
    }
});
</script>
       <div id="custom-cursor">
    <div class="cursor-shape"></div>
    <span class="cursor-text">VIEW</span>
</div>
</body> </html>