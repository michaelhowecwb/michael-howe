---
// Parte Frontmatter - Dados do seu currículo
const nome = "Michael Howe";
const cargo = "Front-End Developer";
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{nome} | Portfolio</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Fira+Code&display=swap" rel="stylesheet">
		
		<style is:global>
			:root {
				--bg: #111111;
				--card-bg: #1a1a1a;
				--text: #ffffff;
				--accent: #00ff9d; /* Verde menta da imagem */
				--secondary: #888888;
			}

			[data-theme='light'] {
				--bg: #ffffff;
				--card-bg: #f5f5f5;
				--text: #111111;
				--accent: #00a86b;
				--secondary: #444444;
			}

			body {
				background-color: var(--bg);
				color: var(--text);
				font-family: 'Inter', sans-serif;
				transition: all 0.3s ease;
				margin: 0;
			}

			code { font-family: 'Fira Code', monospace; }

			.theme-switch-wrapper {
    display: flex;
    align-items: center;
}

.theme-switch {
    display: inline-block;
    height: 38px;
    position: relative;
    width: 140px;
}

.theme-switch input { display: none; }

.slider {
    background-color: #222;
    bottom: 0;
    cursor: pointer;
    left: 0;
    position: absolute;
    right: 0;
    top: 0;
    transition: .4s;
    border-radius: 34px;
    display: flex;
    align-items: center;
    padding: 0 10px;
    border: 1px solid #333;
}

/* O círculo branco que se move */
#icon-container {
    background-color: #fff;
    height: 30px;
    width: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: .4s;
    z-index: 2;
    color: #000; /* Cor do ícone dentro do círculo */
}

#theme-text {
    margin-left: 10px;
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 1px;
    transition: .4s;
    color: #fff;
}

/* Movimentação e cores quando ativo (Light Mode) */
input:checked + .slider {
    background-color: #f0f0f0;
    border-color: #ccc;
}

input:checked + .slider #icon-container {
    transform: translateX(90px);
}

input:checked + .slider #theme-text {
    transform: translateX(-35px);
    color: #000;
}
		</style>
	</head>
	<body>
		<nav style="display: flex; justify-content: space-between; padding: 2rem; max-width: 1200px; margin: 0 auto;">
			<div style="font-weight: bold; font-size: 1.2rem;">{nome}</div>
			<div style="display: flex; gap: 20px; align-items: center;">
				<a href="#services" style="color: var(--secondary); text-decoration: none;">Services</a>
				<a href="#works" style="color: var(--secondary); text-decoration: none;">Works</a>
				<div class="theme-switch-wrapper">
    <label class="theme-switch" for="checkbox">
        <input type="checkbox" id="checkbox" />
        <div class="slider">
            <div id="icon-container">
                </div>
            <span id="theme-text">DARK MODE</span>
        </div>
    </label>
</div>
			</div>
		</nav>

		<main style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
			<section style="display: flex; align-items: center; min-height: 80vh; gap: 50px;">
				<div style="flex: 1;">
					<span style="color: var(--accent); font-family: code; border: 1px solid var(--accent); padding: 5px 10px; border-radius: 5px;">
						{cargo}
					</span>
					<h1 style="font-size: 4rem; margin: 20px 0;">Talk is cheap.<br/>Show me the code</h1>
					<p style="color: var(--secondary); font-size: 1.2rem; max-width: 500px;">
						I design and code beautifully simple things, and I love what I do.
					</p>
					<a href="#contact" style="color: var(--accent); text-decoration: underline; font-weight: bold; font-family: code;">LET'S CHAT!</a>
				</div>
				<div style="flex: 1; text-align: right;">
					<div style="width: 400px; height: 500px; background: #222; display: inline-block; border-radius: 20px; position: relative; overflow: hidden;">
						<span style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #444;">Your Photo</span>
					</div>
				</div>
			</section>

			<section id="services" style="padding: 100px 0;">
				<div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 100px;">
					<div style="display: flex; flex-direction: column; gap: 20px;">
						<div class="service-card" style="background: var(--card-bg); padding: 40px; border-radius: 15px;">
							<h3 style="color: var(--accent);">Design</h3>
							<p style="color: var(--secondary);">Create digital products with unique ideas.</p>
						</div>
						<div class="service-card" style="background: var(--card-bg); padding: 40px; border-radius: 15px;">
							<h3 style="color: var(--accent);">Development</h3>
							<p style="color: var(--secondary);">High performance coding for the web.</p>
						</div>
					</div>
					<div>
						<h2 style="font-size: 2.5rem;">Hello! I'm Michael.</h2>
						<p style="font-style: italic; font-size: 1.5rem;">Every great design begins with an even better story.</p>
						<p style="color: var(--secondary);">Sendo de ascendência europeia e focado no mercado global, trago uma visão técnica e minimalista para cada projeto.</p>
					</div>
				</div>
			</section>
		</main>

		<script>
			const toggleSwitch = document.querySelector('#checkbox');
const themeText = document.querySelector('#theme-text');
const iconContainer = document.querySelector('#icon-container');
const html = document.documentElement;

// Ícones em formato SVG (moderno e leve)
const sunIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>`;
const moonIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>`;

function updateButton(isLight) {
    if (isLight) {
        themeText.innerText = "LIGHT MODE";
        iconContainer.innerHTML = sunIcon;
    } else {
        themeText.innerText = "DARK MODE";
        iconContainer.innerHTML = moonIcon;
    }
}

function switchTheme(e) {
    const isLight = e.target.checked;
    html.setAttribute('data-theme', isLight ? 'light' : 'dark');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    updateButton(isLight);
}

toggleSwitch.addEventListener('change', switchTheme, false);

// Inicialização
const currentTheme = localStorage.getItem('theme') || 'dark';
html.setAttribute('data-theme', currentTheme);
if (currentTheme === 'light') {
    toggleSwitch.checked = true;
    updateButton(true);
} else {
    updateButton(false);
}
		</script>
	</body>
</html>