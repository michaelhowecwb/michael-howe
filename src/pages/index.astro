---
import { getCollection, getEntry } from "astro:content";
import { ui } from "@utils/i18n";
import MainLayout from "@layouts/MainLayout.astro";
import WorkCard from "@components/WorkCard.astro";

const nome = "Michael Howe";
const cargo = "< Full-stack Developer />";
const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");
const t = isPt ? ui.pt : ui.en;
const currentLang = isPt ? "pt-br" : "en";

const allWorks = (await getCollection("works")) || [];
const expertiseEntries = (await getCollection("expertise")) || [];
const expertise = expertiseEntries.sort((a, b) => a.data.order - b.data.order);

const aboutEntry = await getEntry("about", "index");

// Fallback robusto garantindo que dados do Keystatic não quebrem a build (Segurança)
const localizedBio = aboutEntry?.data?.[isPt ? "pt" : "en"];
const aboutData = localizedBio
    ? {
          ...localizedBio,
          bioImage: aboutEntry.data.bioImage,
      }
    : {
          heading: isPt ? "Sobre Mim" : "About Me",
          subheading: isPt
              ? "Desenvolvedor focado em performance"
              : "Performance-focused developer",
          bio: isPt
              ? "Preencha sua bio no Keystatic."
              : "Fill your bio in Keystatic.",
          bioImage: "/minha-foto3.png",
      };

// SEO: JSON-LD Tipado Estritamente
interface PersonSchema {
    "@context": string;
    "@type": string;
    name: string;
    jobTitle: string;
    url: string;
    sameAs: string[];
    knowsAbout: string[];
}

const schema: PersonSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: nome,
    jobTitle: "Full-stack Developer",
    url: Astro.site ? Astro.site.toString() : Astro.url.origin,
    sameAs: [
        "https://github.com/michaelhowecwb",
        "https://www.linkedin.com/in/michael-howe-cwb/",
    ],
    knowsAbout: [
        "Full-stack Development",
        "React",
        "Astro",
        "TypeScript",
        "Node.js",
        "UI/UX Design",
    ],
};
const jsonLd = JSON.stringify(schema);
---

<MainLayout
    title={`${nome} | Full-stack Developer Portfolio`}
    lang={currentLang}
    description={isPt
        ? "Portfólio de Michael Howe, Desenvolvedor Full-stack em Curitiba. Especialista em interfaces premium com React, Astro e arquiteturas modernas."
        : "Michael Howe's Portfolio - Full-stack Developer based in Brazil. Specialist in premium interfaces with React, Astro, and modern architectures."}
>
    <script is:inline type="application/ld+json" set:html={jsonLd} />

    <div class="progress-wrap"><div class="progress-bar" id="bar"></div></div>
    <div class="bg-glow" id="mouse-glow"></div>

    <style>
        /* --- Accessibility & Focus (Strict Mode Standard) --- */
        *:focus-visible {
            outline: none !important;
            box-shadow: 0 0 0 2px var(--bg), 0 0 0 4px var(--accent) !important;
            border-radius: inherit;
            transition: box-shadow 0.2s ease-in-out;
        }

        /* --- Dark Mode Icon Support --- */
        .astro-dark { display: none; }
        @media (prefers-color-scheme: dark) {
            .astro-light { display: none; }
            .astro-dark { display: block; }
        }
        /* Fallbacks automáticos caso seu tema injete classes no HTML */
        html.dark .astro-light, html[data-theme="dark"] .astro-light { display: none !important; }
        html.dark .astro-dark, html[data-theme="dark"] .astro-dark { display: block !important; }

        /* --- Structure & Interaction --- */
        .text-accent {
            color: var(--accent);
        }
        .text-gradient {
            background: linear-gradient(to right, var(--accent), #fff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: bold;
        }
        .text-underline {
            border-bottom: 2px solid var(--accent);
        }
        .custom-underline {
            position: relative;
            display: inline-block;
        }
        .custom-underline::after {
            content: "";
            position: absolute;
            left: 50%;
            right: 0;
            bottom: -2px;
            height: 4px;
            background-color: var(--accent);
            border-radius: 2px;
            z-index: -1;
            transition: width 0.3s ease;
        }

        a,
        button,
        .about-card,
        .work-card,
        .letsChat {
            cursor: pointer !important;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }
        section {
            position: relative;
            padding: 120px 0;
            border-bottom: 1px solid var(--card-border);
        }

        .progress-wrap {
            position: fixed;
            top: 70px;
            left: 0;
            width: 100%;
            height: 2px;
            z-index: 1000;
            pointer-events: none;
        }
        .progress-bar {
            height: 100%;
            background: var(--accent);
            width: 0%;
            transition: width 0.1s ease-out;
            box-shadow: 0 0 10px var(--accent);
        }

        .bg-glow {
            position: fixed;
            top: 0;
            left: 0;
            width: 600px;
            height: 600px;
            background: radial-gradient(
                circle,
                var(--accent) 0%,
                transparent 70%
            );
            opacity: 0;
            filter: blur(100px);
            z-index: 0;
            pointer-events: none;
            will-change: transform, opacity;
            transition: opacity 1s ease;
        }
        .bg-glow.visible {
            opacity: 0.08;
        }

        /* --- Hero Section --- */
        .hero-container {
            display: flex;
            align-items: center;
            min-height: 85vh;
            padding-top: 40px;
            gap: 60px;
        }
        
        .hero-content {
            flex: 1.2;
        }

        .hero-cargo {
            color: var(--accent);
            font-family: 'Fira Code', monospace;
            font-size: 1.2rem;
            font-weight: bold;
        }

        h1.main-header {
            font-size: clamp(3.5rem, 12vw, 6rem);
            font-weight: 900;
            line-height: 0.85;
            letter-spacing: -4px;
            background: radial-gradient(
                circle at var(--x, 50%) var(--y, 50%),
                var(--accent) 0%,
                var(--text) 100%
            );
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 2px 10px var(--dropshadow-rgb));
            margin: 20px 0 30px;
            padding: 20px 0;
        }
        .hero-subtitle {
            color: var(--secondary);
            font-size: 1.3rem;
            max-width: 500px;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        .letsChat {
            text-decoration: none;
            display: inline-block;
            padding: 14px 35px;
            border: 2px solid var(--accent);
            border-radius: 50px;
            color: var(--accent);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: transparent;
        }
        .letsChat:hover,
        .letsChat:focus-visible {
            background: var(--accent);
            color: #000;
            transform: translateY(-5px);
            box-shadow: 0 10px 20px var(--dropshadow-rgb);
        }

        /* --- Visual Wrapper --- */
        .visual-wrapper {
            flex: 1;
            display: flex;
            justify-content: center;
            position: relative;
        }
        .photo-sensor {
            width: 380px;
            height: 480px;
            position: relative;
            z-index: 50;
        }
        #profile-photo {
            position: absolute;
            width: 100%;
            height: 100%;
            transition: transform 0.1s ease-out;
            border-radius: 20px;
            overflow: hidden;
            /*background-color: var(--card-border);*/ /* Evita CLS e FOUC */
        }
        #profile-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .floating-icon {
            position: absolute;
            z-index: 60;
            filter: drop-shadow(0 0px 25px rgba(var(--accent-rgb), 0.3));
            pointer-events: none;
            transition: all 0.3s ease;
        }

        @keyframes float-1 {
            0%,
            100% {
                transform: translateY(0) rotate(0);
            }
            50% {
                transform: translateY(-20px) rotate(5deg);
            }
        }
        @keyframes float-2 {
            0%,
            100% {
                transform: translateY(0) rotate(0);
            }
            50% {
                transform: translateY(15px) rotate(-8deg);
            }
        }
        @keyframes float-3 {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.1) translateY(-10px);
            }
        }

        .anim-1 {
            animation: float-1 4s ease-in-out infinite;
        }
        .anim-2 {
            animation: float-2 5s ease-in-out infinite;
        }
        .anim-3 {
            animation: float-3 6s ease-in-out infinite;
        }

        /* --- About Section --- */
        #about {
            background-color: var(--section-alt-rgba);
            backdrop-filter: blur(10px);
        }
        .about-container {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 80px;
            align-items: start;
        }
        .expertise-list {
            display: flex;
            flex-direction: column;
            gap: 40px;
        }
        .about-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--card-border);
            padding: 40px;
            border-radius: 20px;
            box-shadow: -6px -6px 0px var(--accent);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
        }
        .spotlight-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(
                600px circle at var(--mouse-x) var(--mouse-y),
                rgba(255, 255, 255, 0.08),
                transparent 40%
            );
            z-index: 0;
            opacity: 0;
            transition: opacity 0.5s ease;
            pointer-events: none;
        }
        .spotlight-card:hover::before {
            opacity: 1;
        }
        .about-card:hover,
        .about-card:focus-visible {
            transform: translate(4px, 4px);
            box-shadow: 6px 6px 0px var(--accent);
            border: 1px solid var(--accent);
        }

        .about-card-title {
            color: var(--accent);
            font-size: 1.5rem;
            margin-bottom: 15px;
            font-weight: 800;
        }

        .about-card-desc {
            color: var(--secondary);
            line-height: 1.6;
            margin: 0;
        }

        .intro-text h2 {
            font-size: 3rem;
            font-weight: 900;
            letter-spacing: -2px;
            margin-bottom: 20px;
        }

        .intro-sub {
            color: var(--text);
            font-style: italic;
            font-size: 1.4rem;
            opacity: 0.8;
        }

        .intro-bio {
            color: var(--secondary);
            line-height: 1.8;
            font-size: 1.1rem;
            margin-bottom: 30px;
        }

        .intro-text .bio-line {
            border-left: 6px solid var(--accent);
            padding-left: 25px;
            margin-top: 30px;
        }

        /* --- Works Section --- */
        #works {
            padding: 60px 0 200px 0;
            border-bottom: none !important;
        }
        .works-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 40px;
        }
        .selected-works-title {
            padding-left: 2rem;
            font-size: 3rem;
            font-weight: 900;
            margin-bottom: 60px;
            letter-spacing: -2px;
        }
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.2, 0.6, 0.2, 1);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        @media (max-width: 992px) {
            section {
                padding: 60px 0;
            }
            .hero-container {
                flex-direction: column;
                text-align: center;
                gap: 40px;
            }
            .about-container {
                grid-template-columns: 1fr;
                gap: 50px;
                display: flex;
                flex-direction: column;
            }
            .intro-text {
                order: -1;
                text-align: center;
                margin: auto;
            }
            .intro-text .bio-line {
                border-left: none;
                border-top: 4px solid var(--accent);
                padding: 25px 0 0 0;
            }
            .expertise-list {
                order: 2;
                width: 100%;
            }
            .photo-sensor {
                width: 280px;
                height: 350px;
            }
            .floating-icon {
                transform: scale(0.7);
                opacity: 0.8;
            }
            .intro-text h2 {
                font-size: 2.2rem;
            }
        }
    </style>

    <main style="position: relative; z-index: 1;">
        <section id="home" class="container">
            <div class="hero-container">
                <div class="hero-content reveal">
                    <h3 class="hero-cargo">{cargo}</h3>
                    <h1 class="main-header">{t["hero.title"]}</h1>
                    <p class="hero-subtitle">{t["hero.subtitle"]}</p>
                    <button id="hero-chat-btn" class="letsChat magnetic-btn">
                        {t["lets.chat"]}
                    </button>
                </div>

                <div class="visual-wrapper reveal">
                    <div class="floating-icon anim-1" style="top: -20px; left: -30px; width: 60px;">
                        <img src="/icons/Astro_LightMode.svg" class="astro-light" alt="Astro Logo" style="width: 100%; height: auto;" />
                        <img src="/icons/Astro_DarkMode.svg" class="astro-dark" alt="Astro Logo" style="width: 100%; height: auto;" />
                    </div>

                    <div class="floating-icon anim-2" style="top: 20px; right: -40px; width: 75px;">
                        <img src="/icons/React.svg" alt="React Logo" style="width: 100%; height: auto;" />
                    </div>

                    <div class="floating-icon anim-3" style="top: 50%; right: -65px; width: 55px;">
                        <img src="/icons/Kotlin.svg" alt="Kotlin Logo" style="width: 100%; height: auto;" />
                    </div>

                    <div class="floating-icon anim-3" style="top: 35%; left: -85px; width: 50px;">
                        <img src="/icons/Java.svg" alt="Java Logo" style="width: 100%; height: auto;" />
                    </div>

                    <div class="floating-icon anim-1" style="bottom: 60px; left: -60px; width: 50px;">
                        <svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
                            <path d="M0 0h256v256H0z" fill="#F7DF1E"></path>
                            <path d="M67.3 213.9l19.6-11.8c3.8 6.7 7.2 12.4 15.5 12.4 7.9 0 12.9-3.1 12.9-15.1v-81.8h24v81.8c0 24.9-14.6 36.3-35.9 36.3-19.2 0-30.4-10-36.1-22M152.4 211.3l19.6-11.3c5.1 8.4 11.8 14.6 23.7 14.6 10 0 16.3-5 16.3-11.9 0-8.2-6.5-11.2-17.5-16l-6-2.6c-17.4-7.4-28.9-16.7-28.9-36.3 0-18 13.8-31.8 35.2-31.8 15.3 0 26.3 5.3 34.2 19.3l-18.7 12c-4.1-7.4-8.6-10.3-15.5-10.3-7 0-11.5 4.5-11.5 10.3 0 7.2 4.5 10.1 14.8 14.6l6 2.6c20.5 8.7 32 17.7 32 37.8 0 21.6-17 33.5-39.9 33.5-22.3 0-36.7-10.6-43.8-24.6" fill="#000"></path>
                        </svg>
                    </div>

                    <div class="floating-icon anim-2" style="bottom: -15px; right: -25px; width: 60px;">
                        <img src="/icons/Python.svg" alt="Python Logo" style="width: 100%; height: auto;" />
                    </div>

                    <div class="photo-sensor">
                        <div id="profile-photo">
                            <img
                                src={aboutData.bioImage}
                                alt={nome}
                                width="380"
                                height="480"
                                loading="eager"
                                fetchpriority="high"
                                decoding="async"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="about">
            <div class="container about-container">
                <div class="expertise-list">
                    {
                        expertise.map((item) => {
                            const card = item.data[isPt ? "pt" : "en"];
                            return (
                                <div class="about-card spotlight-card reveal">
                                    <h3 class="about-card-title">
                                        {card.title}
                                    </h3>
                                    <p class="about-card-desc">
                                        {card.description}
                                    </p>
                                </div>
                            );
                        })
                    }
                </div>

                <div class="intro-text">
                    <h2 class="reveal">{aboutData.heading}</h2>
                    <p class="intro-sub reveal">
                        {aboutData.subheading}
                    </p>
                    <div class="bio-line reveal">
                        <p class="intro-bio">
                            {aboutData.bio}
                        </p>
                        <a
                            href={isPt ? "/pt/about" : "/about"}
                            class="letsChat magnetic-btn"
                        >
                            {
                                isPt
                                    ? "Mais sobre mim →"
                                    : "Learn more about me →"
                            }
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section id="works" class="container">
            <h2 class="selected-works-title reveal">
                <span class="custom-underline">{t["works.title"]}</span>
            </h2>
            <div class="works-grid">
                {
                    allWorks.map((work) => {
                        const content = work.data[isPt ? "pt" : "en"];
                        const cleanId = work.id.split("/")[0];
                        return (
                            <div class="reveal">
                                <WorkCard
                                    title={content.title}
                                    description={content.shortDescription}
                                    tags={work.data.tags}
                                    thumbnail={work.data.thumbnail}
                                    link={
                                        isPt
                                            ? `/pt/work/${cleanId}`
                                            : `/work/${cleanId}`
                                    }
                                />
                            </div>
                        );
                    })
                }
            </div>
        </section>
    </main>
</MainLayout>

<script>
    function initHome() {
        const bar = document.getElementById("bar");
        const glowEl = document.getElementById("mouse-glow");
        const title = document.querySelector("h1.main-header") as HTMLElement;
        const photoEl = document.getElementById("profile-photo");
        const photoSensor = document.querySelector(".photo-sensor");
        const magneticBtns = document.querySelectorAll(".magnetic-btn");
        const spotlightCards = document.querySelectorAll(".spotlight-card");
        const heroSection = document.getElementById("home");

        // Intersection Observer for Animation Throttling
        let isHeroVisible = true;
        if (heroSection && window.IntersectionObserver) {
            const heroObserver = new IntersectionObserver((entries) => {
                isHeroVisible = entries[0].isIntersecting;
            }, { threshold: 0 });
            heroObserver.observe(heroSection);
        }

        // DOM caching para evitar Layout Thrashing
        let cachedRects = {
            cards: [] as DOMRect[],
            title: null as DOMRect | null,
            photoSensor: null as DOMRect | null,
            btns: [] as DOMRect[]
        };

        function updateCache() {
            cachedRects.cards = Array.from(spotlightCards).map(el => el.getBoundingClientRect());
            if (title) cachedRects.title = title.getBoundingClientRect();
            if (photoSensor) cachedRects.photoSensor = photoSensor.getBoundingClientRect();
            cachedRects.btns = Array.from(magneticBtns).map(el => el.getBoundingClientRect());
        }

        // Debounce nativo para mitigar problemas de performance no Resize (Evita congelamento da tela)
        function debounce(func: Function, wait: number) {
            let timeout: ReturnType<typeof setTimeout>;
            return function(this: any, ...args: any[]) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        const debouncedUpdateCache = debounce(updateCache, 150);

        // Inicializa cache e atualiza no resize com debounce
        updateCache();
        window.addEventListener('resize', debouncedUpdateCache);
        window.addEventListener('scroll', updateCache, { passive: true });

        // Contact Button
        document
            .getElementById("hero-chat-btn")
            ?.addEventListener("click", () => {
                window.dispatchEvent(new CustomEvent("openContactModal"));
            });

        const isTouch = window.matchMedia("(pointer: coarse)").matches;
        let mouseX = 0,
            mouseY = 0,
            currentX = 0,
            currentY = 0;
        const ease = 0.15;
        let isMoving = false;
        let pTargetX = 0,
            pTargetY = 0,
            pCurrX = 0,
            pCurrY = 0;

        if (!isTouch) {
            window.addEventListener("mousemove", (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;

                if (glowEl && !isMoving) {
                    isMoving = true;
                    glowEl.classList.add("visible");
                    requestAnimationFrame(animateGlow);
                }

                // Spotlight Cards (Performance otimizada)
                spotlightCards.forEach((card, index) => {
                    const rect = cachedRects.cards[index];
                    if (rect) {
                        (card as HTMLElement).style.setProperty(
                            "--mouse-x",
                            `${e.clientX - rect.left}px`
                        );
                        (card as HTMLElement).style.setProperty(
                            "--mouse-y",
                            `${e.clientY - rect.top}px`
                        );
                    }
                });

                // Title Gradient 
                if (title && cachedRects.title) {
                    const rect = cachedRects.title;
                    title.style.setProperty(
                        "--x",
                        `${((e.clientX - rect.left) / rect.width) * 100}%`
                    );
                    title.style.setProperty(
                        "--y",
                        `${((e.clientY - rect.top) / rect.height) * 100}%`
                    );
                }

                // Profile Photo Sensor
                if (photoSensor && cachedRects.photoSensor) {
                    const rect = cachedRects.photoSensor;
                    const inside =
                        e.clientX >= rect.left &&
                        e.clientX <= rect.right &&
                        e.clientY >= rect.top &&
                        e.clientY <= rect.bottom;
                    pTargetX = inside
                        ? (e.clientX - (rect.left + rect.width / 2)) / 7
                        : 0;
                    pTargetY = inside
                        ? (e.clientY - (rect.top + rect.height / 2)) / 7
                        : 0;
                }

                // Magnetic Buttons
                magneticBtns.forEach((btn, index) => {
                    const rect = cachedRects.btns[index];
                    if (rect) {
                        const dist = Math.hypot(
                            e.clientX - (rect.left + rect.width / 2),
                            e.clientY - (rect.top + rect.height / 2),
                        );
                        if (dist < 80) {
                            const bx = (e.clientX - (rect.left + rect.width / 2)) * 0.3;
                            const by = (e.clientY - (rect.top + rect.height / 2)) * 0.3;
                            (btn as HTMLElement).style.transform = `translate3d(${bx}px, ${by}px, 0)`;
                        } else {
                            (btn as HTMLElement).style.transform = `translate3d(0, 0, 0)`;
                        }
                    }
                });
            });

            function animateGlow() {
                if (!isMoving) return;
                currentX += (mouseX - currentX) * ease;
                currentY += (mouseY - currentY) * ease;
                if (glowEl)
                    glowEl.style.transform = `translate3d(${currentX - 300}px, ${currentY - 300}px, 0)`;
                requestAnimationFrame(animateGlow);
            }

            function animatePhoto() {
                if (!isHeroVisible) {
                    requestAnimationFrame(animatePhoto);
                    return;
                }
                pCurrX += (pTargetX - pCurrX) * 0.1;
                pCurrY += (pTargetY - pCurrY) * 0.1;
                if (photoEl)
                    photoEl.style.transform = `translate3d(${pCurrX}px, ${pCurrY}px, 0) scale(${pTargetX !== 0 ? 1.05 : 1})`;
                requestAnimationFrame(animatePhoto);
            }
            animatePhoto();
        }

        window.addEventListener("scroll", () => {
            if (bar) {
                const winH =
                    document.documentElement.scrollHeight -
                    document.documentElement.clientHeight;
                bar.style.width = (window.scrollY / winH) * 100 + "%";
            }
        }, { passive: true });

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting)
                        entry.target.classList.add("active");
                });
            },
            { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
        );

        document
            .querySelectorAll(".reveal")
            .forEach((el) => observer.observe(el));
    }

    document.addEventListener("astro:page-load", initHome);
</script>