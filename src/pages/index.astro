---
import ThemeToggle from '../components/ThemeToggle.astro';
import WorkCard from '../components/WorkCard.astro';
const nome = "Michael Howe";
const cargo = "Front-End Developer";
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{nome} | Portfolio</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Fira+Code&display=swap" rel="stylesheet">
		
		<style is:global>
:root {
    --bg: #0b0b0b; /* Um preto mais profundo e elegante */
    --card-bg: #141414; 
    --text: #ffffff;
    --cursor-text: #111111;
    --text-rgb: 255, 255, 255;
    --accent: #00ff9d; /* Neon para o Dark */
    --secondary: #a0a0a0; /* Um cinza um pouco mais claro para leitura */
    --card-border: rgba(255, 255, 255, 0.05);
}

[data-theme='light'] {
    --bg: #f9f9f9; 
    --card-bg: #ffffff; 
    --text: #111111;
    --cursor-text: #ffffff;
    --text-rgb: 0, 0, 0;
    --accent: #008f5d; /* Verde mais denso para contraste no claro */
    --secondary: #666666;
    --card-border: rgba(0, 0, 0, 0.06);
}

			body {
				background-color: var(--bg);
				color: var(--text);
				font-family: 'Inter', sans-serif;
				transition: all 0.3s ease;
				margin: 0;
			}

			code { font-family: 'Fira Code', monospace; }
html, body {
    margin: 0;
    padding: 0;
    cursor: none; /* Esconde a seta padrão */
}
a, button, .chat-link, .service-card, .work-card, h1 {
    cursor: none !important;
}

section {
    position: relative;
    border-bottom: 1px solid var(--card-border); /* Linhas sutis dividindo o conteúdo */
}
			@keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
    100% { transform: translateY(0px); }
}
@media (max-width: 768px) {
    h1 { font-size: 2.5rem !important; }
    section { flex-direction: column; text-align: center; gap: 20px; }
    div[style*="width: 400px"] { width: 100% !important; max-width: 300px; height: 380px !important; }
    .glow-astro-container, .glow-react-container { display: none; }
}
.reveal {
    animation: fadeUp 1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    opacity: 0;
}
.reveal:nth-child(1) { animation-delay: 0.1s; }
.reveal:nth-child(2) { animation-delay: 0.3s; }
.reveal:nth-child(3) { animation-delay: 0.5s; }
.reveal:nth-child(4) { animation-delay: 0.7s; }

@keyframes fadeUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
    }
}

#custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none !important;
    z-index: 10000;
}

.cursor-shape {
    position: absolute;
    width: 100%;
    height: 100%;
    /* No estado normal (círculo) */
    background: rgba(var(--bg, 255, 255, 255), 0.1);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1.5px solid rgba(var(--text-rgb, 255, 255, 255), 0.8);
    border-radius: 50%;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* ESTADO DE HOVER - A SOLUÇÃO DEFINITIVA */
#custom-cursor.is-hovering .cursor-shape {
    transform: scale(1.8);
    background: rgba(var(--text-rgb, 255, 255, 255), 0.8);
    border-radius: 0%;
    border: none; 
    clip-path: polygon(50% 5%, 62% 38%, 95% 50%, 62% 62%, 50% 95%, 38% 62%, 5% 50%, 38% 38%);
}

/* Criamos a borda da estrela usando um elemento antes dela */
#custom-cursor.is-hovering .cursor-shape::before {
    content: "";
    position: absolute;
    /* Alinhamos exatamente com o contêiner */
    inset: 0; 
    /* Cor idêntica à borda do seu círculo (branco 0.4) */
    background: rgba(var(--text-rgb, 255, 255, 255), 0.8);
    clip-path: polygon(50% 5%, 62% 38%, 95% 50%, 62% 62%, 50% 95%, 38% 62%, 5% 50%, 38% 38%);
    z-index: -1;
}

/* Criamos um "buraco" no meio para que reste apenas a borda */
#custom-cursor.is-hovering .cursor-shape::after {
    content: "";
    position: absolute;
    /* Criamos a espessura de 1.5px */
    inset: 1.5px; 
    /* Cor de fundo com a transparência desejada */
    background: rgba(var(--bg, 255, 255, 255), 0.8);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    clip-path: polygon(50% 5%, 62% 38%, 95% 50%, 62% 62%, 50% 95%, 38% 62%, 5% 50%, 38% 38%);
    z-index: -1;
}

.cursor-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    font-family: 'Inter', sans-serif;
    font-size: 5px;
    font-weight: 900;
    /* Cor padrão */
    color: var(--cursor-text);
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 10;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    pointer-events: none;
}

#custom-cursor.is-hovering .cursor-text {
    opacity: 1;
    /* Forçamos a cor verde neon para garantir contraste total */
    color: var(--cursor-text); 
    transform: translate(-50%, -50%) scale(1);
    /* Adicionamos um leve brilho para ajudar na leitura sobre o branco */
    text-shadow: 0 0 4px rgba(0, 0, 0, 0.2);
}
/* Em celulares (touch), volta o cursor padrão e esconde a bola */
@media (pointer: coarse) {
    #custom-cursor {
        display: none;
    }
    html, body {
        cursor: auto;
    }
    a, button, .chat-link, .service-card, .work-card, h1 {
        cursor: pointer !important;
    }
}

nav a, .chat-link {
    position: relative;
    text-decoration: none;
    transition: color 0.3s;
}

nav a::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -5px;
    left: 50%;
    background-color: var(--accent);
    transition: all 0.3s ease-in-out;
    transform: translateX(-50%);
}

nav a:hover::after {
    width: 100%;
}

nav a:hover {
    color: var(--accent) !important;
}
/* O sensor precisa estar NA FRENTE de tudo para detectar o mouse */
.photo-sensor {
    position: relative;
    width: 400px;
    height: 500px;
    margin: auto;
    /*background: rgba(255,0,0,0.2);*/
    z-index: 20; /* Maior que a foto e os ícones flutuantes */
    overflow: visible; /* Importante para a foto poder "sair" um pouco da borda */
}

#profile-photo {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    /* Remova o transition: transform daqui */
    will-change: transform;
    z-index: 10;
}
#profile-photo img {
    width: 100%;
    height: 100%;
    border-radius: 15px;
    object-fit: cover;
    display: block;
    /* Remova o transform: scale(1.1) daqui se quiser tirar o zoom fixo */
}
.glow-astro-container {
    position: absolute;
    width: 50px;
    height: 50px;
    filter: drop-shadow(0 0 15px rgba(188, 82, 238, 0.9));
    animation: float 4s ease-in-out infinite;
    z-index: 10;
}

.astro-icon-mask {
    width: 100%;
    height: 100%;
    background-color: #BC52EE;
    
    -webkit-mask: url('/icons/astro.svg') no-repeat center;
    mask: url('/icons/astro.svg') no-repeat center;
    -webkit-mask-size: contain;
    mask-size: contain;
}
.glow-react-container {
    position: absolute;
    width: 50px;
    height: 50px;
    filter: drop-shadow(0 0 15px rgba(97, 218, 251, 0.9));
    animation: float 4s ease-in-out infinite;
    z-index: 10;
}

.react-icon-mask {
    width: 100%;
    height: 100%;
    background-color: #61DAFB;
    
    -webkit-mask: url('/icons/react.svg') no-repeat center;
    mask: url('/icons/react.svg') no-repeat center;
    -webkit-mask-size: contain;
    mask-size: contain;
}
.service-card, .project-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    /* No Light Mode, sombras suaves funcionam melhor que sombras sólidas */
    box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.03); 
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
}

.service-card:hover, .project-card:hover {
    /* Inverte a sombra no hover para dar sensação de clique/pressão */
    transform: translate(4px, 4px);
    box-shadow: 4px 4px 0px var(--accent);
}

[data-theme='dark'] .service-card:hover {
    background: #1d1d1d;
    border-color: var(--accent);
}

[data-theme='light'] .service-card:hover {
    background: #ffffff;
    box-shadow: 0px 20px 40px rgba(0, 0, 0, 0.06);
    border-color: var(--accent);
}
h1.main-header {
    font-size: 4.5rem;
    line-height: 1.1;
    /* Cursor de link para indicar interatividade */
    cursor: pointer;
    
    /* Radial gradient ajustado para ser mais suave */
background: radial-gradient(
        circle at var(--x) var(--y), 
        var(--accent), 
        var(--text) 80% /* Força o gradiente a terminar na cor do texto principal */
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: background 0.1s ease-out, filter 0.3s ease;
}
h1.main-header:hover {
    filter: drop-shadow(0 0 10px rgba(0, 255, 157, 0.2));
}
.chat-link {
    display: inline-block;
    padding: 12px 24px;
    border: 1px solid var(--accent);
    border-radius: 50px;
    color: var(--accent);
    text-decoration: none;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.8rem;
    transition: all 0.3s ease;
    background: transparent;
    border: 2px solid var(--accent); /* Borda mais grossa para presença */
    color: var(--accent);
}

.chat-link:hover {
    background: var(--accent);
    color: #111;
    box-shadow: 0 0 20px rgba(0, 255, 157, 0.4);
}
[data-theme='light'] .chat-link:hover {
    background: var(--accent);
    color: #ffffff; /* Texto branco no botão verde escuro */
    box-shadow: 0 10px 20px rgba(0, 112, 74, 0.2);
}
@keyframes reveal {
    0% { transform: translateY(30px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
}

		</style>
	</head>
	<link rel="icon" type="image/png" href="/favicon.png" />
