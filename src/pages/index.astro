---
import ThemeToggle from '../components/ThemeToggle.astro';
import WorkCard from '../components/WorkCard.astro';
const nome = "Michael Howe";
const cargo = "Front-End Developer";
---

<html lang="pt-br">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{nome} | Portfolio</title>
        
        <link rel="icon" type="image/png" href="/favicon.png" />
        
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Fira+Code&display=swap" rel="stylesheet">
        
        <style is:global>
            :root {
                --bg: #0b0b0b;
                --card-bg: #141414; 
                --text: #ffffff;
                --cursor-text: #111111;
                --text-rgb: 255, 255, 255;
                --accent: #00ff9d;
                --secondary: #a0a0a0;
                --card-border: rgba(255, 255, 255, 0.05);
            }

            [data-theme='light'] {
                --bg: #f9f9f9; 
                --card-bg: #ffffff; 
                --text: #111111;
                --cursor-text: #ffffff;
                --text-rgb: 0, 0, 0;
                --accent: #008f5d;
                --secondary: #666666;
                --card-border: rgba(0, 0, 0, 0.06);
            }

            /* Reset de Segurança para o Vercel */
            * { box-sizing: border-box; }
            
            img {
                max-width: 100%;
                height: auto;
                display: block;
            }

            body {
                background-color: var(--bg);
                color: var(--text);
                font-family: 'Inter', sans-serif;
                transition: background-color 0.3s ease, color 0.3s ease;
                margin: 0;
                padding: 0;
                cursor: none;
                overflow-x: hidden;
            }

            code { font-family: 'Fira Code', monospace; }

            a, button, .chat-link, .service-card, .work-card, h1 {
                cursor: none !important;
            }

            section {
                position: relative;
                border-bottom: 1px solid var(--card-border);
            }

            /* Animações */
            @keyframes float {
                0% { transform: translateY(0px); }
                50% { transform: translateY(-20px); }
                100% { transform: translateY(0px); }
            }

            .reveal {
                animation: fadeUp 1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
                opacity: 0;
            }
            .reveal:nth-child(1) { animation-delay: 0.1s; }
            .reveal:nth-child(2) { animation-delay: 0.3s; }

            @keyframes fadeUp {
                from { opacity: 0; transform: translateY(30px); }
                to { opacity: 1; transform: translateY(0); }
            }

            /* Cursor Customizado */
            #custom-cursor {
                position: fixed;
                top: 0;
                left: 0;
                width: 20px;
                height: 20px;
                display: flex;
                align-items: center;
                justify-content: center;
                pointer-events: none !important;
                z-index: 10000;
            }

            .cursor-shape {
                position: absolute;
                width: 100%;
                height: 100%;
                background: rgba(var(--text-rgb), 0.1);
                backdrop-filter: blur(6px);
                border: 1.5px solid rgba(var(--text-rgb), 0.8);
                border-radius: 50%;
                transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

            #custom-cursor.is-hovering .cursor-shape {
                transform: scale(1.8);
                background: rgba(var(--text-rgb), 0.8);
                border-radius: 0%;
                clip-path: polygon(50% 5%, 62% 38%, 95% 50%, 62% 62%, 50% 95%, 38% 62%, 5% 50%, 38% 38%);
            }

            .cursor-text {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%) scale(0);
                font-size: 5px;
                font-weight: 900;
                color: var(--cursor-text);
                opacity: 0;
                transition: 0.3s;
                z-index: 10;
                text-transform: uppercase;
            }

            #custom-cursor.is-hovering .cursor-text {
                opacity: 1;
                transform: translate(-50%, -50%) scale(1);
            }

            /* Navegação */
            nav a {
                position: relative;
                text-decoration: none;
                transition: color 0.3s;
            }

            nav a:hover { color: var(--accent) !important; }

            /* Foto de Perfil e Sensores */
            .photo-sensor {
                position: relative;
                width: 100%;
                max-width: 400px;
                height: 500px;
                margin: auto;
                z-index: 20;
            }

            #profile-photo {
                position: absolute;
                inset: 0;
                pointer-events: none;
                will-change: transform;
                z-index: 10;
            }

            #profile-photo img {
                width: 100%;
                height: 100%;
                border-radius: 15px;
                object-fit: cover;
            }

            /* Ícones Flutuantes */
            .glow-astro-container, .glow-react-container {
                position: absolute;
                width: 50px;
                height: 50px;
                z-index: 15;
            }

            .astro-icon-mask {
                width: 100%; height: 100%; background-color: #BC52EE;
                -webkit-mask: url('/icons/astro.svg') no-repeat center / contain;
                mask: url('/icons/astro.svg') no-repeat center / contain;
            }

            .react-icon-mask {
                width: 100%; height: 100%; background-color: #61DAFB;
                -webkit-mask: url('/icons/react.svg') no-repeat center / contain;
                mask: url('/icons/react.svg') no-repeat center / contain;
            }

            /* Cards */
            .service-card {
                background: var(--card-bg);
                border: 1px solid var(--card-border);
                transition: all 0.4s ease;
            }

            .service-card:hover {
                transform: translate(4px, 4px);
                box-shadow: 4px 4px 0px var(--accent);
                border-color: var(--accent);
            }

            /* Header Principal */
            h1.main-header {
                font-size: 4.5rem;
                line-height: 1.1;
                background: radial-gradient(circle at var(--x, 50%) var(--y, 50%), var(--accent), var(--text) 80%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .chat-link {
                display: inline-block;
                padding: 12px 24px;
                border: 2px solid var(--accent);
                border-radius: 50px;
                color: var(--accent);
                text-decoration: none;
                font-weight: bold;
                letter-spacing: 2px;
                transition: 0.3s;
            }

            .chat-link:hover {
                background: var(--accent);
                color: #111;
                box-shadow: 0 0 20px rgba(0, 255, 157, 0.4);
            }

            @media (max-width: 768px) {
                h1.main-header { font-size: 2.5rem; }
                section { flex-direction: column; text-align: center; }
                .photo-sensor { height: 380px; }
                #custom-cursor { display: none; }
                body { cursor: auto; }
            }
        </style>
    </head>

    <body>
        <nav style="display: flex; justify-content: space-between; padding: 2rem; max-width: 1200px; margin: 0 auto;">
            <div style="font-weight: bold; font-size: 1.4rem;">{nome}</div>
            <div style="display: flex; gap: 20px; align-items: center;">
                <a href="#services" style="color: var(--secondary); text-decoration: none;">Services</a>
                <a href="#works" style="color: var(--secondary); text-decoration: none;">Works</a>
                <ThemeToggle />
            </div>
        </nav>

        <main style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
            <section style="display: flex; align-items: center; min-height: 80vh; gap: 50px;">
                <div style="flex: 1;">
                    <span style="color: var(--accent); font-family: monospace; border: 1px solid var(--accent); padding: 5px 10px; border-radius: 5px;">
                        {cargo}
                    </span>
                    <h1 class="main-header reveal">Talk is cheap.<br/>Show me the code</h1>
                    <p class="reveal" style="color: var(--secondary); font-size: 1.2rem; max-width: 500px;">
                        I design and code beautifully simple things, and I love what I do.
                    </p>
                    <a href="#contact" class="chat-link">LET'S CHAT!</a>
                </div>
                
                <div style="flex: 1;">
                    <div style="position: relative;">
                        <div class="glow-astro-container" style="top: -20px; left: -20px;">
                            <div class="astro-icon-mask"></div>
                        </div>
                        <div class="glow-react-container" style="bottom: 50px; right: -30px;"> 
                            <div class="react-icon-mask"></div>
                        </div>
                        
                        <div class="photo-sensor">
                            <div id="profile-photo" class="reveal">
                                 <img src="/minha-foto.jpg" alt="Michael Howe" />
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section id="services" style="padding: 100px 0;">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px;">
                    <div class="service-card" style="padding: 40px; border-radius: 15px;">
                        <h3 style="color: var(--accent);">Design</h3>
                        <p style="color: var(--secondary);">Create digital products with unique ideas.</p>
                    </div>
                    <div class="service-card" style="padding: 40px; border-radius: 15px;">
                        <h3 style="color: var(--accent);">Development</h3>
                        <p style="color: var(--secondary);">High performance coding for the web.</p>
                    </div>
                </div>
            </section>
            
            <section id="works" style="padding: 100px 0;">
                <h2 style="font-size: 2.5rem; margin-bottom: 40px;">Selected Works</h2>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
                    <WorkCard 
                        title="E-commerce Global" 
                        description="Plataforma de vendas focada no mercado europeu." 
                        tags={["Astro", "React", "Stripe"]}
                        link="#"
                    />
                    <WorkCard 
                        title="Dashboard Design" 
                        description="Interface administrativa minimalista." 
                        tags={["Figma", "UI/UX"]}
                        link="#"
                    />
                </div>
            </section>
        </main>

        <footer style="margin-top: 100px; padding: 60px 2rem; border-top: 1px solid var(--card-border); text-align: center;">
            <div style="display: flex; justify-content: center; gap: 30px; margin-bottom: 40px;">
                <a href="#" class="chat-link">GITHUB</a>
                <a href="#" class="chat-link">LINKEDIN</a>
            </div>
            <p style="color: var(--secondary); font-size: 0.9rem;">
                © 2026 {nome} • Based in Brazil, looking for global opportunities.
            </p>
        </footer>

        <script>
            const cursor = document.getElementById('custom-cursor');
            const photoEl = document.getElementById('profile-photo');
            const sensor = document.querySelector('.photo-sensor');
            const title = document.querySelector('h1.main-header') as HTMLElement;

            let mouseX = 0, mouseY = 0;
            let targetX = 0, targetY = 0;
            let currentX = 0, currentY = 0;

            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;

                if (title) {
                    const rect = title.getBoundingClientRect();
                    const x = ((mouseX - rect.left) / rect.width) * 100;
                    const y = ((mouseY - rect.top) / rect.height) * 100;
                    title.style.setProperty('--x', `${x}%`);
                    title.style.setProperty('--y', `${y}%`);
                }

                if (sensor) {
                    const rect = sensor.getBoundingClientRect();
                    const isInside = (mouseX >= rect.left && mouseX <= rect.right && mouseY >= rect.top && mouseY <= rect.bottom);
                    if (isInside) {
                        targetX = (mouseX - (rect.left + rect.width / 2)) / 15;
                        targetY = (mouseY - (rect.top + rect.height / 2)) / 15;
                    } else {
                        targetX = 0; targetY = 0;
                    }
                }
            });

            function animate() {
                if (cursor) {
                    cursor.style.transform = `translate3d(${mouseX - 10}px, ${mouseY - 10}px, 0)`;
                }
                currentX += (targetX - currentX) * 0.1;
                currentY += (targetY - currentY) * 0.1;
                if (photoEl) {
                    photoEl.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) scale(1.02)`;
                }
                requestAnimationFrame(animate);
            }
            animate();

            document.addEventListener('mouseover', (e) => {
                const target = (e.target as HTMLElement).closest('a, button, .service-card, .work-card, h1, .chat-link, .theme-switch');
                if (target) cursor?.classList.add('is-hovering');
            });

            document.addEventListener('mouseout', (e) => {
                const target = (e.target as HTMLElement).closest('a, button, .service-card, .work-card, h1, .chat-link, .theme-switch');
                if (target) cursor?.classList.remove('is-hovering');
            });
        </script>

        <div id="custom-cursor">
            <div class="cursor-shape"></div>
            <span class="cursor-text">VIEW</span>
        </div>
    </body>
</html>