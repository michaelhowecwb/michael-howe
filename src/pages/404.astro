---
import MainLayout from "@layouts/MainLayout.astro";
const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");

const title = isPt ? "404 | Página não encontrada" : "404 | Page Not Found";
const errorCode = "404";
const errorMsg = isPt
  ? "> ERROR: Rota não encontrada..."
  : "> ERROR: Route not found...";
const subText = isPt
  ? "Parece que você tentou acessar um diretório inexistente ou o link foi movido para outra dimensão."
  : "It seems you tried to access a non-existent directory or the link moved to another dimension.";
const btnText = isPt ? "VOLTAR PARA A HOME" : "BACK TO HOME";
const backLink = isPt ? "/pt" : "/";
---

<MainLayout title={title} lang={isPt ? "pt-br" : "en"}>
  <main class="error-page">
    <div class="grid-overlay"></div>

    <div class="glass-card reveal">
      <div class="terminal-header">
        <div class="terminal-dots">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
        </div>
        <span class="terminal-title">system_error.log</span>
      </div>

      <div class="error-visual">
        <h1 class="error-code" data-text={errorCode}>{errorCode}</h1>
      </div>

      <div class="error-content">
        <p class="typewriter">{errorMsg}</p>
        <p class="sub-text">{subText}</p>
      </div>

      <div class="btn-wrapper">
        <a href={backLink} class="back-btn magnetic-btn" data-strength="30">
          <span class="btn-text">{btnText}</span>
          <div class="btn-glow"></div>
        </a>
      </div>
    </div>
  </main>
</MainLayout>

<style>
  .error-page {
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: #050505;
    position: relative;
    overflow: hidden;
  }

  /* Background Grid Effect */
  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(var(--accent-rgb), 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(var(--accent-rgb), 0.05) 1px, transparent 1px);
    background-size: 50px 50px;
    mask-image: radial-gradient(circle at center, black, transparent 80%);
    pointer-events: none;
  }

  .glass-card {
    background: rgba(15, 15, 15, 0.7);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: clamp(2rem, 5vw, 4rem);
    border-radius: clamp(20px, 4vw, 32px);
    text-align: center;
    max-width: 650px;
    width: 100%;
    position: relative;
    z-index: 10;
    box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.8);
  }

  /* --- Terminal Header --- */
  .terminal-header {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-bottom: 3rem;
  }
  .terminal-dots {
    display: flex;
    gap: 8px;
    position: absolute;
    left: 0;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .red {
    background: #ff5f56;
  }
  .yellow {
    background: #ffbd2e;
  }
  .green {
    background: #27c93f;
  }
  .terminal-title {
    font-family: "Fira Code", monospace;
    font-size: 0.7rem;
    color: var(--secondary);
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* --- Glitch Effect --- */
  .error-code {
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 900;
    line-height: 1;
    color: var(--text);
    position: relative;
    margin-bottom: 1.5rem;
    letter-spacing: -5px;
  }

  .error-code::before,
  .error-code::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #050505;
  }

  .error-code::before {
    left: 2px;
    text-shadow: -2px 0 var(--accent);
    clip: rect(44px, 450px, 56px, 0);
    animation: glitch-anim 5s infinite linear alternate-reverse;
  }

  .error-code::after {
    left: -2px;
    text-shadow: -2px 0 #ff5f56;
    clip: rect(44px, 450px, 56px, 0);
    animation: glitch-anim2 5s infinite linear alternate-reverse;
  }

  .typewriter {
    font-family: "Fira Code", monospace;
    color: var(--accent);
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    margin-bottom: 1.5rem;
    border-right: 2px solid var(--accent);
    width: fit-content;
    margin-inline: auto;
    white-space: nowrap;
    overflow: hidden;
    animation:
      typing 2s steps(30, end),
      blink 0.5s step-end infinite;
  }

  .sub-text {
    color: var(--secondary);
    line-height: 1.6;
    margin-bottom: clamp(2rem, 5vw, 3rem);
    font-size: clamp(0.9rem, 1.5vw, 1rem);
  }

  /* --- Magnetic Button Stylin --- */
  .btn-wrapper {
    position: relative;
    display: inline-block;
  }

  .back-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.2rem 3rem;
    background: transparent;
    border: 1px solid rgba(var(--accent-rgb), 0.3);
    color: var(--accent);
    border-radius: 100px;
    font-weight: 900;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: border 0.3s ease;
  }

  .btn-text {
    position: relative;
    z-index: 2;
    transition: color 0.3s ease;
  }

  .btn-glow {
    position: absolute;
    inset: 0;
    background: var(--accent);
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.7, 0, 0.2, 1);
    z-index: 1;
  }

  .back-btn:hover {
    border-color: var(--accent);
  }
  .back-btn:hover .btn-text {
    color: #000;
  }
  .back-btn:hover .btn-glow {
    transform: translateY(0);
  }

  /* --- Animations --- */
  @keyframes typing {
    from {
      width: 0;
    }
    to {
      width: 100%;
    }
  }
  @keyframes blink {
    from,
    to {
      border-color: transparent;
    }
    50% {
      border-color: var(--accent);
    }
  }

  @keyframes glitch-anim {
    0% {
      clip: rect(31px, 9999px, 94px, 0);
    }
    4.1% {
      clip: rect(91px, 9999px, 43px, 0);
    }
    100% {
      clip: rect(67px, 9999px, 62px, 0);
    }
  }

  @keyframes glitch-anim2 {
    0% {
      clip: rect(65px, 9999px, 100px, 0);
    }
    100% {
      clip: rect(10px, 9999px, 30px, 0);
    }
  }

  /* --- Mobile Fixes --- */
  @media (max-width: 600px) {
    .error-page {
      padding: 1rem;
    }
    .glass-card {
      padding: 2.5rem 1.5rem;
    }
    .typewriter {
      white-space: normal;
      border-right: none;
      width: 100%;
      animation: none;
    } /* Remove typewriter no mobile para evitar quebra de layout */
    .error-code {
      letter-spacing: -2px;
    }
  }
</style>

<script>
  function init404() {
    // Reveal Observer
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("active");
        });
      },
      { threshold: 0.1 },
    );
    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

    // Magnetic Button Logic
    const mBtn = document.querySelector(".magnetic-btn") as HTMLElement;
    if (mBtn && window.innerWidth > 768) {
      mBtn.addEventListener("mousemove", (e) => {
        const rect = mBtn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        const strength = mBtn.dataset.strength
          ? parseInt(mBtn.dataset.strength)
          : 40;

        mBtn.style.transform = `translate3d(${x / strength}px, ${y / strength}px, 0)`;
      });

      mBtn.addEventListener("mouseleave", () => {
        mBtn.style.transform = `translate3d(0, 0, 0)`;
      });
    }
  }

  init404();
  document.addEventListener("astro:after-swap", init404);
</script>
