                    </div>

                    <div class="photo-sensor">
                        <div id="profile-photo">
                            <img
                                src={aboutData.bioImage}
                                alt={nome}
                                loading="eager"
                                fetchpriority="high"
                                decoding="sync"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="about">
            <div class="container about-container">
                <div class="expertise-list">
                    {
                        expertise.map((item) => {
                            const card = item.data[isPt ? "pt" : "en"];
                            return (
                                <div class="about-card spotlight-card reveal">
                                    <h3 style="color: var(--accent); font-size: 1.5rem; margin-bottom: 15px; font-weight: 800;">
                                        {card.title}
                                    </h3>
                                    <p style="color: var(--secondary); line-height: 1.6; margin: 0;">
                                        {card.description}
                                    </p>
                                </div>
                            );
                        })
                    }
                </div>

                <div class="intro-text">
                    <h2 class="reveal">{aboutData.heading}</h2>
                    <p
                        class="reveal"
                        style="color: var(--text); font-style: italic; font-size: 1.4rem; opacity: 0.8;"
                    >
                        {aboutData.subheading}
                    </p>
                    <div class="bio-line reveal">
                        <p
                            style="color: var(--secondary); line-height: 1.8; font-size: 1.1rem; margin-bottom: 30px;"
                        >
                            {aboutData.bio}
                        </p>
                        <a
                            href={isPt ? "/pt/about" : "/about"}
                            class="letsChat magnetic-btn"
                            >{
                                isPt
                                    ? "Mais sobre mim →"
                                    : "Learn more about me →"
                            }</a
                        >
                    </div>
                </div>
            </div>
        </section>

        <section id="works" class="container">
            <h2
                class="selected-works-title reveal"
                style="font-size: 3rem; font-weight: 900; margin-bottom: 60px; letter-spacing: -2px;"
            >
                <span class="custom-underline">{t["works.title"]}</span>
            </h2>
            <div class="works-grid">
                {
                    allWorks.map((work) => {
                        const content = work.data[isPt ? "pt" : "en"];
                        const cleanId = work.id.split("/")[0];
                        return (
                            <div class="reveal">
                                <WorkCard
                                    title={content.title}
                                    description={content.shortDescription}
                                    tags={work.data.tags}
                                    thumbnail={work.data.thumbnail}
                                    link={
                                        isPt
                                            ? `/pt/work/${cleanId}`
                                            : `/work/${cleanId}`
                                    }
                                />
                            </div>
                        );
                    })
                }
            </div>
        </section>
    </main>
    <ContactModal />
</MainLayout>

<script>
    function initHome() {
        const bar = document.getElementById("bar");
        const glowEl = document.getElementById("mouse-glow");
        const title = document.querySelector("h1.main-header") as HTMLElement;
        const photoEl = document.getElementById("profile-photo");
        const photoSensor = document.querySelector(".photo-sensor");
        const magneticBtns = document.querySelectorAll(".magnetic-btn");
        const spotlightCards = document.querySelectorAll(".spotlight-card");

        // Contact Button
        document
            .getElementById("hero-chat-btn")
            ?.addEventListener("click", () => {
                window.dispatchEvent(new CustomEvent("openContactModal"));
            });

        const isTouch = window.matchMedia("(pointer: coarse)").matches;
        let mouseX = 0,
            mouseY = 0,
            currentX = 0,
            currentY = 0;
        const ease = 0.15;
        let isMoving = false;
        let pTargetX = 0,
            pTargetY = 0,
            pCurrX = 0,
            pCurrY = 0;

        if (!isTouch) {
            window.addEventListener("mousemove", (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;

                if (glowEl && !isMoving) {
                    isMoving = true;
                    glowEl.classList.add("visible");
                    requestAnimationFrame(animateGlow);
                }

                spotlightCards.forEach((card) => {
                    const rect = card.getBoundingClientRect();
                    (card as HTMLElement).style.setProperty(
                        "--mouse-x",
                        `${e.clientX - rect.left}px`,
                    );
                    (card as HTMLElement).style.setProperty(
                        "--mouse-y",
                        `${e.clientY - rect.top}px`,
                    );
                });

                if (title) {
                    const rect = title.getBoundingClientRect();
                    title.style.setProperty(
                        "--x",
                        `${((e.clientX - rect.left) / rect.width) * 100}%`,
                    );
                    title.style.setProperty(
                        "--y",
                        `${((e.clientY - rect.top) / rect.height) * 100}%`,
                    );
                }

                if (photoSensor) {
                    const rect = photoSensor.getBoundingClientRect();
                    const inside =
                        e.clientX >= rect.left &&
                        e.clientX <= rect.right &&
                        e.clientY >= rect.top &&
                        e.clientY <= rect.bottom;
                    pTargetX = inside
                        ? (e.clientX - (rect.left + rect.width / 2)) / 7
                        : 0;
                    pTargetY = inside
                        ? (e.clientY - (rect.top + rect.height / 2)) / 7
                        : 0;
                }

                magneticBtns.forEach((btn) => {
                    const rect = btn.getBoundingClientRect();
                    const dist = Math.hypot(
                        e.clientX - (rect.left + rect.width / 2),
                        e.clientY - (rect.top + rect.height / 2),
                    );
                    if (dist < 80) {
                        const bx =
                            (e.clientX - (rect.left + rect.width / 2)) * 0.3;
                        const by =
                            (e.clientY - (rect.top + rect.height / 2)) * 0.3;
                        (btn as HTMLElement).style.transform =
                            `translate3d(${bx}px, ${by}px, 0)`;
                    } else {
                        (btn as HTMLElement).style.transform =
                            `translate3d(0, 0, 0)`;
                    }
                });
            });

            function animateGlow() {
                if (!isMoving) return;
                currentX += (mouseX - currentX) * ease;
                currentY += (mouseY - currentY) * ease;
                if (glowEl)
                    glowEl.style.transform = `translate3d(${currentX - 300}px, ${currentY - 300}px, 0)`;
                requestAnimationFrame(animateGlow);
            }

            function animatePhoto() {
                pCurrX += (pTargetX - pCurrX) * 0.1;
                pCurrY += (pTargetY - pCurrY) * 0.1;
                if (photoEl)
                    photoEl.style.transform = `translate3d(${pCurrX}px, ${pCurrY}px, 0) scale(${pTargetX !== 0 ? 1.05 : 1})`;
                requestAnimationFrame(animatePhoto);
            }
            animatePhoto();
        }

        window.addEventListener("scroll", () => {
            if (bar) {
                const winH =
                    document.documentElement.scrollHeight -
                    document.documentElement.clientHeight;
                bar.style.width = (window.scrollY / winH) * 100 + "%";
            }
        });

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting)
                        entry.target.classList.add("active");
                });
            },
            { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
        );

        document
            .querySelectorAll(".reveal")
            .forEach((el) => observer.observe(el));
    }

    document.addEventListener("astro:page-load", initHome);
</script>
