---
import { getCollection, getEntry } from "astro:content";
import { ui } from "@utils/i18n";
import MainLayout from "@layouts/MainLayout.astro";
import WorkCard from "@components/WorkCard.astro";

const nome = "Michael Howe";
const cargo = "// Full-stack Developer";
const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");
const t = isPt ? ui.pt : ui.en;
const currentLang = isPt ? "pt-br" : "en";

const allWorks = await getCollection("works") || [];
const expertiseEntries = await getCollection("expertise") || [];
const expertise = expertiseEntries.sort((a, b) => a.data.order - b.data.order);

const aboutEntry = await getEntry("about", "index");
const aboutData = aboutEntry?.data?.[isPt ? "pt" : "en"] || {
    heading: isPt ? "Sobre Mim" : "About Me",
    subheading: isPt ? "Desenvolvedor focado em performance" : "Performance-focused developer",
    bio: isPt ? "Preencha sua bio no Keystatic." : "Fill your bio in Keystatic."
};
---

<MainLayout title={`${nome} | Portfolio`} lang={currentLang}>
    <div class="progress-wrap"><div class="progress-bar" id="bar"></div></div>
    <div class="bg-glow" id="mouse-glow"></div>
    
    <!--<div class="noise-overlay"></div>-->

    <style>
        /* --- 1. TEXTURA E GERAL --- */

        /*.noise-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.80' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.03;
            pointer-events: none; z-index: 9999;
        }*/

        a, button, .about-card, .work-card, .letsChat { cursor: pointer !important; }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

        section { position: relative; padding: 120px 0; border-bottom: 1px solid var(--card-border); }

        /* --- 2. BARRA DE PROGRESSO & GLOW --- */
        .progress-wrap { position: fixed; top: 70px; left: 0; width: 100%; height: 2px; z-index: 1000; pointer-events: none; }
        .progress-bar { height: 100%; background: var(--accent); width: 0%; transition: width 0.1s ease-out; box-shadow: 0 0 10px var(--accent); }

        .bg-glow {
            position: fixed; top: 0; left: 0; width: 600px; height: 600px;
            background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
            opacity: 0; filter: blur(100px); z-index: 0; pointer-events: none;
            will-change: transform, opacity; transition: opacity 1s ease;
        }
        .bg-glow.visible { opacity: 0.08; }

        /* --- 3. HERO SECTION --- */
        .hero-container { display: flex; align-items: center; min-height: 85vh; gap: 60px; max-width: 1200px; margin: 0 auto; }

        h1.main-header {
            font-size: clamp(3.5rem, 12vw, 6rem); font-weight: 900; line-height: 0.85; letter-spacing: -4px;
            background: radial-gradient(circle at var(--x, 50%) var(--y, 50%), var(--accent) 0%, var(--text) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 2px 10px var(--dropshadow-rgb)); margin: 20px 0 30px;
        }

        .hero-subtitle { color: var(--secondary); font-size: 1.3rem; max-width: 500px; line-height: 1.6; margin-bottom: 40px; }

        .letsChat {
            text-decoration: none; display: inline-block; padding: 14px 35px; border: 2px solid var(--accent);
            border-radius: 50px; color: var(--accent); font-weight: 800; text-transform: uppercase; letter-spacing: 1px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: transparent;
        }
        .letsChat:hover {
            background: var(--accent); color: #000; transform: translateY(-5px);
            box-shadow: 0 10px 20px var(--dropshadow-rgb);
        }

        /* --- 4. FOTO MAGNÉTICA --- */
        .visual-wrapper { flex: 1; display: flex; justify-content: center; position: relative; }
        .photo-sensor { width: 380px; height: 480px; position: relative; z-index: 50; }
        #profile-photo { position: absolute; width: 100%; height: 100%; transition: transform 0.1s ease-out; }
        #profile-photo img { width: 100%; height: 100%; object-fit: cover; }

        .floating-icon { position: absolute; width: 60px; height: 60px; z-index: 60; animation: float 4s ease-in-out infinite; }

        /* --- 5. ABOUT / EXPERTISE (COM SEU EFEITO DE SOMBRA) --- */
        #about { background-color: var(--section-alt-rgba); backdrop-filter: blur(10px); }
        .about-container { display: grid; grid-template-columns: 1fr 1.5fr; gap: 80px; align-items: start; }
        
        .about-card {
            background: rgba(255, 255, 255, 0.03); border: 1px solid var(--card-border); padding: 40px;
            border-radius: 20px; box-shadow: -6px -6px 0px var(--accent); /* Sua sombra superior esquerda */
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative; overflow: hidden;
        }
        .about-card:hover { 
            transform: translate(4px, 4px); 
            box-shadow: 6px 6px 0px var(--accent); /* Move para inferior direita */
            border: 1px solid var(--accent); 
        }

        .intro-text h2 { font-size: 3rem; font-weight: 900; letter-spacing: -2px; margin-bottom: 20px; }
        .intro-text .bio-line { border-left: 6px solid var(--accent); padding-left: 25px; margin-top: 30px; }

        /* --- 6. WORKS GRID --- */
        #works { padding: 60px 0 200px 0; border-bottom: none !important; display: block;}
        .works-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 40px; }

        .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.2, 0.6, 0.2, 1); }
        .reveal.active { opacity: 1; transform: translateY(0); }

        @media (max-width: 992px) {
            .hero-container, .about-container { flex-direction: column; text-align: center; }
            .hero-subtitle { margin: 0 auto 40px; }
            .about-card { text-align: left; }
        }
    </style>

    <main style="position: relative; z-index: 1;">
        <section id="home" class="container">
            <div class="hero-container">
                <div style="flex: 1.2;" class="reveal">
                    <span style="color: var(--accent); font-family: 'Fira Code', monospace; font-size: 0.9rem; font-weight: bold;">{cargo}</span>
                    <h1 class="main-header">{t["hero.title"]}</h1>
                    <p class="hero-subtitle">{t["hero.subtitle"]}</p>
                    <a class="letsChat magnetic-btn" href="#contact">{t["lets.chat"]}</a>
                </div>

                <div class="visual-wrapper reveal">
                    <div class="floating-icon" style="top: -30px; left: -20px;"><div class="astro-mask"></div></div>
                    <div class="floating-icon" style="bottom: 10px; right: -20px; animation-delay: -2s;"><div class="react-mask"></div></div>
                    <div class="photo-sensor"><div id="profile-photo"><img src="/minha-foto3.png" alt={nome} /></div></div>
                </div>
            </div>
        </section>

        <section id="about">
            <div class="container about-container">
                <div style="display: flex; flex-direction: column; gap: 40px;">
                    {expertise.map((item) => {
    const lang = isPt ? "pt" : "en";
    const card = item.data[lang];
    return (
        <div class="about-card spotlight-card reveal"> <h3 style="color: var(--accent); font-size: 1.5rem; margin-bottom: 15px; font-weight: 800;">{card.title}</h3>
            <p style="color: var(--secondary); line-height: 1.6; margin: 0;">{card.description}</p>
        </div>
    )
})}
                </div>

                <div class="intro-text">
                    <h2 class="reveal">{aboutData.heading}</h2>
                    <p class="reveal" style="color: var(--text); font-style: italic; font-size: 1.4rem; opacity: 0.8;">{aboutData.subheading}</p>
                    <div class="bio-line reveal">
                        <p style="color: var(--secondary); line-height: 1.8; font-size: 1.1rem; margin-bottom: 30px;">{aboutData.bio}</p>
                        <a href={isPt ? "/pt/about" : "/about"} class="letsChat magnetic-btn">{isPt ? "Mais sobre mim →" : "Learn more about me →"}</a>
                    </div>
                </div>
            </div>
        </section>

        <section id="works" class="container">
            <h2 class="reveal" style="font-size: 3rem; font-weight: 900; margin-bottom: 60px; letter-spacing: -2px;">{t["works.title"]}</h2>
            <div class="works-grid">
                {allWorks.map((work) => {
                    const lang = (isPt ? "pt" : "en") as "pt" | "en";
                    const content = work.data[lang];
                    if (!content) return null;
                    const cleanId = work.id.split("/")[0];
                    return (
                        <div class="reveal">
                            <WorkCard
                                title={content.title}
                                description={content.shortDescription}
                                tags={work.data.tags}
                                thumbnail={work.data.thumbnail}
                                link={isPt ? `/pt/work/${cleanId}` : `/work/${cleanId}`}
                            />
                        </div>
                    );
                })}
            </div>
        </section>
    </main>
</MainLayout>

<script>
    function initHome() {
        // --- 1. SELEÇÃO DE ELEMENTOS ---
        const bar = document.getElementById("bar");
        const glowEl = document.getElementById("mouse-glow") as HTMLElement;
        const title = document.querySelector("h1.main-header") as HTMLElement;
        const photoEl = document.getElementById("profile-photo");
        const photoSensor = document.querySelector(".photo-sensor");
        const magneticBtns = document.querySelectorAll(".magnetic-btn");
        const spotlightCards = document.querySelectorAll('.spotlight-card'); // Captura todos os cards

        // Variáveis de estado
        let mouseX = 0, mouseY = 0, currentX = 0, currentY = 0;
        const ease = 0.15;
        let isMoving = false;
        let pTargetX = 0, pTargetY = 0, pCurrX = 0, pCurrY = 0;

        // --- 2. EVENTO DE MOUSE ÚNICO (Alta Performance) ---
        window.addEventListener("mousemove", (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;

            // Ativa o Glow de fundo
            if (glowEl && !isMoving) {
                isMoving = true;
                glowEl.classList.add('visible');
                requestAnimationFrame(animateGlow);
            }

            // Spotlight nos Cards (Expertise e Works)
            spotlightCards.forEach(card => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
                (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
            });

            // Gradiente no Título Hero
            if (title) {
                const rect = title.getBoundingClientRect();
                title.style.setProperty("--x", `${((e.clientX - rect.left) / rect.width) * 100}%`);
                title.style.setProperty("--y", `${((e.clientY - rect.top) / rect.height) * 100}%`);
            }

            // Sensor da Foto Magnética
            if (photoSensor) {
                const rect = photoSensor.getBoundingClientRect();
                const inside = e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
                pTargetX = inside ? (e.clientX - (rect.left + rect.width / 2)) / 7 : 0;
                pTargetY = inside ? (e.clientY - (rect.top + rect.height / 2)) / 7 : 0;
            }

            // Botões Magnéticos
            magneticBtns.forEach(btn => {
                const rect = btn.getBoundingClientRect();
                const dist = Math.hypot(e.clientX - (rect.left + rect.width/2), e.clientY - (rect.top + rect.height/2));
                if (dist < 80) {
                    const bx = (e.clientX - (rect.left + rect.width/2)) * 0.3;
                    const by = (e.clientY - (rect.top + rect.height/2)) * 0.3;
                    (btn as HTMLElement).style.transform = `translate3d(${bx}px, ${by}px, 0)`;
                } else {
                    (btn as HTMLElement).style.transform = `translate3d(0, 0, 0)`;
                }
            });
        });

        // --- 3. LOOPS DE ANIMAÇÃO (Smooth Motion) ---
        function animateGlow() {
            if (!isMoving) return;
            currentX += (mouseX - currentX) * ease;
            currentY += (mouseY - currentY) * ease;
            if (glowEl) glowEl.style.transform = `translate3d(${currentX - 300}px, ${currentY - 300}px, 0)`;
            requestAnimationFrame(animateGlow);
        }

        function animatePhoto() {
            pCurrX += (pTargetX - pCurrX) * 0.1;
            pCurrY += (pTargetY - pCurrY) * 0.1;
            if (photoEl) (photoEl as HTMLElement).style.transform = `translate3d(${pCurrX}px, ${pCurrY}px, 0) scale(${pTargetX !== 0 ? 1.05 : 1})`;
            requestAnimationFrame(animatePhoto);
        }
        animatePhoto();

        // --- 4. PROGRESS BAR & REVEAL ---
        window.addEventListener("scroll", () => {
            if (bar) {
                const winH = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                bar.style.width = (window.scrollY / winH) * 100 + "%";
            }
        });

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add("active"); });
        }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });
        document.querySelectorAll(".reveal").forEach(el => observer.observe(el));
    }

    // Inicialização segura com Astro
    initHome();
    document.addEventListener("astro:after-swap", initHome);
</script>