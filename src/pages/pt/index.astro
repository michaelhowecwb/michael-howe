---
import { getCollection, getEntry } from "astro:content";
import { ui } from "@utils/i18n";
import MainLayout from "@layouts/MainLayout.astro";
import WorkCard from "@components/WorkCard.astro";
import ContactModal from "@components/ContactModal.astro";

const nome = "Michael Howe";
const cargo = "< Full-stack Developer />";
const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");
const t = isPt ? ui.pt : ui.en;
const currentLang = isPt ? "pt-br" : "en";

const allWorks = (await getCollection("works")) || [];
const expertiseEntries = (await getCollection("expertise")) || [];
const expertise = expertiseEntries.sort((a, b) => a.data.order - b.data.order);

const aboutEntry = await getEntry("about", "index");

const localizedBio = aboutEntry?.data?.[isPt ? "pt" : "en"];
const aboutData = localizedBio
    ? {
          ...localizedBio,
          bioImage: aboutEntry.data.bioImage,
      }
    : {
          heading: isPt ? "Sobre Mim" : "About Me",
          subheading: isPt
              ? "Desenvolvedor focado em performance"
              : "Performance-focused developer",
          bio: isPt
              ? "Preencha sua bio no Keystatic."
              : "Fill your bio in Keystatic.",
          bioImage: "/minha-foto3.png",
      };

// SEO: JSON-LD
const schema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: nome,
    jobTitle: "Full-stack Developer",
    url: Astro.site || Astro.url.origin,
    sameAs: [
        "https://github.com/michaelhowecwb",
        "https://www.linkedin.com/in/michael-howe-cwb/",
    ],
    knowsAbout: [
        "Full-stack Development",
        "React",
        "Astro",
        "TypeScript",
        "Node.js",
        "UI/UX Design",
    ],
};
const jsonLd = JSON.stringify(schema);
---

<MainLayout
    title={`${nome} | Full-stack Developer Portfolio`}
    lang={currentLang}
    description={isPt
        ? "Portfólio de Michael Howe, Desenvolvedor Full-stack em Curitiba. Especialista em interfaces premium com React, Astro e arquiteturas modernas."
        : "Michael Howe's Portfolio - Full-stack Developer based in Brazil. Specialist in premium interfaces with React, Astro, and modern architectures."}
>
    <script is:inline type="application/ld+json" set:html={jsonLd} />

    <div class="progress-wrap"><div class="progress-bar" id="bar"></div></div>
    <div class="bg-glow" id="mouse-glow"></div>

    <style>
        /* --- Structure & Interaction --- */
        .text-accent {
            color: var(--accent);
        }
        .text-gradient {
            background: linear-gradient(to right, var(--accent), #fff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: bold;
        }
        .text-underline {
            border-bottom: 2px solid var(--accent);
        }
        .custom-underline {
            position: relative;
            display: inline-block;
        }
        .custom-underline::after {
            content: "";
            position: absolute;
            left: 50%;
            right: 0;
            bottom: -2px;
            height: 4px;
            background-color: var(--accent);
            border-radius: 2px;
            z-index: -1;
            transition: width 0.3s ease;
        }

        a,
        button,
        .about-card,
        .work-card,
        .letsChat {
            cursor: pointer !important;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }
        section {
            position: relative;
            padding: 120px 0;
            border-bottom: 1px solid var(--card-border);
        }

        .progress-wrap {
            position: fixed;
            top: 70px;
            left: 0;
            width: 100%;
            height: 2px;
            z-index: 1000;
            pointer-events: none;
        }
        .progress-bar {
            height: 100%;
            background: var(--accent);
            width: 0%;
            transition: width 0.1s ease-out;
            box-shadow: 0 0 10px var(--accent);
        }

        .bg-glow {
            position: fixed;
            top: 0;
            left: 0;
            width: 600px;
            height: 600px;
            background: radial-gradient(
                circle,
                var(--accent) 0%,
                transparent 70%
            );
            opacity: 0;
            filter: blur(100px);
            z-index: 0;
            pointer-events: none;
            will-change: transform, opacity;
            transition: opacity 1s ease;
        }
        .bg-glow.visible {
            opacity: 0.08;
        }

        /* --- Hero Section --- */
        .hero-container {
            display: flex;
            align-items: center;
            min-height: 85vh;
            padding-top: 40px;
            gap: 60px;
        }
        h1.main-header {
            font-size: clamp(3.5rem, 12vw, 6rem);
            font-weight: 900;
            line-height: 0.85;
            letter-spacing: -4px;
            background: radial-gradient(
                circle at var(--x, 50%) var(--y, 50%),
                var(--accent) 0%,
                var(--text) 100%
            );
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 2px 10px var(--dropshadow-rgb));
            margin: 20px 0 30px;
            padding: 20px 0;
        }
        .hero-subtitle {
            color: var(--secondary);
            font-size: 1.3rem;
            max-width: 500px;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        .letsChat {
            text-decoration: none;
            display: inline-block;
            padding: 14px 35px;
            border: 2px solid var(--accent);
            border-radius: 50px;
            color: var(--accent);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: transparent;
        }
        .letsChat:hover {
            background: var(--accent);
            color: #000;
            transform: translateY(-5px);
            box-shadow: 0 10px 20px var(--dropshadow-rgb);
        }

        /* --- Visual Wrapper --- */
        .visual-wrapper {
            flex: 1;
            display: flex;
            justify-content: center;
            position: relative;
        }
        .photo-sensor {
            width: 380px;
            height: 480px;
            position: relative;
            z-index: 50;
        }
        #profile-photo {
            position: absolute;
            width: 100%;
            height: 100%;
            transition: transform 0.1s ease-out;
            border-radius: 20px;
            overflow: hidden;
        }
        #profile-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .floating-icon {
            position: absolute;
            z-index: 60;
            filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.3));
            pointer-events: none;
            transition: all 0.3s ease;
        }

        @keyframes float-1 {
            0%,
            100% {
                transform: translateY(0) rotate(0);
            }
            50% {
                transform: translateY(-20px) rotate(5deg);
            }
        }
        @keyframes float-2 {
            0%,
            100% {
                transform: translateY(0) rotate(0);
            }
            50% {
                transform: translateY(15px) rotate(-8deg);
            }
        }
        @keyframes float-3 {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.1) translateY(-10px);
            }
        }

        .anim-1 {
            animation: float-1 4s ease-in-out infinite;
        }
        .anim-2 {
            animation: float-2 5s ease-in-out infinite;
        }
        .anim-3 {
            animation: float-3 6s ease-in-out infinite;
        }

        /* --- About Section --- */
        #about {
            background-color: var(--section-alt-rgba);
            backdrop-filter: blur(10px);
        }
        .about-container {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 80px;
            align-items: start;
        }
        .expertise-list {
            display: flex;
            flex-direction: column;
            gap: 40px;
        }
        .about-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--card-border);
            padding: 40px;
            border-radius: 20px;
            box-shadow: -6px -6px 0px var(--accent);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
        }
        .spotlight-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(
                600px circle at var(--mouse-x) var(--mouse-y),
                rgba(255, 255, 255, 0.08),
                transparent 40%
            );
            z-index: 0;
            opacity: 0;
            transition: opacity 0.5s ease;
            pointer-events: none;
        }
        .spotlight-card:hover::before {
            opacity: 1;
        }
        .about-card:hover {
            transform: translate(4px, 4px);
            box-shadow: 6px 6px 0px var(--accent);
            border: 1px solid var(--accent);
        }

        .intro-text h2 {
            font-size: 3rem;
            font-weight: 900;
            letter-spacing: -2px;
            margin-bottom: 20px;
        }
        .intro-text .bio-line {
            border-left: 6px solid var(--accent);
            padding-left: 25px;
            margin-top: 30px;
        }

        /* --- Works Section --- */
        #works {
            padding: 60px 0 200px 0;
            border-bottom: none !important;
        }
        .works-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 40px;
        }
        .selected-works-title{
            padding-left: 2rem;
        }
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.2, 0.6, 0.2, 1);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        @media (max-width: 992px) {
            section {
                padding: 60px 0;
            }
            .hero-container {
                flex-direction: column;
                text-align: center;
                gap: 40px;
            }
            .about-container {
                grid-template-columns: 1fr;
                gap: 50px;
                display: flex;
                flex-direction: column;
            }
            .intro-text {
                order: -1;
                text-align: center;
                margin: auto;
            }
            .intro-text .bio-line {
                border-left: none;
                border-top: 4px solid var(--accent);
                padding: 25px 0 0 0;
            }
            .expertise-list {
                order: 2;
                width: 100%;
            }
            .photo-sensor {
                width: 280px;
                height: 350px;
            }
            .floating-icon {
                transform: scale(0.7);
                opacity: 0.8;
            }
            .intro-text h2 {
                font-size: 2.2rem;
            }
        }
    </style>

