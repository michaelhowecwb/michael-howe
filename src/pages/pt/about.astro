---
import { getEntry } from "astro:content";
import MainLayout from "@layouts/MainLayout.astro";

const nome = "Michael Howe";
const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");
const currentLang = isPt ? "pt-br" : "en";

const aboutEntry = await getEntry("about", "index");

const rawData = aboutEntry?.data;
const localizedData = isPt ? rawData?.pt : rawData?.en;
const bioImage = rawData?.bioImage;

// Security fallback in case the translation does not exist (prevents the site from breaking).
if (!localizedData) return Astro.redirect(isPt ? "/pt/" : "/");

const backLink = isPt ? "/pt/" : "/";

// --- Specific SEO ---
const seoTitle = isPt ? `Sobre | ${nome}` : `About | ${nome}`;
const seoDesc = isPt
    ? `Conheça a trajetória de Michael Howe, Desenvolvedor Full-stack. De entusiasta a especialista em arquiteturas modernas.`
    : `Learn about Michael Howe's journey as a Full-stack Developer. From tech enthusiast to modern architecture specialist.`;
---

<MainLayout title={seoTitle} description={seoDesc} lang={currentLang}>
    <div class="progress-wrap"><div class="progress-bar" id="bar"></div></div>
    <div class="bg-glow" id="mouse-glow"></div>

    <style>
        .text-accent {
            color: var(--accent);
        }
        .text-gradient {
            background: linear-gradient(to right, var(--accent), #fff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: bold;
        }
        .text-underline {
            border-bottom: 2px solid var(--accent);
        }
        .custom-underline {
            position: relative;
            display: inline-block;
        }
        .custom-underline::after {
            content: "";
            position: absolute;
            left: 20%;
            right: 0;
            bottom: -2px;
            height: 4px;
            background-color: var(--accent);
            border-radius: 2px;
            z-index: -1;
            transition: width 0.3s ease;
        }

        /* --- Structure --- */
        .about-page {
            padding: 120px 0;
            max-width: 1200px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        /* --- Progress & Glow --- */
        .progress-wrap {
            position: fixed;
            top: 70px;
            left: 0;
            width: 100%;
            height: 2px;
            z-index: 1000;
            pointer-events: none;
        }
        .progress-bar {
            height: 100%;
            background: var(--accent);
            width: 0%;
            transition: width 0.1s ease-out;
            box-shadow: 0 0 10px var(--accent);
        }

        .bg-glow {
            position: fixed;
            top: 0;
            left: 0;
            width: 600px;
            height: 600px;
            background: radial-gradient(
                circle,
                var(--accent) 0%,
                transparent 70%
            );
            opacity: 0;
            filter: blur(100px);
            z-index: -1;
            pointer-events: none;
            will-change: transform, opacity;
            transition: opacity 1s ease;
        }
        .bg-glow.visible {
            opacity: 0.08;
        }

        /* --- Content --- */
        .back-link {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 40px;
            color: var(--accent);
            text-decoration: none;
            font-family: "Fira Code", monospace;
            transition: all 0.3s ease;
            font-size: 1.2rem;
        }
        .back-link:hover {
            color: var(--text);
            font-weight: 300;
        }

        h1 {
            font-size: clamp(3rem, 8vw, 5.5rem);
            margin-bottom: 40px;
            color: var(--text);
            letter-spacing: -3px;
            font-weight: 800;
            line-height: 1;
        }

        /* --- Bio Section --- */
        .bio-container {
            margin-bottom: 100px;
            overflow: visible;
        }

        .bio-photo {
            float: right;
            width: 400px;
            margin: 10px 0 30px 40px;
            border-radius: 20px;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .bio-photo:hover {
            transform: scale(1.03) rotate(2deg);
        }

        .full-bio {
            font-size: 1.15rem;
            line-height: 1.9;
            color: var(--secondary);
            white-space: pre-line;
            text-align: justify;
            border-left: solid 6px var(--accent);
            padding-left: 20px;
        }

        /* --- Timeline --- */
        .timeline-section {
            margin-top: 120px;
        }
        .timeline {
            position: relative;
            border-left: 1px solid var(--card-border);
        }

        .timeline-item {
            position: relative;
            margin-bottom: 40px;
            padding-left: 45px;
        }

        .timeline-item::before {
            content: "";
            position: absolute;
            left: -11px;
            top: 35px;
            width: 20px;
            height: 20px;
            background: var(--bg);
            border: 2px solid var(--accent);
            border-radius: 50%;
            z-index: 2;
            transition: all 0.3s ease-out;
        }

        .timeline-item:hover::before {
            background: var(--accent);
            box-shadow: 0 0 15px var(--accent);
            transform: scale(1.15);
        }

        .timeline-content {
            padding: 40px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 15px;
            border: 1px solid transparent;
            transition: all 0.3s ease;
        }

        .timeline-item:hover .timeline-content {
            border-color: var(--card-border);
            background: rgba(255, 255, 255, 0.05);
            transform: translateX(20px);
        }

        .time-year {
            font-family: "Fira Code", monospace;
            color: var(--accent);
            font-size: 0.9rem;
            font-weight: bold;
        }
        .time-role {
            font-size: 1.7rem;
            color: var(--text);
            margin: 10px 0;
            letter-spacing: -1px;
        }

        /* --- Reveal --- */
        .reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.8s cubic-bezier(0.2, 0.6, 0.2, 1);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- Responsiveness --- */
        @media (max-width: 992px) {
            .bio-photo {
                float: none;
                width: 100%;
                margin: 0 0 40px 0;
            }
            .about-page {
                padding: 80px 1.5rem;
            }
            .full-bio {
                text-align: left;
            }
        }

        @media (max-width: 768px) {
            h1 {
                font-size: 3rem;
            }
            .timeline-item {
                padding-left: 30px;
            }
            .timeline-item:hover .timeline-content {
                transform: translateX(10px);
            }
        }
    </style>

    <main class="container">
        <div class="about-page">
            <a href={backLink} class="back-link reveal">
                ← {isPt ? "Voltar ao Início" : "Back to Home"}
            </a>

            <article class="bio-container reveal">
                <header>
                    <span
                        style="color: var(--accent); font-family: 'Fira Code', monospace; font-size: 0.9rem; display: block; margin-bottom: 10px;"
                    >
                        {isPt ? "// A história" : "// The story"}
                    </span>
                    <h1>{localizedData.heading}</h1>
                </header>

                {
                    bioImage && (
                        <img
                            src={bioImage}
                            alt={`Michael Howe - Full-stack Developer`}
                            class="bio-photo reveal"
                            loading="eager"
                            fetchpriority="high"
                            decoding="sync"
                        />
                    )
                }

                <div class="full-bio">
                    {localizedData.fullBio}
                </div>
            </article>

            {
                localizedData.experience &&
                    localizedData.experience.length > 0 && (
                        <section class="timeline-section">
                            <h2
                                class="reveal"
                                style="font-size: 2.2rem; margin-bottom: 50px; color: var(--text); letter-spacing: -1.5px;"
                            >
                                {isPt
                                    ? "Trajetória Profissional"
                                    : "Professional Journey"}
                            </h2>
                            <div class="timeline">
                                {localizedData.experience.map((item) => (
                                    <div class="timeline-item reveal">
                                        <div class="timeline-content">
                                            <span class="time-year">
                                                {item.year}
                                            </span>
                                            <h3 class="time-role">
                                                {item.role}
                                            </h3>
                                            <span style="color: var(--accent); font-weight: bold; display: block; margin-bottom: 10px;">
                                                {item.company}
                                            </span>
                                            <p
                                                class="time-desc"
                                                style="color: var(--secondary);"
                                            >
                                                {item.description}
                                            </p>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </section>
                    )
            }
        </div>
    </main>

    <script>
        function initAboutEffects() {
            const bar = document.getElementById("bar");
            const glowEl = document.getElementById("mouse-glow") as HTMLElement;
            const isTouch = window.matchMedia("(pointer: coarse)").matches;

            // Progress Bar
            window.addEventListener("scroll", () => {
                if (bar) {
                    const winH =
                        document.documentElement.scrollHeight -
                        document.documentElement.clientHeight;
                    bar.style.width = (window.scrollY / winH) * 100 + "%";
                }
            });

            // Glow (Lerp Engine) - Desktop Only
            let mouseX = 0,
                mouseY = 0,
                currentX = 0,
                currentY = 0;
            const ease = 0.15;
            let isMoving = false;

            if (glowEl && !isTouch) {
                window.addEventListener("mousemove", (e) => {
                    mouseX = e.clientX;
                    mouseY = e.clientY;

                    if (!isMoving) {
                        isMoving = true;
                        glowEl.classList.add("visible");
                        requestAnimationFrame(animateGlow);
                    }
                });

                function animateGlow() {
                    if (!isMoving) return;
                    currentX += (mouseX - currentX) * ease;
                    currentY += (mouseY - currentY) * ease;
                    glowEl.style.transform = `translate3d(${currentX - 300}px, ${currentY - 300}px, 0)`;
                    requestAnimationFrame(animateGlow);
                }
            }

            // Reveal System
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting)
                            entry.target.classList.add("active");
                    });
                },
                { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
            );

            document
                .querySelectorAll(".reveal")
                .forEach((el) => observer.observe(el));
        }

        document.addEventListener("astro:page-load", initAboutEffects);
    </script>
</MainLayout>
