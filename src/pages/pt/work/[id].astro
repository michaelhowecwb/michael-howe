---
import { getCollection, type CollectionEntry } from 'astro:content';
import MainLayout from '@layouts/MainLayout.astro';
import { ui } from '@utils/i18n';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((work) => ({
    params: { id: work.id.split('/')[0] },
    props: { work },
  }));
}

interface Props {
  work: CollectionEntry<'works'>;
}

const { work } = Astro.props;
const { pathname } = Astro.url;

// Detecção de idioma pela URL
const isPt = pathname.includes("/pt");
const lang = (isPt ? 'pt' : 'en') as 'pt' | 'en';
const currentLangTag = isPt ? 'pt-br' : 'en';

// Seleção de dados
const content = work.data[lang];
const globalData = work.data;

const textBack = isPt ? '← Voltar' : '← Go Back';
const textDemo = isPt ? 'Acessar Projeto ↗' : 'Live Demo ↗';
const textRepo = isPt ? 'Repositório ↗' : 'Repository ↗';

// Define para onde o botão "Voltar" deve apontar
const backLink = isPt ? "/pt/" : "/";

// Função para gerar parágrafos reais e evitar texto "grudado"
const formatText = (text: string | undefined) => {
  if (!text) return [];
  return text.split('\n').filter(p => p.trim() !== '');
};
---

<MainLayout title={`${content.title} | Portfolio`} lang={currentLangTag}>
  <div class="progress-wrap"><div class="progress-bar" id="bar"></div></div>

  <div class="work-article-container">
    <header class="project-header reveal">
      <a href={backLink} class="back-btn">{textBack}</a>
      <h1 class="hero-title">{content.title}</h1>
      
      <div class="header-container">
        <div class="description-column">
          <div class="description-text">
            {formatText(content.shortDescription).map(p => <p>{p}</p>)}
          </div>
          
          <div class="meta-info">
            <div class="tags-row">
              {globalData.tags.map(tag => <span class="work-tag">{tag}</span>)}
            </div>
            
            <div class="links-row">
              {globalData.demoLink && (
                <a href={globalData.demoLink} target="_blank" class="btn-primary">
                  {textDemo}
                </a>
              )}
              {globalData.repoLink && (
                <a href={globalData.repoLink} target="_blank" class="btn-outline">
                  {textRepo}
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </header>

    {globalData.thumbnail && (
      <div class="hero-visual reveal">
        <div class="parallax-window">
            <img src={globalData.thumbnail} alt={content.title} class="parallax-img" id="hero-img" />
        </div>
      </div>
    )}

    <article class="details-stack">
      {content.detailedSections.map((section, index) => (
        <section class={`detail-section reveal ${index % 2 !== 0 ? 'is-reversed' : ''}`}>
          {section.sectionTitle && <h2 class="section-heading">{section.sectionTitle}</h2>}
          
          <div class="section-body">
            {section.image && (
              <div class="section-image-wrap">
                <img src={section.image} alt={section.sectionTitle} loading="lazy" />
              </div>
            )}
            <div class="section-text">
              {formatText(section.content).map(p => <p>{p}</p>)}
            </div>
            <div style="clear: both;"></div>
          </div>
        </section>
      ))}
    </article>
  </div>
</MainLayout>

<style>
  .work-article-container { 
    max-width: 1000px; /* Reduzi um pouco para ficar mais elegante */
    margin: 0 auto; 
    padding: 140px 2rem 100px; 
  }
  
  /* Progress Bar */
/* Barra de Progresso */
  .progress-wrap { 
    position: fixed; 
    top: 70px; /* Alinhado com a altura da sua Navbar */
    left: 0; 
    width: 100%; 
    height: 2px; 
    z-index: 1000; 
    pointer-events: none;
  }
  .progress-bar { 
    height: 100%; 
    background: var(--accent); 
    width: 0%; 
    transition: width 0.1s ease-out; 
    box-shadow: 0 0 10px var(--accent);
  }

  /* Header Editorial */
.header-container {
    width: 100%;
    margin-bottom: 4rem;
  }

  .project-header { margin-bottom: 6rem; }
  .back-btn { color: var(--secondary); text-decoration: none; font-family: 'Fira Code', monospace; font-size: 0.85rem; margin-bottom: 2rem; display: block; }
  .hero-title { font-size: clamp(3rem, 10vw, 5.5rem); font-weight: 900; letter-spacing: -3px; line-height: 0.9; margin-bottom: 3rem; color: var(--text); }

  .description-column {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .description-text p {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--secondary);
    max-width: 800px; /* Evita linhas muito longas e cansativas */
  }
  .meta-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .tags-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .work-tag { font-size: 0.75rem; font-weight: 800; padding: 6px 14px; border-radius: 4px; background: rgba(var(--text-rgb), 0.05); color: var(--accent); border: 1px solid var(--card-border); text-transform: uppercase; }

  .links-row { display: flex; gap: 1rem; }
  .btn-primary { background: var(--accent); color: #000; padding: 14px 30px; border-radius: 50px; text-decoration: none; font-weight: 800; font-size: 0.9rem; transition: 0.3s; border: 2px solid var(--accent); }
  .btn-outline { border: 2px solid var(--accent); color: var(--accent); padding: 14px 30px; border-radius: 50px; text-decoration: none; font-weight: 800; font-size: 0.9rem; transition: 0.3s; }
  .btn-primary:hover, .btn-outline:hover { transform: translateY(-4px); box-shadow: 0 15px 30px var(--dropshadow-rgb); }

  /* Hero Image & Parallax */
  .hero-visual { 
    width: 100%; 
    max-width: 800px; /* A imagem não será mais gigante */
    margin: 0 auto 6rem; /* Centraliza a imagem */
    border-radius: 20px;
    overflow: hidden;
  }
  .parallax-window {
    width: 100%;
    aspect-ratio: 16 / 9; /* Mantém uma proporção de cinema elegante */
    overflow: hidden;
  }
  .parallax-img { 
    width: 100%; 
    height: 100%;
    object-fit: cover; /* Garante que preencha o espaço sem distorcer */
  }

  /* Seções Detalhadas (Float para Texto Contornar Imagem) */
  .details-stack { display: flex; flex-direction: column; gap: 10rem; }
  .section-heading { font-size: 2.8rem; font-weight: 800; margin-bottom: 3rem; color: var(--text); position: relative; padding-bottom: 15px; }
  .section-heading::after { content: ''; position: absolute; left: 0; bottom: 0; width: 60px; height: 4px; background: var(--accent); }

  .section-body { width: 100%; position: relative; }
  .section-image-wrap { 
    width: 45%; 
    max-width: 500px; 
    margin-bottom: 2rem; 
    background: transparent;
    /* Adicione estas duas linhas abaixo */
    shape-margin: 2rem; 
    border-radius: 20px;
  }
  
  /* Logica de Float */
  .detail-section .section-image-wrap { float: right; margin-left: 4rem; }
  .detail-section.is-reversed .section-image-wrap { float: left; margin-right: 4rem; margin-left: 0; }

  .section-image-wrap img { width: 100%; border-radius: 20px; display: block; transition: 0.5s; }
  .section-image-wrap:hover img { transform: translateY(-10px); filter: drop-shadow(0 20px 40px rgba(0,0,0,0.3)); }

  .section-text p { font-size: 1.2rem; line-height: 1.9; color: var(--secondary); margin-bottom: 1.8rem; text-align: justify; }

  /* Animações reveal */
  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
  .reveal.active { opacity: 1; transform: translateY(0); }

  @media (max-width: 992px) {
    .header-grid { grid-template-columns: 1fr; gap: 2rem; }
    .section-image-wrap { width: 100% !important; float: none !important; margin: 0 0 2rem 0 !important; }
    .hero-title { font-size: 3.2rem; }
    .section-text p { text-align: left; }
    .links-row { flex-direction: column; }
    .btn-primary, .btn-outline { text-align: center; }
  }
</style>

<script>
  function initProject() {
    const bar = document.getElementById('bar');
    const heroImg = document.getElementById('hero-img');

    window.addEventListener('scroll', () => {
      // 1. Barra de progresso
      if (bar) {
        const winH = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        bar.style.width = (window.scrollY / winH) * 100 + "%";
      }
      // 2. Parallax
      if (heroImg) {
        const speed = 0.1;
        (heroImg as HTMLElement).style.transform = `translateY(${window.scrollY * speed}px) scale(1.1)`;
      }
    });

    // 3. Intersection Observer (Reveal)
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }

  initProject();
  document.addEventListener('astro:after-swap', initProject);
</script>