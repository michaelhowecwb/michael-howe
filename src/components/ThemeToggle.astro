<div class="theme-switch-wrapper">

    <label class="theme-switch" for="checkbox">

        <input type="checkbox" id="checkbox" />

        <div class="slider">

            <div id="icon-container"></div>

            <span id="theme-text">DARK SIDE</span>

        </div>

    </label>

</div>



<style>

    .theme-switch-wrapper { display: flex; align-items: center; }

    .theme-switch { display: inline-block; height: 38px; position: relative; width: 150px; }

    .theme-switch input { display: none; }

   

    .slider {

        background-color: #222;

        bottom: 0;

        cursor: pointer !important;

        left: 0;

        position: absolute;

        right: 0;

        top: 0;

        transition: .4s;

        border-radius: 34px;

        display: flex;

        align-items: center;

        padding: 0 5px;

        border: 1px solid #333;
        transition: background-color .4s, border-color 0.3s ease;
    }

    .slider:hover {
        border: 1px solid var(--accent);
    }

    input:checked + .slider:hover {
        border-color: var(--accent);
    }

    #icon-container {

        background-color: #777;

        height: 30px;

        width: 30px;

        border-radius: 50%;

        display: flex;

        align-items: center;

        justify-content: center;

        transition: .4s;

        z-index: 2;

        overflow: hidden; /* Garante que o ícone não escape do círculo */

    }



    /* Estilo base da imagem */

    #icon-container :global(img) {

        width: 100%;

        height: 100%;

        object-fit: contain;

        transition: transform 0.3s ease, filter 0.3s ease;

    }



    #theme-text {

        margin-left: 10px; font-size: 10px; font-weight: bold;

        letter-spacing: 1px; transition: .4s; color: #fff; font-family: sans-serif;

    }



    input:checked + .slider { background-color: #f0f0f0; border-color: #ccc; }

    input:checked + .slider #icon-container {

        transform: translateX(108px);

        background-color: #777;

    }

    input:checked + .slider #theme-text { transform: translateX(-35px); color: #000; }

</style>



<script>

    const toggleSwitch = document.querySelector('#checkbox') as HTMLInputElement;

    const themeText = document.querySelector('#theme-text');

    const iconContainer = document.querySelector('#icon-container');

    const html = document.documentElement;



    // CONFIGURAÇÃO DE TAMANHO: Ajuste os valores de scale aqui

    const ICON_CONFIG = {

        light: {

            path: '/icons/jedi-order.svg',

            scale: '1.0', // Aumenta o ícone Jedi

            filter: 'invert(1)'

        },

        dark: {

            path: '/icons/sith.svg',

            scale: '1.8', // Aumenta o ícone Sith (que estava pequeno)

            filter: 'invert(0)'

        }

    };



    function updateUI(isLight: boolean) {

        if (themeText && iconContainer) {

            const config = isLight ? ICON_CONFIG.light : ICON_CONFIG.dark;

           

            themeText.textContent = isLight ? "LIGHT SIDE" : "DARK SIDE";

           

            // Aplicamos a escala diretamente no style da imagem

            iconContainer.innerHTML = `

                <img src="${config.path}"

                     alt="Icon"

                     style="filter: ${config.filter}; transform: scale(${config.scale});" />

            `;

        }

    }



    toggleSwitch?.addEventListener('change', (e) => {

        const isLight = (e.target as HTMLInputElement).checked;

        html.setAttribute('data-theme', isLight ? 'light' : 'dark');

        localStorage.setItem('theme', isLight ? 'light' : 'dark');

        updateUI(isLight);

    });



    const currentTheme = localStorage.getItem('theme') || 'dark';

    html.setAttribute('data-theme', currentTheme);

    if (currentTheme === 'light' && toggleSwitch) {

        toggleSwitch.checked = true;

        updateUI(true);

    } else {

        updateUI(false);

    }

</script>