<div class="theme-switch-wrapper">
    <label class="theme-switch" for="checkbox">
        <input type="checkbox" id="checkbox" />
        <div class="slider">
            <div id="icon-container"></div>
            <span id="theme-text">DARK MODE</span>
        </div>
    </label>
</div>

<style>
    .theme-switch-wrapper { display: flex; align-items: center; }
    .theme-switch { display: inline-block; height: 38px; position: relative; width: 150px; }
    .theme-switch input { display: none; }
    .slider {
        background-color: #222;
        bottom: 0; cursor: pointer; left: 0; position: absolute; right: 0; top: 0;
        transition: .4s; border-radius: 34px; display: flex; align-items: center; padding: 0 5px;
        border: 1px solid #333;
    }
    #icon-container {
        background-color: #fff; height: 30px; width: 30px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        transition: .4s; z-index: 2; color: #000;
    }
    #theme-text {
        margin-left: 10px; font-size: 10px; font-weight: bold;
        letter-spacing: 1px; transition: .4s; color: #fff;
    }
    input:checked + .slider { background-color: #f0f0f0; }
    input:checked + .slider #icon-container { transform: translateX(108px); }
    input:checked + .slider #theme-text { transform: translateX(-35px); color: #000; }
</style>

<script>
    const toggleSwitch = document.querySelector('#checkbox') as HTMLInputElement;
    const themeText = document.querySelector('#theme-text');
    const iconContainer = document.querySelector('#icon-container');
    const html = document.documentElement;

    const sunIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>`;
    const moonIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>`;

    function updateUI(isLight: boolean) {
        if (themeText && iconContainer) {
            themeText.textContent = isLight ? "LIGHT MODE" : "DARK MODE";
            iconContainer.innerHTML = isLight ? sunIcon : moonIcon;
        }
    }

    toggleSwitch?.addEventListener('change', (e) => {
        const isLight = (e.target as HTMLInputElement).checked;
        html.setAttribute('data-theme', isLight ? 'light' : 'dark');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        updateUI(isLight);
    });

    const currentTheme = localStorage.getItem('theme') || 'dark';
    html.setAttribute('data-theme', currentTheme);
    if (currentTheme === 'light' && toggleSwitch) {
        toggleSwitch.checked = true;
        updateUI(true);
    } else {
        updateUI(false);
    }
</script>