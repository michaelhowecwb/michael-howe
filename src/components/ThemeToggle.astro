<div class="theme-switch-wrapper">
    <label class="theme-switch" for="theme-checkbox">
        <input type="checkbox" id="theme-checkbox" />
        <div class="slider">
            <div class="icon-container" id="icon-target"></div>
            <span id="theme-text">DARK SIDE</span>
        </div>
    </label>
</div>

<style>
    .theme-switch-wrapper { 
        display: flex; 
        align-items: center; 
        z-index: 100;
    }
    
    .theme-switch { 
        display: inline-block; 
        height: 38px; 
        position: relative; 
        width: 150px; 
    }
    
    .theme-switch input { 
        display: none; 
    }
    
    .slider {
        background-color: #222;
        inset: 0;
        cursor: pointer; 
        position: absolute; 
        transition: .4s; 
        border-radius: 34px; 
        display: flex; 
        align-items: center; 
        padding: 0 5px;
        border: 1px solid #333;
    }

    .icon-container {
        background-color: #fff;
        height: 30px; 
        width: 30px; 
        border-radius: 50%;
        display: flex; 
        align-items: center; 
        justify-content: center;
        transition: .4s; 
        z-index: 2; 
        overflow: hidden;
    }

    /* Estilo para a imagem injetada */
    .icon-container :global(img) {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transition: transform 0.3s ease;
        display: block;
    }

    #theme-text {
        margin-left: 10px; 
        font-size: 10px; 
        font-weight: bold;
        letter-spacing: 1px; 
        transition: .4s; 
        color: #fff; 
        font-family: sans-serif;
        pointer-events: none;
    }

    /* Estados de Ativação */
    input:checked + .slider { 
        background-color: #f0f0f0; 
        border-color: #ccc; 
    }
    
    input:checked + .slider .icon-container { 
        transform: translateX(108px); 
        background-color: #111; 
    }
    
    input:checked + .slider #theme-text { 
        transform: translateX(-35px); 
        color: #000; 
    }
</style>

<script>
    const toggleSwitch = document.querySelector('#theme-checkbox') as HTMLInputElement;
    const themeText = document.querySelector('#theme-text');
    const iconContainer = document.querySelector('#icon-target');
    const html = document.documentElement;

    const ICON_CONFIG = {
        light: {
            path: './icons/jedi-order.svg',
            scale: '1.0',
            filter: 'invert(1)'
        },
        dark: {
            path: './icons/sith.svg',
            scale: '1.8',
            filter: 'invert(0)'
        }
    };

    function updateUI(isLight: boolean) {
        if (themeText && iconContainer) {
            const config = isLight ? ICON_CONFIG.light : ICON_CONFIG.dark;
            themeText.textContent = isLight ? "LIGHT SIDE" : "DARK SIDE";
            
            iconContainer.innerHTML = `
                <img src="${config.path}" 
                     alt="Theme Icon" 
                     style="filter: ${config.filter}; transform: scale(${config.scale});" />
            `;
        }
    }

    // Listener para mudança manual
    toggleSwitch?.addEventListener('change', (e) => {
        const isLight = (e.target as HTMLInputElement).checked;
        const theme = isLight ? 'light' : 'dark';
        
        html.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        updateUI(isLight);
    });

    // Inicialização correta (Executa ao carregar a página)
    const savedTheme = localStorage.getItem('theme') || 'dark';
    const isActuallyLight = savedTheme === 'light';

    html.setAttribute('data-theme', savedTheme);
    
    if (toggleSwitch) {
        toggleSwitch.checked = isActuallyLight;
        updateUI(isActuallyLight);
    }
</script>