---
// ThemeToggle.astro - Refinado com efeitos de aura e mola
---

<div class="theme-switch-wrapper">
    <label
        class="theme-switch"
        for="theme-checkbox"
        aria-label="Alternar entre Lado Luminoso e Sombrio"
    >
        <input type="checkbox" id="theme-checkbox" role="switch" />
        <div class="slider">
            <div id="icon-container">
                <img id="theme-icon" src="" alt="Ícone do Tema" loading="eager" />
            </div>
            <span id="theme-text">DARK SIDE</span>
            <div class="glow-aura"></div>
        </div>
    </label>
</div>

<style>
    .theme-switch-wrapper {
        display: flex;
        align-items: center;
    }

    .theme-switch {
        display: inline-block;
        height: 42px; /* Aumentado levemente para melhor toque */
        position: relative;
        width: 160px;
        user-select: none;
    }

    .theme-switch input {
        display: none;
    }

    .slider {
        background-color: #0f0f0f;
        bottom: 0;
        cursor: pointer !important;
        left: 0;
        position: absolute;
        right: 0;
        top: 0;
        /* Transição tipo "Mola" (Spring) */
        transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        border-radius: 40px;
        display: flex;
        align-items: center;
        padding: 0 6px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        overflow: hidden;
    }

    /* Aura de brilho dinâmica */
    .glow-aura {
        position: absolute;
        inset: 0;
        border-radius: 40px;
        pointer-events: none;
        transition: box-shadow 0.4s ease;
        z-index: 0;
    }

    /* Hover: Efeito de ignição de sabre de luz */
    .theme-switch:hover .slider {
        border-color: var(--accent);
        box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.3);
    }

    #icon-container {
        background-color: var(--accent);
        height: 32px;
        width: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 
            transform 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55),
            background-color 0.4s ease,
            box-shadow 0.4s ease;
        z-index: 2;
        overflow: hidden;
        box-shadow: 0 0 10px rgba(var(--accent-rgb), 0.5);
    }

    #theme-icon {
        width: 85%;
        height: 85%;
        object-fit: contain;
        transition: transform 0.4s ease, filter 0.3s ease;
    }

    #theme-text {
        position: relative;
        z-index: 2;
        margin-left: 20px;
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 2px;
        transition: all 0.4s ease;
        color: #fff;
        font-family: 'Inter', sans-serif;
        text-shadow: 0 0 5px rgba(0,0,0,0.5);
    }

    /* --- ESTADOS DE ATIVAÇÃO --- */

    /* Light Mode (Jedi) */
    input:checked + .slider {
        background-color: #f0f0f0;
        border-color: #ccc;
    }

    input:checked + .slider .glow-aura {
        box-shadow: inset 0 0 20px rgba(0, 150, 255, 0.1);
    }

    input:checked + .slider #icon-container {
        transform: translateX(114px) rotate(360deg);
        background-color: #0077ff; /* Azul Jedi */
        box-shadow: 0 0 15px rgba(0, 119, 255, 0.6);
    }

    input:checked + .slider #theme-text {
        transform: translateX(-42px);
        color: #333;
    }

    /* Dark Mode (Sith) Custom Accent */
    :global([data-theme="dark"]) #icon-container {
        background-color: #ff0000; /* Vermelho Sith */
        box-shadow: 0 0 15px rgba(255, 0, 0, 0.6);
    }

    /* Responsividade */
    @media (max-width: 768px) {
        .theme-switch { width: 140px; height: 38px; }
        input:checked + .slider #icon-container { transform: translateX(96px) rotate(360deg); }
    }
</style>

<script>
    function setupTheme() {
        const toggleSwitch = document.querySelector("#theme-checkbox") as HTMLInputElement;
        const html = document.documentElement;
        const themeText = document.querySelector("#theme-text");
        const themeIcon = document.querySelector("#theme-icon") as HTMLImageElement;

        const ICON_CONFIG = {
            light: {
                path: "/icons/jedi-order.svg", // Certifique-se que o caminho está correto
                scale: "1.0",
                filter: "brightness(0) invert(1)", // Ícone branco no fundo azul
            },
            dark: {
                path: "/icons/sith.svg",
                scale: "1.9",
                filter: "brightness(0) invert(1)", // Ícone branco no fundo vermelho
            },
        };

        function updateUI(isLight: boolean) {
            if (!themeText || !themeIcon) return;

            const config = isLight ? ICON_CONFIG.light : ICON_CONFIG.dark;
            themeText.textContent = isLight ? "LIGHT SIDE" : "DARK SIDE";
            
            // Pequeno delay na troca da imagem para sincronizar com o meio do deslize
            setTimeout(() => {
                themeIcon.src = config.path;
                themeIcon.style.filter = config.filter;
                themeIcon.style.transform = `scale(${config.scale})`;
            }, 100);
        }

        // Inicialização
        const savedTheme = localStorage.getItem("theme") || "dark";
        const isInitialLight = savedTheme === "light";
        
        if (toggleSwitch) {
            toggleSwitch.checked = isInitialLight;
            updateUI(isInitialLight);
        }

        toggleSwitch?.addEventListener("change", (e) => {
            const isChecked = (e.target as HTMLInputElement).checked;
            const newTheme = isChecked ? "light" : "dark";

            html.setAttribute("data-theme", newTheme);
            localStorage.setItem("theme", newTheme);
            updateUI(isChecked);

            // Dispatch evento global para outros componentes reagirem se necessário
            window.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: newTheme } }));
        });
    }

    setupTheme();
    document.addEventListener("astro:after-swap", setupTheme);
</script>