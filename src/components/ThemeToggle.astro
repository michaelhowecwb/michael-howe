---
// ThemeToggle.astro - Refinado com efeitos de aura e mola (Star Wars Edition)
---

<div class="theme-switch-wrapper">
    <label class="theme-switch" for="theme-checkbox">
        <input
            type="checkbox"
            id="theme-checkbox"
            role="switch"
            aria-label="Alternar entre Lado Luminoso e Sombrio"
        />
        <div class="slider">
            <div id="icon-container">
                <img
                    id="theme-icon"
                    src=""
                    alt=""
                    loading="eager"
                    decoding="async"
                />
            </div>
            <span id="theme-text">DARK SIDE</span>
            <div class="glow-aura"></div>
        </div>
    </label>
</div>

<style>
    /* --- Theme Variables --- */
    :root {
        --jedi-blue: #0077ff;
        --sith-red: #ff0000;
        --switch-bg: #0f0f0f;
    }

    :global([data-theme="light"]) {
        --switch-bg: #e2e8f0;
    }

    /* --- Structure --- */
    .theme-switch-wrapper {
        display: flex;
        align-items: center;
    }

    .theme-switch {
        display: inline-block;
        height: 42px;
        position: relative;
        width: 160px;
        user-select: none;
        cursor: pointer;
    }

    .theme-switch input {
        display: none;
    }

    .slider {
        background-color: var(--switch-bg);
        bottom: 0;
        left: 0;
        position: absolute;
        right: 0;
        top: 0;
        transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        border-radius: 40px;
        display: flex;
        align-items: center;
        padding: 0 6px;
        border: 1px solid rgba(128, 128, 128, 0.2);
        overflow: hidden;
    }

    .glow-aura {
        position: absolute;
        inset: 0;
        border-radius: 40px;
        pointer-events: none;
        transition: box-shadow 0.4s ease;
        z-index: 0;
    }

    .theme-switch:hover .slider {
        border-color: var(--accent);
        box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.3);
    }

    #icon-container {
        background-color: var(--accent);
        height: 32px;
        width: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
            transform 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55),
            background-color 0.4s ease,
            box-shadow 0.4s ease;
        z-index: 2;
        box-shadow: 0 0 10px rgba(var(--accent-rgb), 0.5);
    }

    #theme-icon {
        width: 85%;
        height: 85%;
        object-fit: contain;
        transition:
            transform 0.4s ease,
            filter 0.3s ease;
    }

    #theme-text {
        position: relative;
        z-index: 2;
        margin-left: 20px;
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 2px;
        transition: all 0.4s ease;
        color: var(--text);
        font-family: "Inter", sans-serif;
        pointer-events: none;
    }

    :global([data-theme="dark"]) #theme-text {
        text-shadow: 0 0 5px rgba(0, 0, 0, 0.5);
    }
    :global([data-theme="light"]) #theme-text {
        text-shadow: none;
    }

    /* --- Light Mode --- (Jedi) */
    input:checked + .slider {
        border-color: #ccc;
    }

    input:checked + .slider .glow-aura {
        box-shadow: inset 0 0 20px rgba(0, 150, 255, 0.1);
    }

    input:checked + .slider #icon-container {
        transform: translateX(114px) rotate(360deg);
        background-color: var(--jedi-blue);
        box-shadow: 0 0 15px rgba(0, 119, 255, 0.6);
    }

    input:checked + .slider #theme-text {
        transform: translateX(-42px);
    }

    /* --- Dark Mode (Sith) --- */
    :global([data-theme="dark"]) #icon-container {
        background-color: var(--sith-red);
        box-shadow: 0 0 15px rgba(255, 0, 0, 0.6);
    }

    @media (max-width: 768px) {
        .theme-switch {
            width: 140px;
            height: 38px;
        }
        #icon-container {
            height: 28px;
            width: 28px;
        }
        input:checked + .slider #icon-container {
            transform: translateX(98px) rotate(360deg);
        }
        input:checked + .slider #theme-text {
            transform: translateX(-38px);
        }
    }
</style>

<script>
    const ICON_CONFIG = {
        light: {
            path: "/icons/jedi-order.svg",
            scale: "1.0",
            filter: "brightness(0) invert(1)",
        },
        dark: {
            path: "/icons/sith.svg",
            scale: "1.9",
            filter: "brightness(0) invert(1)",
        },
    };

    document.addEventListener("astro:page-load", () => {
        const toggleSwitch = document.querySelector(
            "#theme-checkbox",
        ) as HTMLInputElement;
        const html = document.documentElement;
        const themeText = document.querySelector("#theme-text");
        const themeIcon = document.querySelector(
            "#theme-icon",
        ) as HTMLImageElement;

        if (!toggleSwitch || !themeIcon || !themeText) return;

        function updateUI(isLight: boolean) {
            const config = isLight ? ICON_CONFIG.light : ICON_CONFIG.dark;
            themeText!.textContent = isLight ? "LIGHT SIDE" : "DARK SIDE";

            setTimeout(() => {
                themeIcon.src = config.path;
                themeIcon.style.filter = config.filter;
                themeIcon.style.transform = `scale(${config.scale})`;
            }, 150);
        }

        const currentTheme = localStorage.getItem("theme") || "dark";
        html.setAttribute("data-theme", currentTheme);

        const isInitialLight = currentTheme === "light";

        toggleSwitch.checked = isInitialLight;
        updateUI(isInitialLight);

        toggleSwitch.addEventListener("change", (e) => {
            const isChecked = (e.target as HTMLInputElement).checked;
            const newTheme = isChecked ? "light" : "dark";

            html.setAttribute("data-theme", newTheme);
            localStorage.setItem("theme", newTheme);
            updateUI(isChecked);

            window.dispatchEvent(
                new CustomEvent("theme-changed", {
                    detail: { theme: newTheme },
                }),
            );
        });
    });
</script>
