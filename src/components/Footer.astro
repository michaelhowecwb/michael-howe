---
const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");
const nome = "Michael Howe";
---

<footer class="footer-stripe">
  <div class="footer-container">
    <div class="footer-cta reveal">
      <span class="status-badge">
        <span class="ping"></span>
        {isPt ? "Disponível para novos projetos" : "Available for new projects"}
      </span>
      <h2 class="cta-title">
        {
          isPt ? (
            <>
              Vamos criar algo incrível<span class="text-accent"> ?</span>
            </>
          ) : (
            <>
              Let's build something great<span class="text-accent"> ?</span>
            </>
          )
        }
      </h2>

      <button
        id="footer-contact-btn"
        class="main-contact-link"
        aria-label={isPt ? "Abrir formulário de contato" : "Open contact form"}
      >
        <span class="btn-content">
          {isPt ? "ME ENVIE UMA MENSAGEM" : "SEND ME A MESSAGE"}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="var(--accent)"
            class="mail-icon"
            aria-hidden="true"
          >
            <use href="/icons/EmailFill.svg"></use>
          </svg>
        </span>
      </button>
    </div>

    <div class="footer-bottom-grid">
      <div class="footer-info reveal">
        <div class="info-item">
          <span class="info-label">{isPt ? "LOCALIZAÇÃO" : "LOCATION"}</span>
          <address class="info-value">Curitiba, PR — Brazil 🇧🇷</address>
        </div>

        <div class="info-item">
          <span class="info-label">{isPt ? "SOCIAL" : "FOLLOW ME"}</span>
          <div class="social-links">
            <a
              href="https://github.com/michaelhowecwb"
              target="_blank"
              rel="noopener noreferrer"
              class="social-item-wrap"
              aria-label="GitHub"
            >
              <div class="icon-box github-box">
                <svg
                  viewBox="0 0 99.59 99.59"
                  xmlns="http://www.w3.org/2000/svg"
                  class="social-svg"
                  aria-hidden="true"
                ><use href="/icons/GitHubRound.svg"></use>
                </svg>
              </div>
              <span class="social-label">GitHub</span>
            </a>

            <a
              href="https://www.linkedin.com/in/michael-howe-cwb/"
              target="_blank"
              rel="noopener noreferrer"
              class="social-item-wrap"
              aria-label="LinkedIn"
            >
              <div class="icon-box linkedin-box">
                <svg
                  viewBox="0 0 99.59 99.59"
                  xmlns="http://www.w3.org/2000/svg"
                  class="social-svg"
                  aria-hidden="true"
                ><use href="/icons/LinkedInRound.svg"></use>
                </svg>
              </div>
              <span class="social-label">LinkedIn</span>
            </a>
          </div>
        </div>
      </div>

      <div class="footer-copy-area reveal">
        <p class="footer-copy">© {new Date().getFullYear()} — {nome}</p>
        <p class="footer-tagline">
          {isPt ? "Feito com Astro & Paixão" : "Built with Astro & Passion"}
        </p>
      </div>
    </div>
  </div>
</footer>

<noscript>
  <style>
    /* Fallback de segurança: Garante que o footer apareça caso o JavaScript esteja desativado */
    .reveal {
      opacity: 1 !important;
      transform: translateY(0) !important;
    }
  </style>
</noscript>

<style>
  .text-accent {
    color: var(--accent);
  }
  .text-gradient {
    background: linear-gradient(to right, var(--accent), #fff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: bold;
  }
  .text-underline {
    border-bottom: 2px solid var(--accent);
  }
  .custom-underline {
    position: relative;
    display: inline-block;
  }
  .custom-underline::after {
    content: "";
    position: absolute;
    left: 20%;
    right: 0;
    bottom: -2px;
    height: 4px;
    background-color: var(--accent);
    border-radius: 2px;
    z-index: -1;
    transition: width 0.3s ease;
  }

  .footer-stripe {
    width: 100%;
    background-color: var(--footer-bg);
    border-top: 1px solid var(--card-border);
    padding: 120px 0 60px;
    position: relative;
    overflow: hidden;
  }
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
  }

  .footer-cta {
    text-align: center;
    margin-bottom: 120px;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(var(--accent-rgb), 0.1);
    color: var(--accent);
    padding: 8px 20px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 30px;
  }

  .ping {
    width: 8px;
    height: 8px;
    background-color: var(--accent);
    border-radius: 50%;
    position: relative;
  }
  .ping::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--accent);
    border-radius: 50%;
    animation: ping-anim 1.5s infinite;
  }
  @keyframes ping-anim {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(3);
      opacity: 0;
    }
  }

  .cta-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 900;
    letter-spacing: -4px;
    line-height: 0.9;
    margin-bottom: 60px;
    color: var(--text);
  }

  .main-contact-link {
    display: inline-block;
    text-decoration: none;
    border-radius: 100px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
  }

  .btn-content {
    display: flex;
    align-items: center;
    gap: 15px;
    border: 2px solid var(--accent);
    color: var(--accent);
    padding: 18px 45px;
    border-radius: 100px;
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 1px;
    transition: all 0.4s ease;
  }

  .main-contact-link:hover {
    transform: translateY(-5px);
  }
  .main-contact-link:hover .btn-content {
    background: var(--accent);
    color: #000;
    box-shadow: 0 0 30px rgba(var(--accent-rgb), 0.4);
  }
  .main-contact-link:hover .mail-icon {
    transform: rotate(10deg) scale(1.1);
    fill: #000;
    transition: 0.3s;
  }

  /* A11y: Foco visível para navegação por teclado */
  .main-contact-link:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 4px;
  }

  .footer-bottom-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: flex-end;
    border-top: 1px solid var(--card-border);
    padding-top: 60px;
  }

  .info-item {
    margin-bottom: 30px;
  }
  .info-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 15px;
    letter-spacing: 2px;
  }
  .info-value {
    font-size: 1.1rem;
    color: var(--text);
    font-weight: 500;
    font-style: normal;
  }

  .social-links {
    display: flex;
    gap: 40px;
    margin-top: 10px;
  }
  .social-item-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  /* A11y: Foco visível ajustado para os links sociais */
  .social-item-wrap:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 6px;
    border-radius: 8px;
  }

  .icon-box {
    width: 60px;
    height: 60px;
    border: 1px solid var(--card-border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .social-svg {
    width: 34px;
    height: 34px;
    fill: var(--accent);
    transition: 0.3s;
  }
  .github-box .social-svg {
    width: 40px;
    height: 40px;
    color: var(--accent);
  }
  .linkedin-box .social-svg {
    width: 40px;
    height: 40px;
    color: var(--accent);
  }

  .social-label {
    font-family: "Fira Code", monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: 0.3s;
  }

  .social-item-wrap:hover .icon-box {
    background: var(--accent);
    border-color: var(--accent);
    transform: translateY(-6px) scale(1.2);
    box-shadow: 0 10px 20px var(--dropshadow-rgb);
  }
  .social-item-wrap:hover .social-svg {
    fill: #000;
    color: #000;
  }
  .social-item-wrap:hover .social-label {
    color: var(--accent);
    letter-spacing: 2px;
  }

  .footer-copy-area {
    text-align: right;
  }
  .footer-copy {
    font-size: 1rem;
    color: var(--text);
    font-weight: 600;
    margin: 0;
  }
  .footer-tagline {
    font-size: 0.8rem;
    color: var(--secondary);
    margin-top: 5px;
  }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s ease;
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Fallback: Acessibilidade para usuários com preferência de movimento reduzido */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1 !important;
      transform: translateY(0) !important;
      transition: none !important;
    }
  }

  @media (max-width: 768px) {
    .footer-stripe {
      padding: 80px 0 40px;
    }
    .footer-bottom-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }
    .social-links {
      justify-content: center;
    }
    .footer-copy-area {
      text-align: center;
    }
    .cta-title {
      letter-spacing: -2px;
      margin-bottom: 40px;
    }
    .btn-content {
      padding: 16px 30px;
      font-size: 1rem;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const footerBtn = document.getElementById("footer-contact-btn");

    if (footerBtn && !footerBtn.hasAttribute("data-listener-attached")) {
      footerBtn.addEventListener("click", () => {
        window.dispatchEvent(new CustomEvent("openContactModal"));
      });
      footerBtn.setAttribute("data-listener-attached", "true");
    }
  });
</script>