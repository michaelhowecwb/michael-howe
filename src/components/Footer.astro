---
import { ui } from "@utils/i18n";
const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");
const t = isPt ? ui.pt : ui.en;
const nome = "Michael Howe";
---

<footer class="footer-stripe">
  <div class="footer-container">
    <div class="footer-cta reveal">
      <span class="status-badge">
        <span class="ping"></span>
        {isPt ? "Disponível para novos projetos" : "Available for new projects"}
      </span>
      <h2 class="cta-title">
        {isPt ? "Vamos criar algo incrível?" : "Let's build something great?"}
      </h2>
      
      <a href="mailto:michaelhowecwb@gmail.com" class="main-contact-link">
        <span class="btn-content">
          {isPt ? "ME MANDE UM E-MAIL" : "SEND ME AN EMAIL"}
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mail-icon" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </span>
      </a>
    </div>

    <div class="footer-bottom-grid">
      <div class="footer-info reveal">
        <div class="info-item">
          <span class="info-label">{isPt ? "LOCALIZAÇÃO" : "LOCATION"}</span>
          <span class="info-value">Curitiba, PR — Brazil 🇧🇷</span>
        </div>
        
        <div class="info-item">
          <span class="info-label">{isPt ? "SOCIAL" : "FOLLOW ME"}</span>
          <div class="social-links">
            <a href="https://github.com/michaelhowecwb" target="_blank" rel="noopener noreferrer" class="social-item-wrap">
              <div class="icon-box github-box">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="social-svg" aria-hidden="true">
                  <path d="M12 1A10.89 10.89 0 0 0 1 11.77 10.79 10.79 0 0 0 8.52 22c.55.1.75-.23.75-.52v-1.83c-3.06.65-3.71-1.44-3.71-1.44a2.86 2.86 0 0 0-1.22-1.58c-1-.66.08-.65.08-.65a2.31 2.31 0 0 1 1.68 1.11 2.37 2.37 0 0 0 3.2.89 2.33 2.33 0 0 1 .7-1.44c-2.44-.27-5-1.19-5-5.32a4.15 4.15 0 0 1 1.11-2.91 3.78 3.78 0 0 1 .11-2.84s.93-.29 3 1.1a10.68 10.68 0 0 1 5.5 0c2.1-1.39 3-1.1 3-1.1a3.78 3.78 0 0 1 .11 2.84A4.15 4.15 0 0 1 19 11.2c0 4.14-2.58 5.05-5 5.32a2.5 2.5 0 0 1 .75 2v2.95c0 .35.2.63.75.52A10.8 10.8 0 0 0 23 11.77 10.89 10.89 0 0 0 12 1"/>
                </svg>
              </div>
              <span class="social-label">GitHub</span>
            </a>

            <a href="https://www.linkedin.com/in/michael-how-cwb/" target="_blank" rel="noopener noreferrer" class="social-item-wrap">
              <div class="icon-box linkedin-box">
                <svg viewBox="-143 145 512 512" xmlns="http://www.w3.org/2000/svg" class="social-svg" aria-hidden="true">
                  <path d="M329,145h-432c-22.1,0-40,17.9-40,40v432c0,22.1,17.9,40,40,40h432c22.1,0,40-17.9,40-40V185C369,162.9,351.1,145,329,145z M41.4,508.1H-8.5V348.4h49.9V508.1z M15.1,328.4h-0.4c-18.1,0-29.8-12.2-29.8-27.7c0-15.8,12.1-27.7,30.5-27.7 c18.4,0,29.7,11.9,30.1,27.7C45.6,316.1,33.9,328.4,15.1,328.4z M241,508.1h-56.6v-82.6c0-21.6-8.8-36.4-28.3-36.4 c-14.9,0-23.2,10-27,19.6c-1.4,3.4-1.2,8.2-1.2,13.1v86.3H71.8c0,0,0.7-146.4,0-159.7h56.1v25.1c3.3-11,21.2-26.6,49.8-26.6 c35.5,0,63.3,23,63.3,72.4V508.1z"/>
                </svg>
              </div>
              <span class="social-label">LinkedIn</span>
            </a>
          </div>
        </div>
      </div>

      <div class="footer-copy-area reveal">
        <p class="footer-copy">
          © {new Date().getFullYear()} — {nome}
        </p>
        <p class="footer-tagline">
          {isPt ? "Feito com Astro & Paixão" : "Built with Astro & Passion"}
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-stripe {
    width: 100%;
    background-color: var(--footer-bg);
    border-top: 1px solid var(--card-border);
    padding: 120px 0 60px;
    position: relative;
    overflow: hidden;
  }

  .footer-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 2; }

  /* --- CTA AREA --- */
  .footer-cta { text-align: center; margin-bottom: 120px; }
  
  .status-badge {
    display: inline-flex; align-items: center; gap: 10px;
    background: rgba(var(--accent-rgb), 0.1); color: var(--accent);
    padding: 8px 20px; border-radius: 50px; font-size: 0.75rem;
    font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 30px;
  }

  .ping { width: 8px; height: 8px; background-color: var(--accent); border-radius: 50%; position: relative; }
  .ping::after {
    content: ''; position: absolute; width: 100%; height: 100%;
    background: var(--accent); border-radius: 50%; animation: ping-anim 1.5s infinite;
  }
  @keyframes ping-anim { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(3); opacity: 0; } }

  .cta-title {
    font-size: clamp(2.5rem, 8vw, 5rem); font-weight: 900;
    letter-spacing: -4px; line-height: 0.9; margin-bottom: 60px; color: var(--text);
  }

  /* --- BOTÃO DE E-MAIL --- */
  .main-contact-link {
    display: inline-block;
    text-decoration: none;
    border-radius: 100px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .btn-content {
    display: flex; align-items: center; gap: 15px;
    border: 2px solid var(--accent); color: var(--accent);
    padding: 18px 45px; border-radius: 100px;
    font-size: 1.1rem; font-weight: 800; letter-spacing: 1px;
    transition: all 0.4s ease;
  }

  .mail-icon { transition: transform 0.4s ease; }

  .main-contact-link:hover { transform: translateY(-5px); }
  .main-contact-link:hover .btn-content {
    background: var(--accent); color: #000;
    box-shadow: 0 0 30px rgba(var(--accent-rgb), 0.4);
  }
  .main-contact-link:hover .mail-icon { transform: rotate(10deg) scale(1.1); }

  /* --- GRID INFERIOR --- */
  .footer-bottom-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: flex-end; border-top: 1px solid var(--card-border); padding-top: 60px;
  }

  .info-item { margin-bottom: 30px; }
  .info-label { display: block; font-size: 0.7rem; font-weight: 700; color: var(--accent); margin-bottom: 15px; letter-spacing: 2px; }
  .info-value { font-size: 1.1rem; color: var(--text); font-weight: 500; }

  /* --- SOCIAL LINKS (CORREÇÃO DE TAMANHO) --- */
  .social-links { display: flex; gap: 40px; margin-top: 10px; }
  .social-item-wrap { display: flex; flex-direction: column; align-items: center; gap: 12px; text-decoration: none; }

  .icon-box {
    width: 60px; height: 60px;
    background: transparent; border: 1px solid var(--card-border); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .social-svg { width: 34px; height: 34px; fill: var(--accent); transition: all 0.3s ease; }
  
  /* Ajuste específico para o GitHub para não parecer menor que o LinkedIn */
  .github-box .social-svg { width: 38px; height: 38px; }
  .linkedin-box .social-svg { width: 34px; height: 34px; }

  .social-label {
    font-family: 'Fira Code', monospace; font-size: 0.75rem;
    font-weight: 600; color: var(--secondary); text-transform: uppercase;
    letter-spacing: 1px; transition: all 0.3s ease;
  }

  .social-item-wrap:hover .icon-box {
    background: var(--accent); border-color: var(--accent);
    transform: translateY(-8px) scale(1.1);
    box-shadow: 0 10px 20px var(--dropshadow-rgb);
  }
  .social-item-wrap:hover .social-svg { fill: #000; }
  .social-item-wrap:hover .social-label { color: var(--accent); letter-spacing: 2px; }

  .footer-copy-area { text-align: right; }
  .footer-copy { font-size: 1rem; color: var(--text); font-weight: 600; }
  .footer-tagline { font-size: 0.8rem; color: var(--secondary); margin-top: 5px; }

  .reveal { opacity: 0; transform: translateY(20px); transition: all 0.8s ease; }
  .reveal.active { opacity: 1; transform: translateY(0); }

  @media (max-width: 768px) {
    .footer-bottom-grid { grid-template-columns: 1fr; text-align: center; }
    .social-links { justify-content: center; }
    .footer-copy-area { text-align: center; margin-top: 40px; }
    .cta-title { letter-spacing: -2px; }
  }
</style>

<script>
  function initFooter() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add("active");
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.footer-stripe .reveal').forEach(el => observer.observe(el));
  }
  initFooter();
  document.addEventListener("astro:after-swap", initFooter);
</script>