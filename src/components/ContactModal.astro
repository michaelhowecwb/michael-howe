---
const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");

const meuNumero = "5541997942177";
const mensagemBase = isPt
  ? "Olá Michael, vi seu portfólio e gostaria de conversar!"
  : "Hi Michael, I saw your portfolio and would like to chat!";
const linkWhatsapp = `https://wa.me/${meuNumero}?text=${encodeURIComponent(mensagemBase)}`;
---

<div id="contact-modal" class="modal-overlay">
  <div class="glass-container">
    <button
      id="close-modal"
      class="close-btn"
      aria-label={isPt ? "Fechar" : "Close"}>&times;</button
    >

    <div class="modal-grid">
      <div class="contact-form-side">
        <h2 class="modal-title">{isPt ? "Vamos conversar?" : "Let's talk?"}</h2>
        <p class="modal-subtitle">
          {
            isPt
              ? "Mande uma mensagem e responderei em breve."
              : "Send a message and I'll get back to you shortly."
          }
        </p>

        <form class="specialist-form" novalidate>
          <input
            type="text"
            id="honey"
            name="honey"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            style="position: absolute; left: -9999px; opacity: 0;"
          />
          <div class="input-group">
            <input type="text" id="name" required placeholder=" " />
            <label for="name">{isPt ? "Nome" : "Name"}</label>
            <span class="error-msg"
              >{
                isPt ? "Por favor, diga seu nome" : "Please, tell me your name"
              }</span
            >
          </div>

          <div class="input-group">
            <input type="email" id="email" required placeholder=" " />
            <label for="email">E-mail</label>
            <span class="error-msg"
              >{isPt ? "E-mail inválido" : "Invalid email"}</span
            >
          </div>

          <div class="input-group">
            <textarea id="message" required placeholder=" " rows="4"></textarea>
            <label for="message">{isPt ? "Sua Mensagem" : "Your Message"}</label
            >
            <span class="error-msg"
              >{
                isPt
                  ? "A mensagem não pode estar vazia"
                  : "Message cannot be empty"
              }</span
            >
          </div>

          <button type="submit" class="submit-btn">
            <div class="btn-background"></div>
            <span class="btn-text"
              >{isPt ? "DISPARAR MENSAGEM" : "SEND MESSAGE"}</span
            >
            <div class="btn-progress"></div>
          </button>
        </form>
      </div>

      <div class="contact-social-side">
        <div class="social-header">
          <h3>{isPt ? "Conexão Direta" : "Direct Connect"}</h3>
          <div class="divider"></div>
        </div>

        <div class="social-cards">
          <a
            href={linkWhatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="social-pill whatsapp-pill"
          >
            <div class="pill-icon">
              <svg
                width="32"
                height="32"
                viewBox="0 0 20 20"
                fill="var(--accent)"
                ><path
                  d="M15.821,14.12124 C15.58,14.80344 14.622,15.36761 13.858,15.53266 C13.335,15.64369 12.653,15.73172 10.355,14.77943 C7.774,13.71011 4.19,9.90097 4.19,7.36621 C4.19,6.07582 4.934,4.57337 6.235,4.57337 C6.861,4.57337 6.999,4.58538 7.205,5.07952 C7.446,5.6617 8.034,7.09613 8.104,7.24317 C8.393,7.84635 7.81,8.19946 7.387,8.72462 C7.252,8.88266 7.099,9.05372 7.27,9.3478 C7.44,9.63589 8.028,10.59418 8.892,11.36341 C10.008,12.35771 10.913,12.6748 11.237,12.80984 C11.478,12.90987 11.766,12.88687 11.942,12.69881 C12.165,12.45774 12.442,12.05762 12.724,11.6635 C12.923,11.38141 13.176,11.3464 13.441,11.44643 C13.62,11.50845 15.895,12.56477 15.991,12.73382 C16.062,12.85686 16.062,13.43903 15.821,14.12124 M10.002,0 C4.484,0 0,4.48535 0,10 C0,12.18666 0.705,14.21526 1.904,15.86076 L0.658,19.57687 L4.501,18.3485 C6.082,19.39482 7.969,20 10.002,20 C15.515,20 20,15.51465 20,10 C20,4.48535 15.515,0 10.002,0"
                ></path></svg
              >
            </div>
            <div class="pill-text">
              <span class="pill-label">WhatsApp</span>
              <span class="pill-sub"
                >{isPt ? "Resposta rápida" : "Quick response"}</span
              >
            </div>
          </a>

          <a
            href="https://linkedin.com/in/michael-howe-cwb"
            target="_blank"
            rel="noopener noreferrer"
            class="social-pill linkedin-pill"
          >
            <div class="pill-icon">
              <svg
                width="34"
                height="34"
                viewBox="0 0 99.59 99.59"
                fill="var(--accent)"
                ><path
                  d="M49.795,0A49.795,49.795,0,1,0,99.59,49.795,49.795,49.795,0,0,0,49.795,0ZM36.509,73.868H25.575V38.547H36.509ZM30.991,33.921a6.518,6.518,0,1,1,6.465-6.517A6.492,6.492,0,0,1,30.991,33.921ZM77.481,73.868H66.591V55.328c0-5.085-1.932-7.924-5.953-7.924-4.376,0-6.662,2.956-6.662,7.924V73.868H43.5V38.547H53.986v4.757a12.319,12.319,0,0,1,10.644-5.835c7.49,0,12.851,4.573,12.851,14.034V73.868Z"
                ></path></svg
              >
            </div>
            <div class="pill-text">
              <span class="pill-label">LinkedIn</span>
              <span class="pill-sub"
                >{isPt ? "Rede Profissional" : "Professional Network"}</span
              >
            </div>
          </a>

          <a
            href="https://github.com/michaelhowecwb"
            target="_blank"
            rel="noopener noreferrer"
            class="social-pill github-pill"
          >
            <div class="pill-icon">
              <svg
                width="38"
                height="38"
                viewBox="0 0 24 24"
                fill="var(--accent)"
                ><path
                  d="M12 1A10.89 10.89 0 0 0 1 11.77 10.79 10.79 0 0 0 8.52 22c.55.1.75-.23.75-.52v-1.83c-3.06.65-3.71-1.44-3.71-1.44a2.86 2.86 0 0 0-1.22-1.58c-1-.66.08-.65.08-.65a2.31 2.31 0 0 1 1.68 1.11 2.37 2.37 0 0 0 3.2.89 2.33 2.33 0 0 1 .7-1.44c-2.44-.27-5-1.19-5-5.32a4.15 4.15 0 0 1 1.11-2.91 3.78 3.78 0 0 1 .11-2.84s.93-.29 3 1.1a10.68 10.68 0 0 1 5.5 0c2.1-1.39 3-1.1 3-1.1a3.78 3.78 0 0 1 .11 2.84A4.15 4.15 0 0 1 19 11.2c0 4.14-2.58 5.05-5 5.32a2.5 2.5 0 0 1 .75 2v2.95c0 .35.2.63.75.52A10.8 10.8 0 0 0 23 11.77 10.89 10.89 0 0 0 12 1"
                ></path></svg
              >
            </div>
            <div class="pill-text">
              <span class="pill-label">GitHub</span>
              <span class="pill-sub"
                >{isPt ? "Meus Códigos" : "My Codebase"}</span
              >
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    animation: fadeIn 0.4s ease-out;
  }

  .modal-overlay.open {
    display: flex;
  }

  .glass-container {
    background: rgba(15, 15, 15, 0.85);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    width: 100%;
    max-width: 950px;
    max-height: 90vh;
    overflow-y: auto;
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    padding: 3.5rem;
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.9);
  }

  .glass-container::-webkit-scrollbar {
    width: 6px;
  }
  .glass-container::-webkit-scrollbar-thumb {
    background: var(--accent);
    border-radius: 10px;
  }

  .close-btn {
    position: absolute;
    top: 25px;
    right: 30px;
    background: none;
    border: none;
    color: var(--secondary);
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    transition: 0.3s;
  }
  .close-btn:hover {
    color: var(--accent);
    transform: rotate(90deg);
  }

  .modal-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 5rem;
  }
  .modal-title {
    font-size: 2.8rem;
    font-weight: 900;
    letter-spacing: -2px;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .modal-subtitle {
    color: var(--secondary);
    margin-bottom: 3rem;
    font-size: 1rem;
    opacity: 0.8;
  }
  .specialist-form {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }
  .input-group {
    position: relative;
    width: 100%;
  }

  .input-group input,
  .input-group textarea {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 1.3rem;
    color: #fff;
    font-size: 16px;
    outline: none;
    transition: 0.4s;
  }

  .input-group label {
    position: absolute;
    left: 1.3rem;
    top: 1.3rem;
    color: var(--secondary);
    pointer-events: none;
    transition: 0.3s ease;
  }

  .input-group input:focus + label,
  .input-group input:not(:placeholder-shown) + label,
  .input-group textarea:focus + label,
  .input-group textarea:not(:placeholder-shown) + label {
    transform: translateY(-2.8rem) scale(0.85);
    color: var(--accent);
    font-weight: 800;
  }

  .input-group.error input,
  .input-group.error textarea {
    border-color: #ff5f56;
    animation: shake 0.4s both;
  }
  .error-msg {
    color: #ff5f56;
    font-size: 0.75rem;
    font-weight: 600;
    display: none;
    margin-top: 8px;
  }
  .input-group.error .error-msg {
    display: block;
  }

  .submit-btn {
    position: relative;
    background: #000;
    color: var(--accent);
    border: 2px solid var(--accent);
    padding: 1.3rem;
    border-radius: 14px;
    font-weight: 900;
    letter-spacing: 2px;
    cursor: pointer;
    overflow: hidden;
    transition: 0.3s;
  }
  .btn-text {
    position: relative;
    z-index: 5;
  }
  .btn-background {
    position: absolute;
    inset: 0;
    background: var(--accent);
    opacity: 0;
    transition: 0.3s;
  }
  .submit-btn:hover {
    color: #000;
    box-shadow: 0 0 25px rgba(var(--accent-rgb), 0.5);
  }
  .submit-btn:hover .btn-background {
    opacity: 1;
  }
  .btn-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 4px;
    width: 0%;
    background: #fff;
    z-index: 6;
  }
  .submit-btn.loading .btn-progress {
    width: 100%;
    transition: width 2s linear;
  }

  .social-header h3 {
    font-size: 1.3rem;
    font-weight: 800;
    margin-bottom: 12px;
  }
  .divider {
    width: 50px;
    height: 5px;
    background: var(--accent);
    border-radius: 10px;
    margin-bottom: 2.5rem;
  }
  .social-cards {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .social-pill {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.3rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 22px;
    text-decoration: none;
    transition: 0.4s;
  }
  .pill-icon {
    width: 60px;
    height: 60px;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }
  .pill-label {
    display: block;
    color: var(--text);
    font-weight: 800;
    font-size: 1.1rem;
  }
  .pill-sub {
    color: var(--secondary);
    font-size: 0.85rem;
  }
  .social-pill:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--accent);
    transform: translateX(12px);
  }

  @media (max-width: 900px) {
    .modal-overlay {
      padding: 20px 1.5rem;
      align-items: flex-start;
    }
    .modal-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .glass-container {
      padding: 1.5rem 1.5rem;
      border-radius: 24px;
      max-height: calc(100dvh - 110px);
    }
    .modal-title {
      font-size: 2.2rem;
    }
  }

  @keyframes shake {
    10%,
    90% {
      transform: translateX(-1px);
    }
    30%,
    70% {
      transform: translateX(-3px);
    }
    40%,
    60% {
      transform: translateX(3px);
    }
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script>
  if (!(window as any).contactModalGlobalSetup) {
    window.addEventListener("openContactModal", () => {
      const modal = document.getElementById("contact-modal");
      if (modal) {
        modal.classList.add("open");
        document.body.style.overflow = "hidden";
      }
    });
    (window as any).contactModalGlobalSetup = true;
  }

  document.addEventListener("astro:page-load", () => {
    const modal = document.getElementById("contact-modal");

    if (modal && modal.parentNode !== document.body) {
      document.body.appendChild(modal);
    }

    const closeBtn = document.getElementById("close-modal");
    const form = document.querySelector(".specialist-form") as HTMLFormElement;
    const submitBtn = form?.querySelector(".submit-btn") as HTMLButtonElement;
    const btnText = submitBtn?.querySelector(".btn-text");
    const isPt = window.location.pathname.includes("/pt");

    const closeHandler = () => {
      modal?.classList.remove("open");
      document.body.style.overflow = "";
      form?.reset();
      form
        ?.querySelectorAll(".input-group")
        .forEach((g) => g.classList.remove("error"));
    };

    if (closeBtn && !closeBtn.hasAttribute("data-events-bound")) {
      closeBtn.addEventListener("click", closeHandler);
      closeBtn.setAttribute("data-events-bound", "true");
    }

    if (modal && !modal.hasAttribute("data-events-bound")) {
      modal.addEventListener("click", (e) => {
        if (e.target === modal) closeHandler();
      });
      modal.setAttribute("data-events-bound", "true");
    }

    if (form && !form.hasAttribute("data-events-bound")) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        let hasError = false;
        const inputs = form.querySelectorAll(
          "input[required], textarea[required]",
        );

        inputs.forEach((input: any) => {
          const val = input.value.trim();
          const isEmail = input.type === "email";
          const validEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);

          if (!val || (isEmail && !validEmail)) {
            input.parentElement.classList.add("error");
            hasError = true;
          } else {
            input.parentElement.classList.remove("error");
          }
        });

        if (hasError || !submitBtn || !btnText) return;

        submitBtn.classList.add("loading");
        submitBtn.disabled = true;
        const originalText = btnText.textContent;
        btnText.textContent = isPt ? "IGNITANDO..." : "IGNITING...";

        try {
          const response = await fetch("/api/send-email", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              name: (document.getElementById("name") as HTMLInputElement).value,
              email: (document.getElementById("email") as HTMLInputElement)
                .value,
              message: (
                document.getElementById("message") as HTMLTextAreaElement
              ).value,
              honey: (document.getElementById("honey") as HTMLInputElement)
                .value,
            }),
          });

          if (response.ok) {
            btnText.textContent = isPt
              ? "MENSAGEM DISPARADA! ✓"
              : "MESSAGE SENT! ✓";
            setTimeout(() => {
              closeHandler();
              resetBtn();
            }, 2000);
          } else {
            throw new Error();
          }
        } catch {
          btnText.textContent = isPt ? "FALHA NO DISPARO ✕" : "LAUNCH FAILED ✕";
          setTimeout(resetBtn, 3000);
        }

        function resetBtn() {
          submitBtn!.classList.remove("loading");
          submitBtn!.disabled = false;
          btnText!.textContent = originalText;
        }
      });
      form.setAttribute("data-events-bound", "true");
    }
  });
</script>
