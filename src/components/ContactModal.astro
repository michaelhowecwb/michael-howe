---
// ContactModal.astro
const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");

// CONFIGURAÇÃO DO WHATSAPP
const meuNumero = "5541997942177"; // <--- COLOQUE SEU NÚMERO AQUI (DDI + DDD + NÚMERO, só números)
const mensagemBase = isPt 
  ? "Olá Michael, vi seu portfólio e gostaria de conversar!" 
  : "Hi Michael, I saw your portfolio and would like to chat!";
const linkWhatsapp = `https://wa.me/${meuNumero}?text=${encodeURIComponent(mensagemBase)}`;
---

<div id="contact-modal" class="modal-overlay">
  <div class="glass-container">
    <button id="close-modal" class="close-btn" aria-label="Fechar">&times;</button>
    
    <div class="modal-grid">
      <div class="contact-form-side">
        <h2 class="modal-title">
          {isPt ? "Vamos conversar?" : "Let's talk?"}
        </h2>
        <p class="modal-subtitle">
          {isPt ? "Mande uma mensagem e responderei em breve." : "Send a message and I'll get back to you shortly."}
        </p>

        <form class="specialist-form" novalidate> <div class="input-group">
    <input type="text" id="name" required placeholder=" " />
    <label for="name">{isPt ? "Nome" : "Name"}</label>
    <span class="error-msg">{isPt ? "Por favor, diga seu nome" : "Please, tell me your name"}</span>
  </div>

  <div class="input-group">
    <input type="email" id="email" required placeholder=" " />
    <label for="email">E-mail</label>
    <span class="error-msg">{isPt ? "E-mail inválido" : "Invalid email"}</span>
  </div>

  <div class="input-group">
    <textarea id="message" required placeholder=" " rows="6"></textarea>
    <label for="message">{isPt ? "Sua Mensagem" : "Your Message"}</label>
    <span class="error-msg">{isPt ? "A mensagem não pode estar vazia" : "Message cannot be empty"}</span>
  </div>

  <button type="submit" class="submit-btn">
    <div class="btn-background"></div>
    <span class="btn-text">{isPt ? "DISPARAR MENSAGEM" : "SEND MESSAGE"}</span>
    <div class="btn-progress"></div> </button>
</form>
      </div>

      <div class="contact-social-side">
        <div class="social-header">
            <h3>{isPt ? "Conexão Direta" : "Direct Connect"}</h3>
            <div class="divider"></div>
        </div>

        <div class="social-cards">
          <a href={linkWhatsapp} target="_blank" class="social-pill whatsapp-pill">
            <div class="pill-icon">
                <svg width="38" height="38" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <g transform="translate(-244.000000, -7439.000000)" fill="var(--accent)">
                        <path d="M259.821,7453.12124 C259.58,7453.80344 258.622,7454.36761 257.858,7454.53266 C257.335,7454.64369 256.653,7454.73172 254.355,7453.77943 C251.774,7452.71011 248.19,7448.90097 248.19,7446.36621 C248.19,7445.07582 248.934,7443.57337 250.235,7443.57337 C250.861,7443.57337 250.999,7443.58538 251.205,7444.07952 C251.446,7444.6617 252.034,7446.09613 252.104,7446.24317 C252.393,7446.84635 251.81,7447.19946 251.387,7447.72462 C251.252,7447.88266 251.099,7448.05372 251.27,7448.3478 C251.44,7448.63589 252.028,7449.59418 252.892,7450.36341 C254.008,7451.35771 254.913,7451.6748 255.237,7451.80984 C255.478,7451.90987 255.766,7451.88687 255.942,7451.69881 C256.165,7451.45774 256.442,7451.05762 256.724,7450.6635 C256.923,7450.38141 257.176,7450.3464 257.441,7450.44643 C257.62,7450.50845 259.895,7451.56477 259.991,7451.73382 C260.062,7451.85686 260.062,7452.43903 259.821,7453.12124 M254.002,7439 L253.997,7439 L253.997,7439 C248.484,7439 244,7443.48535 244,7449 C244,7451.18666 244.705,7453.21526 245.904,7454.86076 L244.658,7458.57687 L248.501,7457.3485 C250.082,7458.39482 251.969,7459 254.002,7459 C259.515,7459 264,7454.51465 264,7449 C264,7443.48535 259.515,7439 254.002,7439"></path>
                    </g>
                </svg>
            </div>
            <div class="pill-text">
                <span class="pill-label">WhatsApp</span>
                <span class="pill-sub">{isPt ? "Resposta rápida" : "Quick response"}</span>
            </div>
          </a>

          <a href="https://linkedin.com/in/michael-howe-cwb" target="_blank" class="social-pill linkedin-pill">
            <div class="pill-icon">
                <svg width="40" height="40" viewBox="0 0 99.59 99.59" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="linkedinGrad" x1="0" x2="1" y1="0" y2="1">
                            <stop offset="0" stop-color="var(--accent)"></stop>
                            <stop offset="1" stop-color="var(--accent)"></stop>
                        </linearGradient>
                    </defs>
                    <path fill="url(#linkedinGrad)" d="M49.795,0A49.795,49.795,0,1,0,99.59,49.795,49.795,49.795,0,0,0,49.795,0ZM36.509,73.868H25.575V38.547H36.509ZM30.991,33.921a6.518,6.518,0,1,1,6.465-6.517A6.492,6.492,0,0,1,30.991,33.921ZM77.481,73.868H66.591V55.328c0-5.085-1.932-7.924-5.953-7.924-4.376,0-6.662,2.956-6.662,7.924V73.868H43.5V38.547H53.986v4.757a12.319,12.319,0,0,1,10.644-5.835c7.49,0,12.851,4.573,12.851,14.034V73.868Z"></path>
                </svg>
            </div>
            <div class="pill-text">
                <span class="pill-label">LinkedIn</span>
                <span class="pill-sub">{isPt ? "Rede Profissional" : "Professional Network"}</span>
            </div>
          </a>

          <a href="https://github.com/michaelhowecwb" target="_blank" class="social-pill github-pill">
            <div class="pill-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path fill="var(--accent)" d="M12 1A10.89 10.89 0 0 0 1 11.77 10.79 10.79 0 0 0 8.52 22c.55.1.75-.23.75-.52v-1.83c-3.06.65-3.71-1.44-3.71-1.44a2.86 2.86 0 0 0-1.22-1.58c-1-.66.08-.65.08-.65a2.31 2.31 0 0 1 1.68 1.11 2.37 2.37 0 0 0 3.2.89 2.33 2.33 0 0 1 .7-1.44c-2.44-.27-5-1.19-5-5.32a4.15 4.15 0 0 1 1.11-2.91 3.78 3.78 0 0 1 .11-2.84s.93-.29 3 1.1a10.68 10.68 0 0 1 5.5 0c2.1-1.39 3-1.1 3-1.1a3.78 3.78 0 0 1 .11 2.84A4.15 4.15 0 0 1 19 11.2c0 4.14-2.58 5.05-5 5.32a2.5 2.5 0 0 1 .75 2v2.95c0 .35.2.63.75.52A10.8 10.8 0 0 0 23 11.77 10.89 10.89 0 0 0 12 1"></path>
                </svg>
            </div>
            <div class="pill-text">
                <span class="pill-label">GitHub</span>
                <span class="pill-sub">{isPt ? "Meus Códigos" : "My Codebase"}</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6); /* Reduzi a opacidade para o desfoque atrás aparecer melhor */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    animation: fadeIn 0.4s ease-out;
  }

  .modal-overlay.open { display: flex; }

  /* --- O GLASSMORPHISM CORRIGIDO --- */
  .glass-container {
    background: rgba(20, 20, 20, 0.5); /* Menor opacidade para ver o fundo */
    backdrop-filter: blur(30px); /* Aumentado para efeito mais leitoso */
    -webkit-backdrop-filter: blur(30px);
    width: 100%;
    max-width: 950px;
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.1); /* Borda "brilho de vidro" */
    position: relative;
    padding: 3.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7);
  }

  .close-btn {
    position: absolute;
    top: 25px;
    right: 30px;
    background: none;
    border: none;
    color: var(--secondary);
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    transition: all 0.3s;
  }
  .close-btn:hover { color: var(--accent); transform: rotate(90deg); }

  .modal-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 5rem;
  }

  /* --- FORM SIDE --- */
  .modal-title { font-size: 2.8rem; font-weight: 900; margin-bottom: 0.5rem; letter-spacing: -2px; color: var(--text); }
  .modal-subtitle { color: var(--secondary); margin-bottom: 3rem; font-size: 1rem; opacity: 0.8; }

  .specialist-form { display: flex; flex-direction: column; gap: 1.8rem; }

  .input-group { position: relative; width: 100%; }

  .input-group input, .input-group textarea {
    width: 100%;
    background: rgba(255, 255, 255, 0.05); /* Mais transparente */
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 1.3rem;
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    outline: none;
  }

  .input-group label {
    position: absolute;
    left: 1.3rem;
    top: 1.3rem;
    color: var(--secondary);
    pointer-events: none;
    transition: all 0.3s ease;
  }

  .input-group input:focus, .input-group textarea:focus {
    border-color: var(--accent);
    background: rgba(var(--accent-rgb), 0.08);
    box-shadow: 0 0 20px rgba(var(--accent-rgb), 0.15);
  }

  .input-group input:focus + label,
  .input-group input:not(:placeholder-shown) + label,
  .input-group textarea:focus + label,
  .input-group textarea:not(:placeholder-shown) + label {
    transform: translateY(-2.8rem) scale(0.85);
    color: var(--accent);
    font-weight: 800;
  }

.input-group.error input, 
  .input-group.error textarea {
    border-color: #ff5f56 !important;
    background: rgba(255, 95, 86, 0.05) !important;
    animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both;
  }
  .error-msg {
    color: #ff5f56;
    font-size: 0.75rem;
    font-weight: 600;
    margin-top: 5px;
    display: block;
    opacity: 0;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    pointer-events: none;
    height: 0;
  }

  .input-group.error .error-msg {
    opacity: 1;
    transform: translateY(0);
    height: auto;
    margin-top: 8px;
  }
  /* --- SEND BUTTON --- */
  .submit-btn {
    position: relative;
    background: var(--accent);
    color: #000;
    border: none;
    padding: 1.3rem;
    border-radius: 14px;
    font-weight: 900;
    letter-spacing: 1.5px;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    margin-top: 10px;
  }

  .btn-text { position: relative; z-index: 2; }

  .btn-shimmer {
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    z-index: 1;
  }

  .submit-btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(var(--accent-rgb), 0.4);
  }

  .submit-btn:hover .btn-shimmer {
    left: 100%;
    transition: all 0.8s;
  }

.submit-btn {
    position: relative;
    background: #111; /* Fundo escuro para o brilho destacar */
    color: var(--accent);
    border: 2px solid var(--accent);
    padding: 1.3rem;
    border-radius: 14px;
    font-weight: 900;
    letter-spacing: 2px;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .btn-text { position: relative; z-index: 5; transition: all 0.3s; }

  .btn-background {
    position: absolute;
    inset: 0;
    background: var(--accent);
    opacity: 0.1;
    transition: opacity 0.3s;
  }

  .submit-btn:hover {
    box-shadow: 0 0 20px rgba(var(--accent-rgb), 0.4);
    color: #000;
  }

  .submit-btn:hover .btn-background { opacity: 1; }

/* Barra de carregamento interna */
  .btn-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 4px;
    width: 0%;
    background: #fff;
    box-shadow: 0 0 10px #fff;
    transition: width 0.3s ease;
    z-index: 6;
  }

  .submit-btn.loading .btn-progress {
    width: 100%;
    transition: width 2s linear; /* Tempo simulado de disparo */
  }

  /* Animação de Shake */
  @keyframes shake {
    10%, 90% { transform: translate3d(-1px, 0, 0); }
    20%, 80% { transform: translate3d(2px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
    40%, 60% { transform: translate3d(4px, 0, 0); }
  }

  /* --- SOCIAL SIDE --- */
  .social-header h3 { font-size: 1.3rem; font-weight: 800; margin-bottom: 12px; }
  .divider { width: 50px; height: 5px; background: var(--accent); border-radius: 10px; margin-bottom: 2.5rem; }

  .social-cards { display: flex; flex-direction: column; gap: 1.2rem; }

  .social-pill {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.3rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 22px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .pill-icon {
    width: 65px; /* Aumentado para ícones maiores */
    height: 65px;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    transition: all 0.3s ease;
  }

  .pill-label { display: block; color: var(--text); font-weight: 800; font-size: 1.1rem; }
  .pill-sub { color: var(--secondary); font-size: 0.85rem; }

  .social-pill:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--accent);
    transform: translateX(12px);
  }

  .social-pill:hover .pill-icon {
    transform: scale(1.1);
    background: rgba(var(--accent-rgb), 0.15);
  }

  @media (max-width: 850px) {
    .modal-grid { grid-template-columns: 1fr; gap: 4rem; }
    .glass-container { padding: 2.5rem 1.5rem; }
    .modal-title { font-size: 2.2rem; }
  }

  @keyframes fadeIn { 
    from { opacity: 0; transform: scale(0.95); } 
    to { opacity: 1; transform: scale(1); } 
  }
</style>

<script>
  function setupModal() {
    const modal = document.getElementById('contact-modal');
    const closeBtn = document.getElementById('close-modal');
    const form = document.querySelector('.specialist-form') as HTMLFormElement;
    const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;
    const btnText = submitBtn?.querySelector('.btn-text');
    
    // Detecta o idioma pela URL para as mensagens do botão
    const isPt = window.location.pathname.includes('/pt');

    window.addEventListener('openContactModal', () => {
      modal?.classList.add('open');
      document.body.style.overflow = 'hidden';
    });

    const closeHandler = () => {
      modal?.classList.remove('open');
      document.body.style.overflow = 'auto';
      // Limpa erros e campos ao fechar
      form?.reset();
      form?.querySelectorAll('.input-group').forEach(g => g.classList.remove('error'));
    };

    closeBtn?.addEventListener('click', closeHandler);

    // --- LÓGICA DE VALIDAÇÃO E ENVIO ---
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // 1. Reset de estados anteriores
      const groups = form.querySelectorAll('.input-group');
      groups.forEach(g => g.classList.remove('error'));
      let hasError = false;

      // 2. Validação Sênior (Manual)
      const inputs = form.querySelectorAll('input[required], textarea[required]');
      inputs.forEach((input: any) => {
        const value = input.value.trim();
        const isEmail = input.type === 'email';
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (!value || (isEmail && !emailRegex.test(value))) {
          input.parentElement.classList.add('error');
          hasError = true;
        }
      });

      // Se houver erro, paramos aqui (o CSS cuidará do "shake")
      if (hasError || !submitBtn || !btnText) return;

      // 3. Início do Envio (Efeito Sabre/Ignição)
      submitBtn.classList.add('loading');
      submitBtn.disabled = true;
      const originalText = btnText.textContent;
      btnText.textContent = isPt ? 'IGNITANDO...' : 'IGNITING...';

      const formData = {
        name: (document.getElementById('name') as HTMLInputElement).value,
        email: (document.getElementById('email') as HTMLInputElement).value,
        message: (document.getElementById('message') as HTMLTextAreaElement).value,
      };

      try {
        const response = await fetch('/api/send-email', {
          method: 'POST',
          body: JSON.stringify(formData),
          headers: { 'Content-Type': 'application/json' }
        });

        if (response.ok) {
          // Sucesso
          btnText.textContent = isPt ? 'MENSAGEM DISPARADA! ✓' : 'MESSAGE SENT! ✓';
          submitBtn.style.borderColor = '#27c93f';
          submitBtn.style.color = '#27c93f';
          
          setTimeout(() => {
            closeHandler();
            resetButton(submitBtn, btnText, originalText!);
          }, 2500);
        } else {
          throw new Error();
        }
      } catch (err) {
        // Erro
        btnText.textContent = isPt ? 'FALHA NO DISPARO ✕' : 'LAUNCH FAILED ✕';
        submitBtn.style.borderColor = '#ff5f56';
        submitBtn.style.color = '#ff5f56';
        
        setTimeout(() => {
          resetButton(submitBtn, btnText, originalText!);
        }, 3000);
      }
    });

    function resetButton(btn: HTMLButtonElement, textEl: Element, oldText: string) {
      btn.classList.remove('loading');
      btn.disabled = false;
      btn.style.borderColor = '';
      btn.style.color = '';
      textEl.textContent = oldText;
    }

    // Fechar ao clicar fora
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeHandler();
    });
  }

  setupModal();
  document.addEventListener("astro:after-swap", setupModal);
</script>