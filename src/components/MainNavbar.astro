---
const { pathname } = Astro.url;
const isHome = pathname === '/' || pathname === '/pt/' || pathname === '/pt' || pathname === '/en/' || pathname === '/en';
import { ui } from '@utils/i18n';
import ThemeToggle from '@components/ThemeToggle.astro';
import LanguagePicker from '@components/LanguagePicker.astro';
const nome = "Michael Howe";
const isPt = pathname.includes('/pt');
const t = isPt ? ui.pt : ui.en;
---

<nav class="mainNav">
  <div class="navContainer">
    <div class="brand">
      <span class="navName">{nome}</span>
    </div>

    <div class="navContent">
      <div class="links">
        <a href="#home" class="nav-link" data-scroll-to="home">Home</a>
        <a href="#services" class="nav-link" data-scroll-to="services">{t['nav.services']}</a>
        <a href="#works" class="nav-link" data-scroll-to="works">{t['nav.works']}</a>
      </div>
      
      <div class="separator"></div>

      <div class="controls">
        <LanguagePicker />
        <ThemeToggle />
      </div>
    </div>
  </div>
</nav>

<style>
  /* Base da Navbar */
  .mainNav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 70px;
    z-index: 1000;
    /* Usando a variável RGB para o fundo com opacidade */
    background: rgba(var(--bg-rgb), 0.8); 
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    /* Borda adaptável: clara no dark, escura no light */
    border-bottom: 1px solid rgba(var(--text-rgb), 0.1);
    display: flex;
    align-items: center;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .navContainer {
    width: 100%;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .navName {
    font-weight: 800;
    font-size: 1.5rem;
    white-space: nowrap;
    /* Cor automática baseada no tema */
    color: var(--text); 
  }

  .navContent {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Links e Efeitos */
  .links {
    display: flex;
    gap: 0.5rem;
  }

  .links a {
    position: relative;
    text-decoration: none;
    color: var(--secondary);
    font-size: 0.95rem;
    font-weight: 500;
    white-space: nowrap;
    transition: color 0.3s ease;
    padding: 0 10px;
  }

  /* Linha animada abaixo do link */
  .links a::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -5px;
    left: 50%;
    background-color: var(--accent);
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }

  .links a:hover::after,
  .links a.active::after {
    width: 100%;
  }

  .links a:hover, 
  .links a.active {
    color: var(--accent) !important;
  }

  .separator {
    width: 1px;
    height: 20px;
    /* Separador também se adapta ao tema */
    background: rgba(var(--text-rgb), 0.2);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  /* Ajuste para Mobile */
  @media (max-width: 768px) {
    .links, .separator {
      display: none;
    }
  }

  /* --- LÓGICA LIGHT MODE ESPECÍFICA --- */
  :global([data-theme='light']) .mainNav {
    background: rgba(255, 255, 255, 0.8);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }
</style>