---
import { ui } from "@utils/i18n";
import ThemeToggle from "@components/ThemeToggle.astro";
import LanguagePicker from "@components/LanguagePicker.astro";

const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");
const normalizedPath = pathname.replace(/\/$/, "");
const isHome =
  normalizedPath === "" || normalizedPath === "/" || normalizedPath === "/pt";

const t = isPt ? ui.pt : ui.en;
const baseUrl = isPt ? "/pt/" : "/";
const nome = "Michael Howe";
---

<nav
  class="mainNav"
  id="main-nav"
  aria-label={isPt ? "Menu Principal" : "Main Menu"}
>
  <div class="navContainer">
    <div class="brand">
      <a href={baseUrl} class="brand-link" style="text-decoration: none;">
        <span class="navName">{nome}</span>
      </a>
    </div>

    <div class="navContent">
      <div class="links desktop-only">
        <a
          href={isHome ? "#home" : `${baseUrl}#home`}
          class="nav-link"
          data-section="home">Home</a
        >
        <a
          href={isHome ? "#about" : `${baseUrl}#about`}
          class="nav-link"
          data-section="about">{t["nav.about"]}</a
        >
        <a
          href={isHome ? "#works" : `${baseUrl}#works`}
          class="nav-link"
          data-section="works">{t["nav.works"]}</a
        >
      </div>

      <div class="separator desktop-only"></div>

      <div class="controls">
        <LanguagePicker />
        <ThemeToggle />

        <button
          class="hamburger"
          aria-label={isPt ? "Abrir menu" : "Open menu"}
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <div class="hamburger-box">
            <span class="line"></span>
            <span class="line"></span>
            <span class="line"></span>
          </div>
        </button>
      </div>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-modal="true" aria-label={isPt ? "Navegação Mobile" : "Mobile Navigation"}>
    <a
      href={isHome ? "#home" : `${baseUrl}#home`}
      class="mobile-link"
      data-section="home">Home</a
    >
    <a
      href={isHome ? "#about" : `${baseUrl}#about`}
      class="mobile-link"
      data-section="about">{t["nav.about"]}</a
    >
    <a
      href={isHome ? "#works" : `${baseUrl}#works`}
      class="mobile-link"
      data-section="works">{t["nav.works"]}</a
    >
  </div>
</nav>

<style>
  /* --- Structure --- */
  .mainNav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 80px;
    z-index: 100;
    background: rgba(var(--mainnav-bg-rgb), 0.75);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-bottom: 1px solid rgba(var(--text-rgb), 0.08);
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
  }

  .mainNav.scrolled {
    height: 65px;
    background: rgba(var(--mainnav-bg-rgb), 0.9);
  }

  .navContainer {
    width: 100%;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .navName {
    font-weight: 900;
    font-size: 1.8rem;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .navName::before {
    content: "";
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
  }

  /* --- LINKS --- */
  .links {
    display: flex;
    gap: 2rem;
    background: rgba(var(--text-rgb), 0.03);
    padding: 8px 30px;
    border-radius: 50px;
    border: 1px solid rgba(var(--text-rgb), 0.05);
  }

  .nav-link {
    position: relative;
    text-decoration: none;
    color: var(--secondary);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 5px 0;
    transition: color 0.3s ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--accent);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--accent);
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .navContent {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .controls {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .separator {
    width: 1px;
    height: 20px;
    background: rgba(var(--text-rgb), 0.15);
  }

  /* --- Hamburguer --- */
  .hamburger {
    display: none;
    background: rgba(var(--text-rgb), 0.05);
    border: none;
    cursor: pointer;
    width: 45px;
    height: 45px;
    border-radius: 12px;
    z-index: 100;
    padding: 0;
    margin: 0;
    align-items: center;
    justify-content: center;
  }

  .hamburger-box {
    position: relative;
    width: 24px;
    height: 14px;
    display: block;
  }

  .hamburger .line {
    position: absolute;
    left: 0;
    width: 24px;
    height: 2px;
    background-color: var(--text);
    border-radius: 4px;
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
  }

  .line:nth-child(1) {
    top: 0;
  }
  .line:nth-child(2) {
    top: 6px;
  }
  .line:nth-child(3) {
    top: 12px;
  }

  .hamburger.active .line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .hamburger.active .line:nth-child(2) {
    opacity: 0;
    transform: translateX(10px);
  }
  .hamburger.active .line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* --- Mobile Menu --- */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh; /* Otimização: Respeita a interface dinâmica dos navegadores mobile */
    background: rgba(var(--mainnav-bg-rgb), 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    clip-path: circle(0% at 90% 5%);
    transition: clip-path 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: 100;
    visibility: hidden; /* A11y: Esconde do foco quando fechado */
  }
  .mobile-menu.open {
    clip-path: circle(150% at 90% 5%);
    visibility: visible;
  }

  .mobile-link {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .mobile-link:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .desktop-only,
    .separator {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  // Window Interface Extension for TypeScript Strict Mode
  declare global {
    interface Window {
      navScrollInitialized?: boolean;
      navA11yInitialized?: boolean;
    }
  }

  // Variáveis de estado para persistir durante a SPA (ClientRouter)
  let isHomeRoute = false;
  let cachedLinks: NodeListOf<Element> | null = null;
  let sectionObserver: IntersectionObserver | null = null;

  // Lógica visual do Header simplificada e ultra-leve
  const handleNavScroll = () => {
    const nav = document.getElementById("main-nav");
    if (!nav) return;
    if (window.scrollY > 50) nav.classList.add("scrolled");
    else nav.classList.remove("scrolled");
  };

  // Inicialização de Eventos Globais Únicos (Prevenção de Mem Leak)
  if (!window.navScrollInitialized) {
    window.addEventListener("scroll", handleNavScroll, { passive: true });
    window.navScrollInitialized = true;
  }

  if (!window.navA11yInitialized) {
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        const mobileMenu = document.getElementById("mobile-menu");
        const hamburger = document.querySelector(".hamburger") as HTMLButtonElement | null;
        
        if (mobileMenu?.classList.contains("open") && hamburger) {
          hamburger.click(); // Dispara o toggle de forma segura acionando o botão
        }
      }
    });
    window.navA11yInitialized = true;
  }

  // Previne memory leak limpando o Observer antes do swap de ViewTransitions
  document.addEventListener("astro:before-swap", () => {
    if (sectionObserver) {
      sectionObserver.disconnect();
      sectionObserver = null;
    }
  });

  document.addEventListener("astro:page-load", () => {
    // 1. Deteção Híbrida de Rota
    const pathname = window.location.pathname;
    const normalizedPath = pathname.replace(/\/$/, "");
    isHomeRoute = normalizedPath === "" || normalizedPath === "/" || normalizedPath === "/pt";

    cachedLinks = document.querySelectorAll(".nav-link, .mobile-link");

    // 2. Comportamento Multi-Page: Ativação estática baseada na URL
    if (!isHomeRoute && cachedLinks) {
      let activeSection = "";
      if (pathname.includes("/about") || pathname.includes("/sobre")) {
        activeSection = "about";
      } else if (pathname.includes("/works") || pathname.includes("/trabalhos") || pathname.includes("/work")) {
        activeSection = "works";
      }

      cachedLinks.forEach((link) => {
        link.classList.toggle("active", link.getAttribute("data-section") === activeSection);
      });
    }

    // Força checagem visual inicial
    handleNavScroll();

    // 3. Otimização Perfeccionista: ScrollSpy com IntersectionObserver (Performance nível A)
    if (isHomeRoute && cachedLinks) {
      const sections = ["home", "about", "works"]
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);

      if (sections.length > 0) {
        const observerOptions = {
          root: null,
          rootMargin: "-40% 0px -60% 0px", // Engatilha quando a seção cruza o meio da tela
          threshold: 0
        };

        sectionObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const currentId = entry.target.id;
              cachedLinks?.forEach((link) => {
                link.classList.toggle(
                  "active",
                  link.getAttribute("data-section") === currentId
                );
              });
            }
          });
        }, observerOptions);

        sections.forEach((section) => sectionObserver!.observe(section));
      }
    }

    // 4. Lógica do Menu Mobile e Acessibilidade (A11y Focus Management)
    const hamburger = document.querySelector(".hamburger") as HTMLButtonElement | null;
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    const toggleMenu = () => {
      const isOpen = mobileMenu?.classList.toggle("open");
      hamburger?.classList.toggle("active");
      hamburger?.setAttribute("aria-expanded", isOpen ? "true" : "false");
      document.body.style.overflow = isOpen ? "hidden" : "";
      
      // Acessibilidade: Gerencia o foco do teclado
      if (isOpen) {
        const firstLink = mobileLinks[0] as HTMLElement | undefined;
        if (firstLink) setTimeout(() => firstLink.focus(), 100); 
      } else {
        hamburger?.focus();
      }
    };

    hamburger?.addEventListener("click", toggleMenu);
    
    mobileLinks.forEach((link) =>
      link.addEventListener("click", () => {
        if (mobileMenu?.classList.contains("open")) toggleMenu();
      }),
    );
  });
</script>