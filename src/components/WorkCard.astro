---
interface Props {
  title: string;
  description: string;
  tags: string[]; // Aqui dizemos que tags é uma lista de textos
  link: string;
}

const { title, description, tags, link } = Astro.props;
---
<div class="work-card">
    <div class="work-card-content">
        <h3>{title}</h3>
        <p>{description}</p>
        <div class="tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <a href={link} target="_blank">View Project →</a>
    </div>
</div>

<style>
    .work-card {
        background: var(--card-bg); /* Mudança para variável */
        backdrop-filter: blur(12px);
        padding: 2rem;
        border-radius: 15px;
        border: 1px solid var(--card-border); /* Mudança para variável */
        transition: all 0.3s ease;
        position: relative;
    }
    .work-card:hover {
        transform: translateY(-10px);
        border-color: var(--accent);
    }

.work-card:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: var(--accent);
    box-shadow: 0 20px 40px rgba(0, 255, 157, 0.1);
}

/* Efeito de brilho que segue o mouse (Opcional/Avançado) */
.work-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    opacity: 0;
    transition: opacity 0.3s;
}

.work-card::before { opacity: 1; }
    .tag {
        font-size: 0.7rem;
        background: var(--text);
        color: var(--bg);
        padding: 5px 10px;
        border-radius: 5px;
        margin-right: 5px;
        color: var(--accent);
    }
    h3 { margin-top: 0; }
    a { color: var(--text); text-decoration: none; font-weight: bold; font-size: 0.9rem; margin-top: 20px; display: inline-block; }
    a:hover {
        color: var(--accent);
    }
</style>
