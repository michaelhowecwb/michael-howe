---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link: string;
}

const { title, description, tags, link } = Astro.props;
---

<div class="work-card">
    <div class="work-card-content">
        <h3>{title}</h3>
        <p>{description}</p>
        <div class="tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <a href={link} target="_blank">View Project →</a>
    </div>
</div>

<style>
    .work-card {
        background: var(--card-bg);
        backdrop-filter: blur(12px);
        padding: 2rem;
        border-radius: 15px;
        border: 1px solid var(--card-border);
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%; /* Garante que todos os cards tenham a mesma altura no grid */
    }

    .work-card:hover {
        transform: translateY(-10px) scale(1.01);
        border-color: var(--accent);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 15px 0;
    }

    .tag {
        font-size: 0.7rem;
        font-weight: 600;
        /* Uso do var(--text-rgb) corrigido para garantir compatibilidade */
        background: rgba(var(--text-rgb), 0.1);
        color: var(--accent);
        padding: 4px 12px;
        border-radius: 6px;
        border: 1px solid rgba(var(--text-rgb), 0.1);
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .work-card:hover .tag {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
    }

    h3 { 
        margin: 0 0 10px 0; 
        color: var(--text);
        font-size: 1.4rem;
    }

    p {
        color: var(--secondary);
        font-size: 0.95rem;
        line-height: 1.5;
        flex-grow: 1; /* Faz o texto ocupar o espaço para alinhar o link abaixo */
    }

    a { 
        color: var(--text); 
        text-decoration: none; 
        font-weight: bold; 
        font-size: 0.9rem; 
        margin-top: 20px; 
        display: inline-block;
        transition: color 0.3s ease;
    }

    a:hover {
        color: var(--accent);
    }

    /* CORREÇÃO IMPORTANTE: No Astro, seletores de tema global dentro de 
       estilos escopados devem usar :global() para serem detectados corretamente no build do Vercel.
    */
    :global([data-theme='dark']) .work-card {
        background: linear-gradient(145deg, var(--card-bg), #121212);
    }
</style>