---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link: string;
}
import { ui } from '@utils/i18n';
const { pathname } = Astro.url;
const isPt = pathname.includes('/pt');
const t = isPt ? ui.pt : ui.en;
const { title, description, tags, link } = Astro.props;
---

<div class="work-card">
    <div class="work-card-content">
        <h3>{title}</h3>
        <p>{description}</p>
        <div class="tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <a href={link} target="_blank" rel="noopener noreferrer" aria-label={`View project ${title}`}>
          View Project →
        </a>
    </div>
</div>

<style>
    .work-card {
        background: var(--card-bg);
        backdrop-filter: blur(12px);
        padding: 2.2rem; /* Aumentado levemente para melhor respiro */
        border-radius: 15px;
        /* Borda agora segue o tema corretamente */
        border: 1px solid var(--card-border);
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%; /* Garante que todos os cards na grid tenham o mesmo tamanho */
    }

    .work-card:hover {
        transform: translateY(-8px);
        border-color: var(--accent);
        box-shadow: 0 15px 35px var(--dropshadow-rgb);
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 20px 0;
    }

    .tag {
        font-size: 0.7rem;
        font-weight: 700;
        /* Usamos a variável de texto do tema para o fundo suave */
        background: rgba(var(--text-rgb), 0.08);
        color: var(--accent);
        padding: 5px 12px;
        border-radius: 6px;
        border: 1px solid rgba(var(--text-rgb), 0.05);
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    /* Feedback visual nas tags ao passar o mouse no CARD */
    .work-card:hover .tag {
        background: var(--accent);
        color: var(--links-text); /* Branco no Light / Preto no Dark */
        border-color: var(--accent);
    }

    h3 {
        margin: 0 0 12px 0;
        color: var(--text);
        font-size: 1.4rem;
        letter-spacing: -0.5px;
    }

    p {
        color: var(--secondary);
        font-size: 0.95rem;
        line-height: 1.6;
        flex-grow: 1; /* Empurra o link para o rodapé do card se o texto for curto */
    }

    a {
        color: var(--text);
        text-decoration: none;
        font-weight: 800;
        font-size: 0.85rem;
        margin-top: 25px;
        display: inline-flex;
        align-items: center;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    a:hover {
        color: var(--accent);
        transform: translateX(5px); /* Pequeno slide na seta */
    }

    /* Profundidade Extra no Dark Mode */
    :global([data-theme='dark']) .work-card {
        background: linear-gradient(160deg, var(--card-bg) 0%, rgba(10, 10, 10, 0.8) 100%);
    }
</style>