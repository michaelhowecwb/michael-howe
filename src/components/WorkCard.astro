---
import { Image } from "astro:assets";

interface Props {
    title: string;
    description: string;
    tags: string[];
    thumbnail?: string;
    thumbnailAlt?: string;
    link: string;
}

const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");
const { title, description, tags, thumbnail, thumbnailAlt, link } = Astro.props;

// Função de truncamento inteligente: Corta no espaço mais próximo para não quebrar palavras.
const truncateText = (text: string, maxLength: number = 280) => {
    if (!text) return "";
    if (text.length <= maxLength) return text;
    const truncated = text.substring(0, maxLength);
    return truncated.substring(0, Math.min(truncated.length, truncated.lastIndexOf(" "))) + "...";
};

const displayDescription = truncateText(description);
---

<div class="work-card spotlight-card">
    <div class="work-card-inner">
        <h3 class="project-title">{title}</h3>

        <div class="work-card-body">
            {
                thumbnail && (
                    <div class="work-card-image">
                        <Image
                            src={thumbnail}
                            alt={
                                thumbnailAlt || 
                                (isPt
                                    ? `Miniatura do projeto ${title}`
                                    : `Project thumbnail ${title}`)
                            }
                            width={400}
                            height={225}
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                )
            }
            <p class="description">{displayDescription}</p>
        </div>

        <div class="tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>

        <div class="work-card-footer">
            <a
                href={link}
                class="view-project"
                aria-label={isPt
                    ? `Ver projeto ${title}`
                    : `View project ${title}`}
            >
                <span class="view-project-text">
                    {isPt ? "Ver Projeto" : "View Project"}
                </span>
                <span class="view-project-icon" aria-hidden="true">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                        focusable="false"
                    >
                        <path
                            d="M5 12H19M19 12L12 5M19 12L12 19"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </span>
                <div class="view-project-bg" aria-hidden="true"></div>
            </a>
        </div>
    </div>
</div>

<style>
    .work-card {
        background: rgba(var(--card-bg-rgb), 0.4);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        padding: 2.2rem;
        border-radius: 24px;
        border: 1px solid var(--card-border);
        transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
        position: relative;
        overflow: hidden;
        /* Flexbox principal: absorve o stretch do grid pai, mas não quebra o conteúdo (min-content) */
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: min-content; 
    }

    /* --- Spotlight --- */
    .work-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
            600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
            rgba(var(--accent-rgb), 0.08),
            transparent 40%
        );
        z-index: 1;
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
    }

    @media (hover: hover) {
        .work-card:hover::before {
            opacity: 1;
        }
    }

    .work-card-inner {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .project-title {
        margin: 0 0 20px 0;
        color: var(--text);
        font-size: 1.6rem;
        font-weight: 900;
        letter-spacing: -1px;
        display: block;
    }

    /* --- Corpo Fluido (Garante que a imagem nunca vase por cima de outros elementos) --- */
    .work-card-body {
        display: flow-root;
        margin-bottom: 20px;
    }

    /* --- Imagem Responsiva --- */
    .work-card-image {
        float: right;
        width: 40%;
        max-width: 160px;
        min-width: 110px;
        margin-left: 18px;
        margin-bottom: 8px;
        aspect-ratio: 1 / 1;
        border-radius: 14px;
        overflow: hidden;
    }

    .work-card-image img {
        width: 100%;
        height: 100%;
        display: block;
        transition: transform 0.6s ease;
        object-fit: cover;
    }

    .description {
        color: var(--secondary);
        font-size: 1rem;
        line-height: 1.7;
        text-align: left; /* Garante tipografia fluida sem rios de espaço branco */
        margin: 0;
    }

    /* --- Tags --- */
    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 25px;
    }

    .tag {
        font-size: 0.65rem;
        font-weight: 800;
        background: rgba(var(--text-rgb), 0.05);
        color: var(--accent);
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid var(--card-border);
        text-transform: uppercase;
    }
    
    .work-card:hover .tag {
        color: var(--dark-text);
        background-color: var(--accent);
        transition: ease 0.6s;
    }

    /* --- Rodapé --- */
    .work-card-footer {
        display: flex;
        flex-direction: column;
        margin-top: auto; /* Esta é a mágica que absorve o espaço vazio abaixo das tags */
    }

    /* --- View Project Button --- */
    .view-project {
        position: relative;
        padding: 12px 24px;
        color: var(--text);
        text-decoration: none;
        font-weight: 800;
        font-size: 0.8rem;
        border: 1px solid rgba(var(--accent-rgb), 0.3);
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        width: fit-content;
    }

    .view-project-text,
    .view-project-icon {
        position: relative;
        z-index: 2;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
    }

    .view-project-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: var(--accent);
        transform: translateY(100%);
        transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        z-index: 1;
    }

    .view-project:hover {
        border-color: var(--accent);
        transform: scale(1.02);
    }
    
    .view-project:hover .view-project-text,
    .view-project:hover .view-project-icon {
        color: #000;
    }
    
    .view-project:hover .view-project-bg {
        transform: translateY(0);
    }
    
    .view-project:hover .view-project-icon {
        transform: translateX(5px);
    }

    .work-card:hover {
        transform: translateY(-10px);
        border-color: var(--accent);
        box-shadow: 0 20px 40px var(--dropshadow-rgb);
    }
    
    .work-card:hover .work-card-image img {
        transform: scale(1.05);
    }

    /* --- Mobile Override --- */
    @media (max-width: 767px) {
        .work-card {
            padding: 1.8rem;
        }

        .work-card-image {
            float: none;
            width: 100%;
            max-width: none;
            margin-left: 0;
            margin-bottom: 20px;
            aspect-ratio: auto;
        }

        .work-card-image img {
            aspect-ratio: 16 / 9;
        }
    }

    :global([data-theme="dark"]) .work-card {
        background: linear-gradient(
            165deg,
            rgba(20, 20, 20, 0.7) 0%,
            rgba(5, 5, 5, 0.9) 100%
        );
    }
</style>

<script>
    // Gerenciador encapsulado para o efeito de Spotlight
    function initSpotlightCards() {
        const cards = document.querySelectorAll<HTMLElement>('.spotlight-card');
        
        cards.forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                card.style.setProperty('--mouse-x', `${x}px`);
                card.style.setProperty('--mouse-y', `${y}px`);
            });
        });
    }

    // Inicialização segura compatível com Astro View Transitions
    document.addEventListener('astro:page-load', initSpotlightCards);
    
    // Fallback de inicialização padrão
    if (document.readyState === 'interactive' || document.readyState === 'complete') {
        initSpotlightCards();
    } else {
        document.addEventListener('DOMContentLoaded', initSpotlightCards);
    }
</script>