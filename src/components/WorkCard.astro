---
interface Props {
  title: string;
  description: string;
  tags: string[];
  thumbnail?: string;
  link: string;
}

const { pathname } = Astro.url;
const isPt = pathname.includes('/pt');
const { title, description, tags, thumbnail, link } = Astro.props;
---

<div class="work-card spotlight-card">
    <div class="work-card-inner">
        <div class="work-card-content">
            <h3>{title}</h3>

            {thumbnail && (
                <div class="work-card-image">
                    <img src={thumbnail} alt={`Thumbnail do projeto ${title}`} loading="lazy" />
                </div>
            )}

            <p class="description">{description}</p>
            
            <div class="tags">
                {tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
            
            <a href={link} class="view-project" aria-label={`View project ${title}`}>
                {isPt ? "Ver Projeto →" : "View Project →"}
            </a>
        </div>
        <div style="clear: both;"></div>
    </div>
</div>

<style>
    .work-card {
        background: rgba(var(--card-bg-rgb), 0.4);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        padding: 2.2rem;
        border-radius: 20px;
        border: 1px solid var(--card-border);
        transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
        position: relative;
        /* CORREÇÃO 1: hidden para o brilho respeitar o border-radius */
        overflow: hidden; 
        display: block;
        height: 100%;
    }

    /* --- CAMADA DO SPOTLIGHT (CORRIGIDA) --- */
    .work-card::before {
        content: "";
        position: absolute;
        inset: 0;
        /* CORREÇÃO 2: radial-gradient acima do background do card */
        background: radial-gradient(
            600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), 
            rgba(var(--accent-rgb), 0.15), 
            transparent 40%
        );
        z-index: 1; /* Acima do background do .work-card */
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
    }

    .work-card:hover::before {
        opacity: 1;
    }

    /* CORREÇÃO 3: O conteúdo deve estar acima do Spotlight */
    .work-card-inner {
        position: relative;
        z-index: 2; /* Acima do ::before */
        display: block;
    }

    /* --- IMAGEM --- */
    .work-card-image {
        width: 100%;
        margin-bottom: 20px;
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
        border: 1px solid rgba(var(--text-rgb), 0.05);
    }

    .work-card-image img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 0.6s ease;
    }

    /* --- TEXTO --- */
    h3 { 
        margin: 0 0 15px 0;
        color: var(--text); 
        font-size: 1.6rem; 
        font-weight: 900; 
        letter-spacing: -1px; 
    }
    
    .description { 
        color: var(--secondary); 
        font-size: 1rem; 
        line-height: 1.7; 
        text-align: justify;
        margin: 0;
    }

    .tags { display: flex; flex-wrap: wrap; gap: 8px; margin: 20px 0; }
    .tag {
        font-size: 0.65rem; font-weight: 800; background: rgba(var(--text-rgb), 0.05);
        color: var(--accent); padding: 6px 14px; border-radius: 8px; border: 1px solid var(--card-border);
        text-transform: uppercase;
    }

    .view-project {
        color: var(--accent); text-decoration: none; font-weight: 800; font-size: 0.8rem;
        margin-top: 15px; display: inline-flex; text-transform: uppercase; letter-spacing: 1.5px;
        transition: all 0.3s ease;
    }

    /* --- HOVERS ADICIONAIS --- */
    .work-card:hover { 
        transform: translateY(-12px); 
        border-color: var(--accent); 
        box-shadow: 0 20px 40px var(--dropshadow-rgb); 
    }
    .work-card:hover .work-card-image img { transform: scale(1.08); }

    /* --- RESPONSIVIDADE --- */
    @media (min-width: 768px) {
        .work-card-image {
            float: right;
            width: 180px;
            height: 180px;
            margin-left: 30px;
            margin-bottom: 15px;
            margin-top: 0; 
        }
    }

    :global([data-theme='dark']) .work-card {
        background: linear-gradient(165deg, rgba(20, 20, 20, 0.7) 0%, rgba(5, 5, 5, 0.9) 100%);
    }
</style>