---
interface Props {
    title: string;
    description: string;
    tags: string[];
    thumbnail?: string;
    link: string;
}

const { pathname } = Astro.url;
const isPt = pathname.includes("/pt");
const { title, description, tags, thumbnail, link } = Astro.props;
---

<div class="work-card spotlight-card">
    <div class="work-card-inner">
        <h3 class="project-title">{title}</h3>

        {
            thumbnail && (
                <div class="work-card-image">
                    <img
                        src={thumbnail}
                        alt={
                            isPt
                                ? `Miniatura do projeto ${title}`
                                : `Project thumbnail ${title}`
                        }
                        loading="lazy"
                        decoding="async"
                        width="400"
                        height="225"
                    />
                </div>
            )
        }

        <div class="work-card-content">
            <p class="description">{description}</p>

            <div class="tags">
                {tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>

            <a
                href={link}
                class="view-project"
                aria-label={isPt
                    ? `Ver projeto ${title}`
                    : `View project ${title}`}
            >
                <span class="view-project-text"
                    >{isPt ? "Ver Projeto" : "View Project"}</span
                >
                <span class="view-project-icon">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M5 12H19M19 12L12 5M19 12L12 19"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </span>
                <div class="view-project-bg"></div>
            </a>
        </div>
    </div>
</div>

<style>
    .text-accent {
        color: var(--accent);
    }
    .text-gradient {
        background: linear-gradient(to right, var(--accent), #fff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: bold;
    }
    .text-underline {
        border-bottom: 2px solid var(--accent);
    }
    .custom-underline {
        position: relative;
        display: inline-block;
    }
    .custom-underline::after {
        content: "";
        position: absolute;
        left: 20%;
        right: 0;
        bottom: -2px;
        height: 4px;
        background-color: var(--accent);
        border-radius: 2px;
        z-index: -1;
        transition: width 0.3s ease;
    }
    
    .work-card {
        background: rgba(var(--card-bg-rgb), 0.4);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        padding: 2.2rem;
        border-radius: 24px;
        border: 1px solid var(--card-border);
        transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
        position: relative;
        overflow: hidden;
        display: block;
        height: 100%;
    }

    /* --- Spotlight --- */
    .work-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
            600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
            rgba(var(--accent-rgb), 0.08),
            transparent 40%
        );
        z-index: 1;
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
    }

    @media (hover: hover) {
        .work-card:hover::before {
            opacity: 1;
        }
    }

    .work-card-inner {
        position: relative;
        z-index: 2;
        display: block;
    }

    /* --- Clearfix to hold the float image --- */
    .work-card-inner::after {
        content: "";
        display: table;
        clear: both;
    }

    .project-title {
        margin: 0 0 20px 0;
        color: var(--text);
        font-size: 1.6rem;
        font-weight: 900;
        letter-spacing: -1px;
        display: block;
        clear: both;
    }

    /* --- Image --- */
    .work-card-image {
        width: 200px;
        float: right;
        margin-left: 30px;
        margin-bottom: 15px;
        aspect-ratio: 1 / 1;
        border-radius: 14px;
        overflow: hidden;
    }

    .work-card-image img {
        width: 100%;
        height: 100%;
        display: block;
        transition: transform 0.6s ease;
        object-fit: cover;
    }
    /* --- Card Content --- */
    .work-card-content {
        display: block;
    }

    .description {
        color: var(--secondary);
        font-size: 1rem;
        line-height: 1.7;
        text-align: justify;
        margin: 0 0 20px 0;
    }

    /* --- Tags --- */
    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 25px;
    }

    .tag {
        font-size: 0.65rem;
        font-weight: 800;
        background: rgba(var(--text-rgb), 0.05);
        color: var(--accent);
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid var(--card-border);
        text-transform: uppercase;
    }
    .work-card:hover .tag{color: var(--dark-text); background-color: var(--accent); transition: ease 0.6s;}

    /* --- View Project Button --- */
    .view-project {
        position: relative;
        padding: 12px 24px;
        color: var(--text);
        text-decoration: none;
        font-weight: 800;
        font-size: 0.8rem;
        border: 1px solid rgba(var(--accent-rgb), 0.3);
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        width: fit-content;
    }

    .view-project-text,
    .view-project-icon {
        position: relative;
        z-index: 2;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
    }

    .view-project-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: var(--accent);
        transform: translateY(100%);
        transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        z-index: 1;
    }

    .view-project:hover {
        border-color: var(--accent);
        transform: scale(1.02);
    }
    .view-project:hover .view-project-text,
    .view-project:hover .view-project-icon {
        color: #000;
    }
    .view-project:hover .view-project-bg {
        transform: translateY(0);
    }
    .view-project:hover .view-project-icon {
        transform: translateX(5px);
    }

    .work-card:hover {
        transform: translateY(-10px);
        border-color: var(--accent);
        box-shadow: 0 20px 40px var(--dropshadow-rgb);
    }
    .work-card:hover .work-card-image img {
        transform: scale(1.05);
    }

    /* --- Mobile Override --- */
    @media (max-width: 767px) {
        .work-card {
            height: auto !important;
            display: flex;
            flex-direction: column;
            padding: 1.8rem;
        }

        .work-card-inner {
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .work-card-inner::after {
            display: none;
        }

        .work-card-image {
            float: none;
            width: 100%;
            margin-left: 0;
            aspect-ratio: auto;
        }

        .work-card-image img {
            aspect-ratio: 16 / 9;
        }

        .work-card-content {
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .view-project {
            margin-top: auto;
            align-self: flex-start;
        }
    }

    :global([data-theme="dark"]) .work-card {
        background: linear-gradient(
            165deg,
            rgba(20, 20, 20, 0.7) 0%,
            rgba(5, 5, 5, 0.9) 100%
        );
    }
</style>
