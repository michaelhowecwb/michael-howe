---
// LanguagePicker.astro
const { pathname } = Astro.url;

// 1. Detecta se o usuário já está na versão em português
const isPt = pathname.startsWith('/pt');

// 2. Lógica de tradução de URL (Corrigida)
// Remove a barra final se existir para evitar links como //pt/
const cleanPath = pathname.endsWith('/') ? pathname.slice(0, -1) : pathname;

// Se estou em /work/projeto-x -> vira /pt/work/projeto-x
// Se estou em /pt/work/projeto-x -> vira /work/projeto-x
const ptLink = isPt ? cleanPath : `/pt${cleanPath || ''}`;
const enLink = isPt ? cleanPath.replace(/^\/pt/, '') || '/' : cleanPath;

// Garante que se o link ficar vazio (na home), ele seja pelo menos '/'
const finalEnLink = enLink === '' ? '/' : enLink;
const finalPtLink = ptLink === '' ? '/pt' : ptLink;
---

<div
  class="language-picker"
  aria-label={isPt ? "Selecionar idioma" : "Select language"}
>
  <a
    href={finalEnLink}
    class={`lang-link ${!isPt ? "active" : ""}`}
    aria-current={!isPt ? "page" : undefined}
    data-lang="en"
  >
    EN
  </a>

  <span class="separator" aria-hidden="true">|</span>

  <a
    href={finalPtLink}
    class={`lang-link ${isPt ? "active" : ""}`}
    aria-current={isPt ? "page" : undefined}
    data-lang="pt"
  >
    PT
  </a>
</div>

<style>
  .language-picker {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Inter", sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .language-picker a {
    text-decoration: none;
    color: var(--text);
    opacity: 0.4;
    transition: all 0.3s ease;
  }

  .language-picker a:hover {
    opacity: 1;
    color: var(--accent);
  }

  .language-picker a.active {
    opacity: 1;
    color: var(--accent);
    cursor: default;
    pointer-events: none;
  }

  .separator {
    opacity: 0.2;
    font-weight: 300;
    color: var(--text);
  }
</style>

<script>
  function setupLanguagePicker() {
    const langLinks = document.querySelectorAll(".lang-link");
    langLinks.forEach((link) => {
      link.addEventListener("click", () => {
        const selectedLang = link.getAttribute("data-lang");
        if (selectedLang) {
          sessionStorage.setItem("language_preference", `manual-${selectedLang}`);
        }
      });
    });
  }

  setupLanguagePicker();
  document.addEventListener("astro:after-swap", setupLanguagePicker);
</script>
