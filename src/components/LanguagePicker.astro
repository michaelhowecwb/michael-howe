---
import { ui } from "@utils/i18n";
const { pathname, hash } = Astro.url;

const isPt = pathname.includes("/pt");

const enLink = isPt ? `/${hash}` : `#home`;
const ptLink = isPt ? `#home` : `/pt/${hash}`;
---

<div
  class="language-picker"
  aria-label={isPt ? "Selecionar idioma" : "Select language"}
>
  <a
    href={enLink}
    class={`lang-link ${!isPt ? "active" : ""}`}
    aria-current={!isPt ? "page" : undefined}
    data-lang="en"
  >
    EN
  </a>

  <span class="separator" aria-hidden="true">|</span>

  <a
    href={ptLink}
    class={`lang-link ${isPt ? "active" : ""}`}
    aria-current={isPt ? "page" : undefined}
    data-lang="pt"
  >
    PT
  </a>
</div>

<style>
  .language-picker {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Inter", sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
  }

  .language-picker a {
    text-decoration: none;
    color: var(--text);
    opacity: 0.4;
    transition: all 0.3s ease;
  }

  .language-picker a:hover {
    opacity: 1;
    color: var(--accent);
  }

  .language-picker a.active {
    opacity: 1;
    color: var(--accent);
    cursor: default;
    pointer-events: none; /* Impede o clique no idioma que já está ativo */
  }

  .separator {
    opacity: 0.2;
    font-weight: 300;
  }
</style>

<script>
  // Script para salvar a escolha manual do usuário antes de trocar de página
  function setupLanguagePicker() {
    const langLinks = document.querySelectorAll(".lang-link");

    langLinks.forEach((link) => {
      link.addEventListener("click", () => {
        const selectedLang = link.getAttribute("data-lang");
        // Salva a escolha no sessionStorage (isso quebra a regra do auto-redirecionamento no Layout)
        sessionStorage.setItem("language_preference", `manual-${selectedLang}`);
      });
    });
  }

  // Executa na primeira carga
  setupLanguagePicker();

  // Executa caso o Astro View Transitions esteja ativado
  document.addEventListener("astro:after-swap", setupLanguagePicker);
</script>
