---
const { pathname } = Astro.url;

const isPt = pathname.startsWith("/pt");
const cleanPath =
  pathname.length > 1 && pathname.endsWith("/")
    ? pathname.slice(0, -1)
    : pathname;

const enLink = isPt ? cleanPath.replace(/^\/pt/, "") || "/" : cleanPath;
const ptLink = isPt ? cleanPath : `/pt${cleanPath === "/" ? "" : cleanPath}`;

const finalEnLink = enLink || "/";
const finalPtLink = ptLink || "/pt";
---

<div class="lang-wrapper">
  <nav
    class="language-picker"
    aria-label={isPt ? "Selecionar idioma" : "Select language"}
  >
    <div class={`lang-indicator ${isPt ? "is-pt" : "is-en"}`}></div>

    <a
      href={finalEnLink}
      class={`lang-link ${!isPt ? "active" : ""}`}
      data-lang="en"
      hreflang="en"
      lang="en"
    >
      EN
    </a>

    <a
      href={finalPtLink}
      class={`lang-link ${isPt ? "active" : ""}`}
      data-lang="pt"
      hreflang="pt-br"
      lang="pt"
    >
      PT
    </a>
  </nav>
</div>

<style>
  .lang-wrapper {
    display: flex;
    align-items: center;
  }

  .language-picker {
    position: relative;
    display: flex;
    background: rgba(var(--text-rgb), 0.05);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(var(--text-rgb), 0.1);
    border-radius: 50px;
    padding: 4px;
    gap: 4px;
    transition: all 0.3s ease;
  }

  .language-picker:hover {
    border-color: var(--accent);
    box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.1);
  }

  .lang-link {
    position: relative;
    z-index: 2;
    text-decoration: none;
    color: var(--text);
    font-size: 0.75rem;
    font-weight: 800;
    padding: 6px 14px;
    border-radius: 50px;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    opacity: 0.6;
    letter-spacing: 1px;
  }

  .lang-link:hover {
    opacity: 1;
    color: var(--accent);
  }

  .lang-link.active {
    opacity: 1;
    cursor: default;
    pointer-events: none;
    color: var(--bg);
  }

  .lang-indicator {
    position: absolute;
    top: 4px;
    bottom: 4px;
    width: calc(50% - 6px);
    background: var(--accent);
    border-radius: 50px;
    z-index: 1;
    transition: transform 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    box-shadow: 0 2px 8px rgba(var(--accent-rgb), 0.4);
  }

  .lang-indicator.is-en {
    transform: translateX(0);
  }
  .lang-indicator.is-pt {
    transform: translateX(calc(100% + 4px));
  }

  @media (max-width: 768px) {
    .lang-link {
      padding: 5px 12px;
      font-size: 0.7rem;
    }
  }
</style>

<script>
  // Integrated into the official Astro SPA lifecycle
  document.addEventListener("astro:page-load", () => {
    const langLinks = document.querySelectorAll(".lang-link");
    langLinks.forEach((link) => {
      link.addEventListener("click", () => {
        const selectedLang = link.getAttribute("data-lang");
        if (selectedLang) {
          sessionStorage.setItem(
            "language_preference",
            `manual-${selectedLang}`,
          );
        }
      });
    });
  });
</script>
