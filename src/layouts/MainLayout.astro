---
import MainNavbar from "@components/MainNavbar.astro";
import Footer from "@components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    lang?: string;
}

const { lang = "en" } = Astro.props;

// Dynamic SEO Defaults
const defaultTitle = lang.startsWith("pt")
    ? "Michael Howe | Desenvolvedor Full-stack"
    : "Michael Howe | Full-stack Developer";

const defaultDesc = lang.startsWith("pt")
    ? "Desenvolvedor Full-stack focado em interfaces premium, performance e arquitetura moderna."
    : "Full-stack Developer focused on premium interfaces, performance, and modern architecture.";

const {
    title = defaultTitle,
    description = defaultDesc,
    image = "/og-image.png",
} = Astro.props;

// Ensures an absolute URL for SEO/Social Media.
const siteUrl = Astro.site || new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(image, siteUrl);
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />

        <link rel="icon" type="image/png" href="/icons/favicon512.png?v=2" />
        <link rel="apple-touch-icon" href="/icons/favicon512.png?v=2" />
        <link rel="shortcut icon" href="/icons/favicon512.png?v=2" />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <meta name="robots" content="index, follow" />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={ogImageURL} />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Fira+Code&display=swap"
            rel="stylesheet"
        />

        <ClientRouter />
        <script is:inline>
            // Theme Engine (Executes before rendering to avoid FOUC.)
            const theme = (() => {
                if (
                    typeof localStorage !== "undefined" &&
                    localStorage.getItem("theme")
                ) {
                    return localStorage.getItem("theme");
                }
                return "dark";
            })();
            document.documentElement.setAttribute("data-theme", theme);

            // Language Redirection
            if (
                window.location.pathname === "/" ||
                window.location.pathname === ""
            ) {
                const userLang = (
                    window.navigator.language || window.navigator.userLanguage
                ).toLowerCase();
                const manualSelection = sessionStorage.getItem(
                    "language_preference",
                );

                if (userLang.startsWith("pt") && !manualSelection) {
                    sessionStorage.setItem("language_preference", "auto-pt");
                    window.location.href = "/pt/";
                }
            }
        </script>

        <style is:global>
            /* --- Theme Variables --- */
            :root {
                --bg: #0b0b0b;
                --bg-rgb: 11, 11, 11;
                --mainnav-bg: #14171b;
                --mainnav-bg-rgb: 20, 23, 27;
                --card-bg: #141414;
                --text: #ffffff;
                --dark-text: #111111;
                --text-rgb: 255, 255, 255;
                --accent: #00ff9d;
                --accent-rgb: 0, 255, 157;
                --secondary: #a0a0a0;
                --card-border: rgba(255, 255, 255, 0.05);
                --section-alt: #171717;
                --section-alt-rgba: rgba(23, 23, 23, 0.8);
                --footer-bg: #14171b;
                --btt-bg: #111111;
                --btt-icon: #00ff9d;
                --btt-border: #00ff9d;
                --links: #00ff9d;
                --links-text: #111111;
                --dropshadow-rgb: rgba(0, 255, 157, 0.2);
            }

            [data-theme="light"] {
                --bg: #e3e7ec;
                --bg-rgb: 227, 231, 236;
                --mainnav-bg: #d7dbe0;
                --mainnav-bg-rgb: 215, 219, 224;
                --card-bg: #ffffff;
                --text: #1e293b;
                --light-text: #ffffff;
                --text-rgb: 0, 0, 0;
                --accent: #6366f1;
                --accent-rgb: 99, 102, 241;
                --secondary: #64748b;
                --card-border: rgba(0, 0, 0, 0.06);
                --section-alt: #f1f5f9;
                --section-alt-rgba: rgba(241, 245, 249, 0.8);
                --footer-bg: #e2e8f0;
                --btt-bg: #eeeff1;
                --btt-icon: #111111;
                --btt-border: #111111;
                --links: #111111;
                --links-text: #ffffff;
                --dropshadow-rgb: rgba(120, 131, 255, 0.2);
            }

            /* --- Structure --- */
            html {
                scroll-behavior: auto !important;
            }
            body {
                background-color: var(--bg);
                color: var(--text);
                font-family: "Inter", sans-serif;
                margin: 0;
                overflow-x: hidden;
                overflow-y: auto;
                min-height: 100vh;
            }

            code {
                font-family: "Fira Code", monospace;
            }

            .nav-link {
                transition: color 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                color: var(--secondary);
                text-decoration: none;
            }

            .nav-link.active {
                color: var(--accent) !important;
                font-weight: bold;
            }

            main {
                padding-top: 20px;
                position: relative;
                z-index: 1;
            }
            section {
                scroll-margin-top: 80px;
            }

            /* --- Back to Top --- */
            .back-to-top {
                position: fixed;
                bottom: 30px;
                right: 30px;
                background: var(--btt-bg);
                color: var(--btt-icon);
                width: 45px;
                height: 45px;
                border-radius: 50%;
                border: 2px solid var(--btt-border);
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.3s ease;
                opacity: 0;
                visibility: hidden;
                z-index: 1000;
            }

            .back-to-top.show {
                opacity: 1;
                visibility: visible;
            }
            .back-to-top:hover {
                transform: translateY(-5px);
                background: var(--accent);
                color: var(--links-text);
                border-color: var(--accent);
                box-shadow: 0 4px 15px var(--dropshadow-rgb);
            }

            @media (prefers-reduced-motion: reduce) {
                html {
                    scroll-behavior: auto !important;
                }
            }
        </style>
    </head>

    <body>
        <MainNavbar />
        <main>
            <slot />
        </main>
        <Footer />

        <button
            id="back-to-top"
            aria-label="Voltar ao topo"
            class="back-to-top"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="m18 15-6-6-6 6"></path></svg
            >
        </button>

        <script is:inline>
            // Prevents duplication of global events when the SPA navigates between pages.
            if (!window.customScrollInitialized) {
                window.customScrollInitialized = true;

                // Math scrolling function that bypasses Windows' disabled effects settings.
                function smoothScrollTo(targetPos) {
                    const startPosition = window.scrollY;
                    const distance = targetPos - startPosition;
                    const duration = 800;
                    let start = null;

                    function animation(timestamp) {
                        if (!start) start = timestamp;
                        const progress = timestamp - start;
                        const percentage = Math.min(progress / duration, 1);
                        const easing =
                            percentage < 0.5
                                ? 2 * percentage * percentage
                                : -1 + (4 - 2 * percentage) * percentage;
                        window.scrollTo(0, startPosition + distance * easing);
                        if (progress < duration)
                            window.requestAnimationFrame(animation);
                    }
                    window.requestAnimationFrame(animation);
                }

                // Click Interceptor
                // The `{ capture: true }` attribute makes this script act BEFORE the Astro's native router.
                document.addEventListener(
                    "click",
                    (e) => {
                        const link = e.target.closest('a[href^="#"]');
                        if (!link) return;
                        const targetId = link.getAttribute("href");
                        if (targetId === "#") return;

                        const targetElement = document.querySelector(targetId);
                        if (targetElement) {
                            e.preventDefault();
                            e.stopPropagation(); // Block Astro from making the instant jump

                            // Discreetly updates the URL at the top.
                            history.pushState(null, null, targetId);

                            const targetPos =
                                targetElement.getBoundingClientRect().top +
                                window.scrollY -
                                80;
                            smoothScrollTo(targetPos);
                        }
                    },
                    { capture: true },
                );
            }

            // Logic that needs to be re-executed for each new page rendered.
            document.addEventListener("astro:page-load", () => {
                if ("scrollRestoration" in history) {
                    history.scrollRestoration = "manual";
                }

                const btn = document.getElementById("back-to-top");
                const navLinks = document.querySelectorAll(".nav-link");
                const sections = document.querySelectorAll(
                    "section[id], header[id], #home",
                );

                // Scroll Spy
                const observerOptions = {
                    root: null,
                    rootMargin: "-30% 0px -70% 0px",
                    threshold: 0,
                };

                const observerCallback = (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            const id = entry.target.getAttribute("id");
                            if (!id) return;
                            navLinks.forEach((link) => {
                                link.classList.remove("active");
                                const href = link.getAttribute("href");
                                if (
                                    href &&
                                    (href.endsWith("#" + id) ||
                                        href === "#" + id)
                                ) {
                                    link.classList.add("active");
                                }
                            });
                        }
                    });

                    if (window.scrollY < 100) {
                        navLinks.forEach((link) => {
                            link.classList.remove("active");
                            if (link.getAttribute("href").includes("#home")) {
                                link.classList.add("active");
                            }
                        });
                    }
                };

                const observer = new IntersectionObserver(
                    observerCallback,
                    observerOptions,
                );
                sections.forEach((section) => observer.observe(section));

                // Back to Top Button
                if (btn) {
                    window.addEventListener("scroll", () => {
                        if (window.scrollY > 300) btn.classList.add("show");
                        else btn.classList.remove("show");
                    });

                    // Forces smooth scrolling via JS even on the back-to-top button
                    btn.addEventListener("click", () => {
                        const startPosition = window.scrollY;
                        const duration = 800;
                        let start = null;
                        function animation(timestamp) {
                            if (!start) start = timestamp;
                            const progress = timestamp - start;
                            const percentage = Math.min(progress / duration, 1);
                            const easing =
                                percentage < 0.5
                                    ? 2 * percentage * percentage
                                    : -1 + (4 - 2 * percentage) * percentage;
                            window.scrollTo(
                                0,
                                startPosition + (0 - startPosition) * easing,
                            );
                            if (progress < duration)
                                window.requestAnimationFrame(animation);
                        }
                        window.requestAnimationFrame(animation);
                    });
                }
            });
        </script>
    </body>
</html>
